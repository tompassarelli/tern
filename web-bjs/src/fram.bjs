#lang beagle/js
(ns north.fram)

;; Server-side client for the fram fact-graph daemon (:7977), TCP line protocol:
;; one EDN op per connection, JSON reply. Port of web/lib/north/fram.ex.
;;
;; SIMPLIFICATION vs the Elixir original: every op is sent with `:fmt :json`, so
;; the reply is always JSON and decodes with JSON.parse — the EDN decoder and the
;; old-daemon EDN fallback are dropped (the live coordinator speaks JSON). The
;; 1.6MB all_triples read needs no socket-buffer sizing: userland accumulates
;; chunks until the daemon closes the connection (one request per connection).

(declare-extern Bun Any)
(declare-extern JSON Any)
(declare-extern TextDecoder Any)
(declare-extern Number Any)
(declare-extern Object Any)

;; ---- low-level I/O (js/quote — inherently callback-shaped) ------------------
;; Open a socket, write one op line, accumulate the reply, resolve the raw line
;; on close. Never rejects: connect failure / socket error resolve to null.
;;
;; LEAK FIX (2026-07-10): the client MUST close its own socket on EVERY settle
;; path — success, error, and the added timeout — never trusting the daemon to
;; close first. The prior version relied solely on the daemon's close event, so
;; any op the daemon did not close (slow reply, unparsed op, no close) sat in
;; ESTABLISHED forever; under the /live re-fetch fan-out this exhausted the
;; ephemeral-port range (28,224 leaked conns → machine-wide outage). `settle`
;; is idempotent (Promise resolve ignores the 2nd call) and force-terminates the
;; socket; a 10s watchdog bounds any connection the daemon never answers.
(js/quote
  (export (async function framRequestRaw (port op)
    (return (new Promise (=> (resolve)
      (const chunks (array))
      (const decoder (new TextDecoder "utf-8" (object fatal true)))
      (let received 0)
      (let sock null)
      (let timer null)
      (let settled false)
      (const settle (=> (v)
        (if settled (return))
        (= settled true)
        (if timer (clearTimeout timer))
        (= timer null)
        (const active sock)
        (= sock null)
        (resolve v)
        (if active (try (.terminate active) (catch e null)))))
      (= timer (setTimeout (=> () (settle null)) 10000))
      (const acceptChunk (=> (socket chunk)
        (= received (+ received (dot chunk byteLength)))
        (if (> received 16777216)
          (settle null)
          (try
            (.push chunks (.decode decoder chunk (object stream true)))
            (catch e (settle null))))
        0))
      (const acceptClose (=> (socket)
        (let tail null)
        (try
          (= tail (.decode decoder))
          (catch e (return (settle null))))
        (if tail (.push chunks tail))
        (const framed (.join chunks ""))
        ;; Exactly one terminal line: EOF before LF, a second line, or trailing
        ;; bytes are framing failures. Strip an optional wire CR before LF.
        (if (! (.endsWith framed "\n")) (return (settle null)))
        (const line (.slice framed 0 -1))
        (if (.includes line "\n") (return (settle null)))
        (settle (? (.endsWith line "\r") (.slice line 0 -1) line))
        0))
      (const cp (.connect Bun (object
        hostname "127.0.0.1"
        port port
        socket (object
          open (=> (socket) (= sock socket) (.write socket (tpl "" op "\n")))
          data acceptChunk
          close acceptClose
          error (=> (socket err) (settle null))))))
      ((bracket cp "catch") (=> (err) (settle null))))))))
  ;; JSON.parse yielding null on a malformed line instead of throwing.
  (export (function safeParse (s)
    (try (return (.parse JSON s))
      (catch e (return null)))))
  ;; The coordinator canonicalizes corpus paths before comparing a fence. Use
  ;; the same realpath identity for handshake validation; no FRAM_LOG means no
  ;; wire request, never an ambient/default corpus fallback.
  (export (function runtimeCorpusLog ()
    (const configured (bracket (dot process env) "FRAM_LOG"))
    (if (! configured) (return null))
    (try
      (const fs (.getBuiltinModule process "node:fs"))
      (const canonical (.realpathSync fs configured))
      (if (! (.isFile (.statSync fs canonical))) (return null))
      (return canonical)
      (catch e (return null)))))
  (export (function runtimeWireEnvelope (op)
    (const log (runtimeCorpusLog))
    (if (! log) (return null))
    ;; JSON string literals are valid EDN strings and escape paths safely.
    (return (tpl "{:op :for-log :expected-log " (.stringify JSON log)
                 " :request " op " :fmt :json}"))))
  ;; Fram deliberately emits the long-lived subscription handshake as EDN even
  ;; when the outer request asks for JSON. Parse only its exact two-field shape;
  ;; JSON.parse is valid for the quoted Clojure string literal.
  (export (function runtimeSubscriptionHandshakeValid (line expected)
    (const match (.match line (new RegExp "^\\{:subscribed\\s+(\\d+),?\\s+:log\\s+(\"(?:\\\\.|[^\"\\\\])*\")\\}$")))
    (if (! match) (return false))
    (const version (Number (bracket match 1)))
    (let log null)
    (try (= log (.parse JSON (bracket match 2)))
      (catch e (return false)))
    (if (! (.isSafeInteger Number version)) (return false))
    (if (< version 0) (return false))
    (return (=== log expected))))
  ;; numeric parse helpers (JS Number semantics)
  (export (function parseIntSafe (v)
    (const n (parseInt (String v) 10))
    (return (? (isNaN n) 0 n))))
  ;; Provider token facts are non-negative safe integers. Keep malformed or
  ;; absent facts nullable so reporting never turns unknown usage into zero.
  (export (function parseTokenCount (v)
    (if (=== v null) (return null))
    (if (=== v undefined) (return null))
    (if (=== v "") (return null))
    (const n (Number v))
    (if (.isSafeInteger Number n)
      (if (>= n 0) (return n)))
    (return null)))
  (export (function parseFloatSafe (v)
    (const n (parseFloat (String v)))
    (return (? (isNaN n) 0 n))))
  ;; Agent-roster reads are deliberately two indexed coordinator calls:
  ;; one lease scan, then one subject-literal union for only unexpired controls.
  ;; Control ids came from graph data, so validate + JSON-encode every literal
  ;; before it enters the EDN query. Bounds fail closed instead of recreating the
  ;; old N-handles × N-fields timeout surface.
  (const SESSION_LEASE_PREFIX "@lease:session:")
  (const MAX_AGENT_LEASE_ROWS 100000)
  (const MAX_LIVE_AGENT_CONTROLS 256)
  (const MAX_AGENT_CONTROL_BYTES 256)
  (const MAX_AGENT_BUNDLE_QUERY_BYTES 262144)
  (const MAX_AGENT_BUNDLE_ROWS 32768)
  (const CONTROL_RE (new RegExp "^[A-Za-z0-9][A-Za-z0-9._:-]*$"))
  (const LEASE_INT_RE (new RegExp "^[0-9]+$"))
  (export (function validCoordinatorQuery (response)
    (if (or (=== response null)
            (or (!== (typeof response) "object") (.isArray Array response)))
      (return false))
    (const keys (.sort (.keys Object response)))
    (if (!== (.join keys ",") "engine,ok,version") (return false))
    (if (! (.isArray Array (dot response ok))) (return false))
    (if (or (! (.isSafeInteger Number (dot response version)))
            (< (dot response version) 0))
      (return false))
    (return (or (=== (dot response engine) "index")
                (=== (dot response engine) "scan")))))
  (export (function validAgentControl (value)
    (if (! (=== (typeof value) "string")) (return false))
    (if (> (.byteLength Buffer value "utf8") MAX_AGENT_CONTROL_BYTES) (return false))
    (return (.test CONTROL_RE value))))
  (export (function liveAgentLeases (rows now)
    (if (! (.isArray Array rows)) (return null))
    (if (> (dot rows length) MAX_AGENT_LEASE_ROWS) (return null))
    (const live (new Map))
    (const seen-session-entities (new Set))
    (let valid true)
    (.forEach rows (=> (row)
      (const row-valid (.isArray Array row))
      (if (! row-valid) (= valid false))
      (if (! row-valid) (return))
      (const row-shape-valid (=== (dot row length) 2))
      (if (! row-shape-valid) (= valid false))
      (if (! row-shape-valid) (return))
      (const entity (bracket row 0))
      (const value (bracket row 1))
      (const entity-valid
        (and (=== (typeof entity) "string") (!== entity "")))
      (if (! entity-valid) (= valid false))
      (if (! entity-valid) (return))
      (const value-valid (=== (typeof value) "string"))
      (if (! value-valid) (= valid false))
      (if (! value-valid) (return))
      (const parts (.split value "|"))
      (const parts-valid (=== (dot parts length) 3))
      (if (! parts-valid) (= valid false))
      (if (! parts-valid) (return))
      (const holder (bracket parts 0))
      (const exp-text (bracket parts 1))
      (const epoch-text (bracket parts 2))
      (const lease-text-valid
        (and (!== holder "")
             (and (.test LEASE_INT_RE exp-text)
                  (.test LEASE_INT_RE epoch-text))))
      (if (! lease-text-valid) (= valid false))
      (if (! lease-text-valid) (return))
      (const exp (Number exp-text))
      (const epoch (Number epoch-text))
      (const lease-number-valid
        (and (.isSafeInteger Number exp) (.isSafeInteger Number epoch)))
      (if (! lease-number-valid) (= valid false))
      (if (! lease-number-valid) (return))
      (if (! (.startsWith entity SESSION_LEASE_PREFIX)) (return))
      (if (.has seen-session-entities entity) (= valid false))
      (if (.has seen-session-entities entity) (return))
      (.add seen-session-entities entity)
      (const control (.slice entity (dot SESSION_LEASE_PREFIX length)))
      (const control-valid
        (and (validAgentControl control) (=== holder control)))
      (if (! control-valid) (= valid false))
      (if (! control-valid) (return))
      (if (> exp now) (.set live control exp))))
    (if (! valid) (return null))
    (const controls (.sort (.from Array (.keys live))))
    (if (> (dot controls length) MAX_LIVE_AGENT_CONTROLS) (return null))
    (const leases (array))
    (.forEach controls (=> (control)
      (const lease (object control control))
      ;; Use an explicit property string: raw identifier underscore escaping is
      ;; for Beagle symbols (`expires_s` would compile to `expires__s`).
      (= (bracket lease "expires_s")
         (.floor Math (/ (- (.get live control) now) 1000)))
      (.push leases lease)))
    (return leases)))
  (export (function liveAgentControls (rows now)
    (const leases (liveAgentLeases rows now))
    (if (=== leases null) (return null))
    (return (.map leases (=> (lease) (dot lease control))))))
  (export (function agentBundleOp (controls)
    (if (! (.isArray Array controls)) (return null))
    (if (> (dot controls length) MAX_LIVE_AGENT_CONTROLS) (return null))
    (const unique (.sort (.from Array (new Set controls))))
    (if (! (.every unique (=> (control) (validAgentControl control)))) (return null))
    (const rules (array))
    (.forEach unique (=> (control)
      (.forEach (array (tpl "@agent:" control) (tpl "@session:" control)) (=> (subject)
        (const literal (.stringify JSON subject))
        (.push rules
          (tpl "{:head {:rel \"agent_bundle\" :args [" literal
               " {:var \"p\"} {:var \"o\"}]} :body [{:rel \"triple\" :args ["
               literal " {:var \"p\"} {:var \"o\"}]}]}"))))))
    (const op
      (tpl "{:op :query :query {:find \"agent_bundle\" :rules ["
           (.join rules " ") "]}}"))
    (if (> (.byteLength Buffer op "utf8") MAX_AGENT_BUNDLE_QUERY_BYTES) (return null))
    (return op)))
  (export (function validAgentBundleRow (row)
    (if (! (.isArray Array row)) (return false))
    (if (! (=== (dot row length) 3)) (return false))
    (if (! (=== (typeof (bracket row 0)) "string")) (return false))
    (if (! (=== (typeof (bracket row 1)) "string")) (return false))
    (if (! (=== (typeof (bracket row 2)) "string")) (return false))
    (const subject (bracket row 0))
    (if (.startsWith subject "@agent:")
      (return (validAgentControl (.slice subject 7))))
    (if (.startsWith subject "@session:")
      (return (validAgentControl (.slice subject 9))))
    (return false)))
  (export (function boundedAgentBundleRows (rows controls)
    (if (! (.isArray Array rows)) (return null))
    (if (> (dot rows length) MAX_AGENT_BUNDLE_ROWS) (return null))
    (if (! (.every rows (=> (row) (validAgentBundleRow row))))
      (return null))
    (if controls
      (const allowed (new Set (.map controls (=> (control) (tpl "@agent:" control)))))
      (.forEach controls (=> (control) (.add allowed (tpl "@session:" control))))
      (if (! (.every rows (=> (row) (.has allowed (bracket row 0)))))
        (return null)))
    (return rows)))
  ;; lexical >= for ISO-8601 strings (Beagle >= is numeric).
  (export (function strGte (a b)
    (return (>= a b))))
  ;; The coordinator's generic all-triples projection intentionally omits
  ;; split-log run telemetry. Fold the two append logs mechanically instead;
  ;; no model turn and no price reconstruction. Highest tx wins per run/pred.
  (let runUsageCache (object sig "" triples (array)))
  (export (async function runUsageTriplesFromLogs ()
    (const home (or (dot (dot process env) HOME) ""))
    (const configured (array
      (or (bracket (dot process env) "FRAM_LOG") (tpl "" home "/.local/state/north/coordination.log"))
      (or (bracket (dot process env) "FRAM_TELEMETRY_LOG") (tpl "" home "/.local/state/north/telemetry.log"))))
    (const paths (.from Array (new Set configured)))
    (const files (.map paths (=> (path) (.file Bun path))))
    (const sig (.join (.map files (=> (f i) (tpl "" (bracket paths i) ":" (dot f size) ":" (dot f lastModified)))) "|"))
    (if (=== sig (dot runUsageCache sig)) (return (dot runUsageCache triples)))
    (const texts (await (.all Promise (.map files (=> (f)
      ((bracket (.text f) "catch") (=> (e) "")))))))
    (const latest (new Map))
    (const re (new RegExp ":tx\\s+(\\d+).*?:op\\s+\"([^\"]+)\".*?:l\\s+\"(@run[:-][^\"]+)\".*?:p\\s+\"(agent|tokens|input_tokens|output_tokens|cache_create_tokens|cache_read_tokens|cached_input_tokens|reasoning_output_tokens|usage_terminal_count|usage_scope|usage_total_status|at|ended_at)\".*?:r\\s+\"((?:\\\\.|[^\"])*)\""))
    (.forEach texts (=> (text)
      (.forEach (.split text "\n") (=> (line)
        (const m (.match line re))
        (if m
          (const tx (parseInt (bracket m 1) 10))
          (const op (bracket m 2))
          (const s (bracket m 3))
          (const p (bracket m 4))
          (const raw (bracket m 5))
          (let value null)
          (try (= value (.parse JSON (tpl "\"" raw "\"")))
            (catch e (= value null)))
          (const key (tpl "" s "\u0000" p))
          (const prev (.get latest key))
          (if (and (!== value null) (or (! prev) (> tx (dot prev tx))))
            (if (=== op "retract")
              ((bracket latest "delete") key)
              (.set latest key (object tx tx s s p p o value)))))))))
    (const triples (.map (.from Array (.values latest)) (=> (x) (array (dot x s) (dot x p) (dot x o)))))
    (= runUsageCache (object sig sig triples triples))
    (return triples))))

(declare-extern framRequestRaw [Int String -> (Promise String)])
(declare-extern safeParse [String -> Any])
(declare-extern runtimeCorpusLog [-> Any])
(declare-extern runtimeWireEnvelope [String -> Any])
(declare-extern runtimeSubscriptionHandshakeValid [String String -> Bool])
(declare-extern parseIntSafe [Any -> Int])
(declare-extern parseTokenCount [Any -> Any])
(declare-extern parseFloatSafe [Any -> Float])
(declare-extern validAgentControl [Any -> Bool])
(declare-extern validCoordinatorQuery [Any -> Bool])
(declare-extern liveAgentLeases [Any Int -> Any])
(declare-extern liveAgentControls [Any Int -> Any])
(declare-extern agentBundleOp [Any -> Any])
(declare-extern validAgentBundleRow [Any -> Bool])
(declare-extern boundedAgentBundleRows [Any Any -> Any])
(declare-extern strGte [String String -> Bool])
(declare-extern runUsageTriplesFromLogs [-> (Promise Any)])
(declare-extern process Any)

;; ---- corpus selector ---------------------------------------------------------

(js/export (defn port-for [(graph :- String) (configured-port :- Int)] :- Int
  ;; Never reinterpret a retired/unknown corpus selector as the board. A zero
  ;; port is the explicit invalid-domain sentinel consumed by the API boundary.
  (if (or (nil? graph) (= graph "") (= graph "board")) configured-port 0)))

;; ---- generic query ----------------------------------------------------------
;; Wrap every operation in the explicit FRAM_LOG corpus fence and request JSON
;; at the OUTER connection boundary. Missing/nonexistent FRAM_LOG fails closed.
(js/export (defn corpus-log [] :- Any
  (runtimeCorpusLog)))

(js/export (defn wire-envelope [(op :- String)] :- Any
  (runtimeWireEnvelope op)))

(js/export (defn subscription-handshake-valid? [(line :- String) (expected-log :- String)] :- Bool
  (runtimeSubscriptionHandshakeValid line expected-log)))

(defn query [(port :- Int) (op :- String)] :- (Promise Any)
  (let [wire (wire-envelope op)]
    (if (nil? wire)
      nil
      (let [line (js/await (framRequestRaw port wire))]
        (if (nil? line) nil (safeParse line))))))

;; ---- writes (OCC: read version → assert/retract with :base → retry) --------

(defn esc [(s :- String)] :- String
  (.replaceAll (.replaceAll s "\\" "\\\\") "\"" "\\\""))

(defrecord WriteResult [(status :- String) (value :- Any) (reason :- String)])

(defn version [(port :- Int)] :- (Promise Any)
  (let [resp (js/await (query port "{:op :version}"))]
    (if (nil? resp) nil (.-version resp))))

(defn rejected? [(resp :- Any)] :- Bool
  (or (some? (.-reject resp)) (some? (.-conflict resp))))

(defn occ [(port :- Int) (op :- String) (te :- String) (p :- String) (r :- String) (tries :- Int)] :- (Promise WriteResult)
  (if (<= tries 0)
    (->WriteResult "conflict" nil "tries_exhausted")
    (let [v (js/await (version port))]
      (if (nil? v)
        (->WriteResult "error" nil "nodaemon")
        (let [edn (str "{:op :" op " :te \"" (esc te) "\" :p \"" (esc p) "\" :r \"" (esc r) "\" :base " v "}")
              resp (js/await (query port edn))]
          (cond
            (nil? resp) (->WriteResult "error" nil "no_response")
            (some? (.-ok resp)) (->WriteResult "ok" (.-ok resp) "")
            (some? (.-version resp)) (->WriteResult "ok" (.-version resp) "")
            (rejected? resp) (js/await (occ port op te p r (- tries 1)))
            :else (->WriteResult "ok" resp "")))))))

(js/export (defn assert! [(port :- Int) (te :- String) (p :- String) (r :- String)] :- (Promise WriteResult)
  (occ port "assert" te p r 5)))

(js/export (defn retract! [(port :- Int) (te :- String) (p :- String) (r :- String)] :- (Promise WriteResult)
  (occ port "retract" te p r 5)))

;; ---- EDN op builders --------------------------------------------------------

(def roster-op :- String
  "{:op :query :query {:find \"s\" :rules [{:head {:rel \"s\" :args [{:var \"e\"} {:var \"h\"}]} :body [{:rel \"triple\" :args [{:var \"e\"} \"agent\" {:var \"h\"}]}]}]}}")

(def all-triples-op :- String
  "{:op :query :query {:find \"t\" :rules [{:head {:rel \"t\" :args [{:var \"s\"} {:var \"p\"} {:var \"o\"}]} :body [{:rel \"triple\" :args [{:var \"s\"} {:var \"p\"} {:var \"o\"}]}]}]}}")

(def session-leases-op :- String
  "{:op :query :query {:find \"session_lease\" :rules [{:head {:rel \"session_lease\" :args [{:var \"e\"} {:var \"v\"}]} :body [{:rel \"triple\" :args [{:var \"e\"} \"lease\" {:var \"v\"}]}]}]}}")

(defn resolved-op [(te :- String) (pred :- String)] :- String
  (str "{:op :resolved :te \"" te "\" :p \"" pred "\"}"))

;; ---- accessors (mirror fram.ex) --------------------------------------------

(defn to-s [(v :- Any)] :- String (str v))

;; [[session_entity, handle], ...] — one row per live @session:* handle, deduped.
(js/export (defn agents [(port :- Int)] :- (Promise Any)
  (let [resp (js/await (query port roster-op))]
    (if (or (nil? resp) (nil? (.-ok resp)))
      []
      (let [sess (filterv (fn [row] (.startsWith (nth row 0) "@session:")) (.-ok resp))
            m (reduce (fn [acc row] (assoc acc (nth row 1) row)) {} sess)]
        (vals m))))))

;; One lease query plus one indexed union query for the complete raw facts of
;; live agent/session subjects. An expired lease never contributes a subject;
;; a just-finished lane remains present until that same lease lapses.
(js/export (defn agent-live-leases [(port :- Int) (now :- Int)] :- (Promise Any)
  (let [lease-resp (js/await (query port session-leases-op))
        lease-rows (if (validCoordinatorQuery lease-resp) (.-ok lease-resp) nil)]
    (liveAgentLeases lease-rows now))))

(js/export (defn agent-roster-bundle [(port :- Int) (now :- Int)] :- (Promise Any)
  (let [leases (js/await (agent-live-leases port now))
        controls (if (nil? leases) nil (.map leases (fn [lease] (.-control lease))))]
    (if (nil? leases)
      {"controls" [] "leases" [] "rows" [] "bounded" false}
      (if (= (count controls) 0)
        {"controls" controls "leases" leases "rows" [] "bounded" true}
        (let [op (agentBundleOp controls)]
          (if (nil? op)
            {"controls" [] "leases" [] "rows" [] "bounded" false}
            (let [resp (js/await (query port op))
                  rows (if (not (validCoordinatorQuery resp)) nil
                         (boundedAgentBundleRows (.-ok resp) controls))]
              (if (nil? rows)
                {"controls" [] "leases" [] "rows" [] "bounded" false}
                {"controls" controls "leases" leases "rows" rows "bounded" true})))))))))

;; Single resolved value for entity+predicate, or nil.
(js/export (defn resolved [(port :- Int) (te :- String) (pred :- String)] :- (Promise Any)
  (let [resp (js/await (query port (resolved-op te pred)))]
    (if (or (nil? resp) (nil? (.-value resp))) nil (to-s (.-value resp))))))

;; All resolved values for entity+predicate, as JS array of strings.
(js/export (defn resolved-many [(port :- Int) (te :- String) (pred :- String)] :- (Promise Any)
  (let [resp (js/await (query port (resolved-op te pred)))]
    (if (or (nil? resp) (nil? (.-values resp)))
      []
      (.map (.-values resp) (fn [v] (to-s v)))))))

;; Latest resolved value: values is oldest→newest, so last is current; else :value.
(js/export (defn latest [(port :- Int) (te :- String) (pred :- String)] :- (Promise Any)
  (let [resp (js/await (query port (resolved-op te pred)))]
    (if (nil? resp)
      nil
      (let [vs (.-values resp)]
        (cond
          (and (some? vs) (> (.-length vs) 0)) (to-s (nth vs (- (.-length vs) 1)))
          (some? (.-value resp)) (to-s (.-value resp))
          :else nil))))))

;; Every [s,p,o] triple (strings). The 1.6MB hot read.
(js/export (defn all-triples [(port :- Int)] :- (Promise Any)
  (let [resp (js/await (query port all-triples-op))]
    (if (or (nil? resp) (nil? (.-ok resp)))
      []
      (.map (.-ok resp) (fn [row]
        [(to-s (nth row 0)) (to-s (nth row 1)) (to-s (nth row 2))]))))))

;; ---- token usage fold -------------------------------------------------------

(defn token-pred? [(p :- String)] :- Bool
  (or (= p "input_tokens") (= p "output_tokens")
      (= p "cache_create_tokens") (= p "cache_read_tokens")
      (= p "cached_input_tokens") (= p "reasoning_output_tokens")
      (= p "tokens")))

(defn usage-meta-pred? [(p :- String)] :- Bool
  (or (= p "usage_terminal_count") (= p "usage_scope")
      (= p "usage_total_status")))

(defn run-subject? [(s :- String)] :- Bool
  (or (.startsWith s "@run:") (.startsWith s "@run-")))

(defn legacy-component-total [(r :- Any)] :- Any
  (let [input (parseTokenCount (get r "input_tokens"))
        output (parseTokenCount (get r "output_tokens"))
        cache-create (parseTokenCount (get r "cache_create_tokens"))
        cache-read (parseTokenCount (get r "cache_read_tokens"))]
    ;; Historical Anthropic runs predate usage_total_status but recorded all
    ;; four disjoint terminal categories. A partial component row is ambiguous.
    (if (and (some? input) (some? output)
             (some? cache-create) (some? cache-read))
      (+ input (+ output (+ cache-create cache-read)))
      nil)))

(js/export (defn run-tot [(r :- Any)] :- Any
  (let [status (get r "usage_total_status")
        aggregate (parseTokenCount (get r "tokens"))]
    (cond
      ;; Once structured status exists it owns truth: only exact + aggregate is
      ;; a total. Component subsets remain observable but are never summed.
      (some? status) (if (and (= status "exact") (some? aggregate)) aggregate nil)
      ;; Aggregate-only rows are historical exact telemetry.
      (some? aggregate) aggregate
      :else (legacy-component-total r)))))

(js/export (defn run-context [(r :- Any)] :- Any
  (parseTokenCount (get r "input_tokens"))))

(js/export (defn run-ended [(r :- Any)] :- String
  (get r "at" (get r "ended_at" ""))))

(defn fold-run [(out :- Any) (r :- Any)] :- Any
  (let [h (get r "agent")]
    (if (nil? h)
      out
      (let [tot (run-tot r)
            ctx (run-context r)
            ended (run-ended r)
            exact (some? tot)
            prev (get out h)]
        (if (nil? prev)
          (assoc out h {"context" ctx
                        "context_status" (if (some? ctx) "exact" "unknown")
                        "total" tot
                        "total_status" (if exact "exact" "unknown")
                        "exact_runs" (if exact 1 0)
                        "unknown_runs" (if exact 0 1)
                        "ended" ended})
          (let [newer (strGte ended (get prev "ended" ""))]
            (let [exact-runs (+ (get prev "exact_runs") (if exact 1 0))
                  unknown-runs (+ (get prev "unknown_runs") (if exact 0 1))
                  prev-total (get prev "total")
                  known-total (+ (if (some? prev-total) prev-total 0) (if exact tot 0))]
              (assoc out h {"context" (if newer ctx (get prev "context"))
                            "context_status" (if newer
                                               (if (some? ctx) "exact" "unknown")
                                               (get prev "context_status"))
                            "total" (if (> exact-runs 0) known-total nil)
                            "total_status" (cond
                                             (> unknown-runs 0) (if (> exact-runs 0) "incomplete" "unknown")
                                             :else "exact")
                            "exact_runs" exact-runs
                            "unknown_runs" unknown-runs
                            "ended" (if newer ended (get prev "ended"))}))))))))

;; Per-handle token usage: {handle => {context: latest_input_tokens, total: sum}}.
(js/export (defn agent-tokens [(port :- Int)] :- (Promise Any)
  (let [trips (js/await (runUsageTriplesFromLogs))
        runs (reduce (fn [acc t]
                       (let [s (nth t 0) p (nth t 1) o (nth t 2)]
                         (if (and (run-subject? s)
                                  (or (= p "agent") (= p "at") (= p "ended_at")
                                      (token-pred? p) (usage-meta-pred? p)))
                           (assoc acc s (assoc (get acc s {}) p o))
                           acc)))
                     {} trips)]
    (reduce fold-run {} (vals runs)))))
