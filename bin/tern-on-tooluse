#!/usr/bin/env bash
# tern-on-tooluse — Claude Code PostToolUse "mail heartbeat".
# After EVERY tool call, surface any new tern peer-messages for this agent via
# hookSpecificOutput.additionalContext — no background task, no re-arm. Must NEVER block
# or error out a tool call: bounded by `timeout`, swallows errors, always exits 0. jq-free
# (jq isn't on PATH) — same sed/jget + agent-id derivation as tern-on-spawn so ids match.
set -uo pipefail
IN="$(cat 2>/dev/null || true)"
# pull a flat JSON string field without jq
jget() { printf '%s' "$IN" | sed -n "s/.*\"$1\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p" | head -1; }
cwd="$(jget cwd)"; [ -z "$cwd" ] && cwd="$PWD"
sid="$(jget session_id)"
REPO="$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null || echo "$cwd")"
RN="$(basename "$REPO")"
# identity resolution: per-session cache (written by tern-on-spawn — the per-sid
# truth) -> env pin -> legacy cwd derivation. Cache BEFORE env is deliberate: env is
# ambient and INHERITABLE, so a parent's TERN_AGENT_ID leaks into every subagent;
# preferring env aliased them onto the parent id (2026-07-03, mail answered by the
# wrong actor). The cache is keyed by session_id, so it cannot alias. Env stays only
# as a fallback for a process whose spawn hook never fired (e.g. SDK-dispatched).
# Deriving from each tool call's cwd minted a phantom agent per repo (flood 2026-07-02).
CACHE="${XDG_RUNTIME_DIR:-/tmp}/tern-agent-ids/$sid"
ID=""
if [ -n "$sid" ] && [ -r "$CACHE" ]; then
  ID="$(cat "$CACHE" 2>/dev/null || true)"
fi
[ -z "$ID" ] && ID="${TERN_AGENT_ID:-}"
[ -z "$ID" ] && ID="cc-$RN-${sid:0:8}"
[ "$ID" = "cc-$RN-" ] && ID="cc-$RN-$RANDOM"

# renew presence — the 30min lease "renew every ~3min" the docs promise but nothing did.
# Every tool call refreshes it, so an ACTIVE agent stays online (its concerns stay visible);
# a dead/idle session stops calling tools -> lease lapses -> its concerns auto-hide.
timeout 5 bb "$HOME/code/tern/cli/presence-cli.clj" "${TERN_PORT:-7977}" register "$ID" "$REPO" "$ID" >/dev/null 2>&1 || true

# peek + ack inbox — bounded; failure is silent (never wedge a tool call)
MAIL="$(timeout 6 bb "$HOME/code/tern/cli/inbox-peek.clj" 7977 "$ID" 2>/dev/null || true)"
[ -z "$MAIL" ] && exit 0

CTX="[tern] new peer message(s):
$MAIL"
# emit additionalContext as valid JSON (escape \  then "  then newlines -> \n)
esc="$(printf '%s' "$CTX" | sed 's/\\/\\\\/g; s/"/\\"/g' | sed ':a;N;$!ba;s/\n/\\n/g')"
printf '{"hookSpecificOutput":{"hookEventName":"PostToolUse","additionalContext":"%s"}}\n' "$esc"
exit 0
