#!/usr/bin/env bash
# north-timelog — invoice-ready worklog CSV from north billing facts.
# Reuses the fram fold engine (same view north itself reads). CSV -> stdout,
# grouped-by-invoice totals -> stderr, so `north-timelog msa > invoice.csv` is clean.
#   north-timelog [owner] [invoice_id]
set -euo pipefail
NORTH="$(cd "$(dirname "$0")/.." && pwd)"
FRAM="${FRAM_HOME:-$HOME/code/fram}"
if [ -z "${FRAM_LOG:-}" ]; then
  if [ -f "$HOME/.local/state/north/coordination.log" ]; then
    export FRAM_LOG="$HOME/.local/state/north/coordination.log"
  else
    export FRAM_LOG="$HOME/.local/state/north/facts.log"
  fi
fi
exec bb -cp "$NORTH/out:$FRAM/out" "$NORTH/cli/north-timelog.clj" "$@"
