#!/usr/bin/env bash
# ensure-private-docs — make docs/private/ a gitignored sink for internal agent
# notes in THIS repo. Idempotent; safe to run on every session start.
#
# Convention (north thread 019f1194-d4b7): internal notes / status / scratch /
# handoffs go in docs/private/ (gitignored), NEVER in public docs/. This guarantees
# the ignore rule exists BEFORE anything is written there, so a stray `git add` of an
# internal note can't leak it to a public repo.
set -euo pipefail
repo="${1:-$PWD}"
repo="${repo/#\~/$HOME}"
cd "$repo" 2>/dev/null || exit 0
git rev-parse --git-dir >/dev/null 2>&1 || exit 0          # not a git repo -> nothing to ignore
gi="$(git rev-parse --show-toplevel)/.gitignore"
line="docs/private/"

grep -qxF "$line" "$gi" 2>/dev/null && exit 0              # already ignored -> idempotent no-op

# append with a separating blank line if the file exists and lacks a trailing newline
[ -f "$gi" ] && [ -n "$(tail -c1 "$gi" 2>/dev/null)" ] && printf '\n' >> "$gi"
{
  printf '\n# Internal agent notes / status / scratch / handoffs — NOT user-facing docs.\n'
  printf '# Keep out of git. Put private notes under docs/private/.\n'
  printf '%s\n' "$line"
} >> "$gi"
echo "ensure-private-docs: added '$line' to $gi"
