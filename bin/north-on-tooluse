#!/usr/bin/env bash
# north-on-tooluse — Claude Code / Codex PostToolUse "mail heartbeat".
# After EVERY tool call, surface any new north peer-messages for this agent via
# hookSpecificOutput.additionalContext — no background task, no re-arm. Must NEVER block
# or error out a tool call: bounded by `timeout`, swallows errors, always exits 0.
# Input and output both use Python's JSON parser/serializer; no hand-built escaping.
set -uo pipefail
umask 077

# The provider harness gives this hook 10s, but several individually bounded
# best-effort operations below can otherwise add up past that outer limit. Run
# the implementation behind one much smaller circuit breaker and buffer stdout:
# a timeout/crash therefore becomes an empty, successful hook response rather
# than a provider-visible PostToolUse failure or a truncated JSON envelope.
# Identity repair is retryable because its convergence cache is written only
# after every projection write succeeds.
if [ "${NORTH_TOOLUSE_INNER:-0}" != 1 ]; then
  out_dir="${XDG_RUNTIME_DIR:-/tmp}"
  timeout --signal=TERM --kill-after=0.1s 0.3s mkdir -p "$out_dir" 2>/dev/null || out_dir=/tmp
  out="$(timeout --signal=TERM --kill-after=0.1s 0.3s \
    mktemp "$out_dir/north-tooluse-output.XXXXXX" 2>/dev/null || true)"
  [ -n "$out" ] || exit 0
  trap 'timeout --signal=TERM --kill-after=0.1s 0.2s rm -f "$out" 2>/dev/null || true' EXIT
  NORTH_TOOLUSE_INNER=1 timeout --signal=TERM --kill-after=0.2s 4s "$0" >"$out" 2>/dev/null || true
  if [ -s "$out" ] &&
      timeout --signal=TERM --kill-after=0.1s 0.5s python3 -c '
import json, sys
with open(sys.argv[1], encoding="utf-8") as handle:
    payload = json.load(handle)
specific = payload["hookSpecificOutput"]
assert specific["hookEventName"] == "PostToolUse"
assert isinstance(specific["additionalContext"], str)
' "$out" 2>/dev/null; then
    timeout --signal=TERM --kill-after=0.1s 0.5s cat "$out" 2>/dev/null || true
  fi
  exit 0
fi

# Parse the envelope once. Tool responses can be tens of megabytes; retaining
# the full payload in a shell variable and rescanning it with sed for every
# field made hook cost O(fields × payload). Python is already a global harness
# dependency and its JSON parser gives us one O(payload) pass plus correct
# top-level/structured-field semantics.
PARSED="$(python3 -c '
import json, sys
try:
    d = json.load(sys.stdin)
    effort = d.get("effort")
    effort = effort.get("level", "") if isinstance(effort, dict) else ""
    values = (d.get("cwd", ""), d.get("session_id", ""), d.get("agent_id", ""), effort)
    for value in values:
        value = value if isinstance(value, str) else ""
        print(value.replace("\n", "").replace("\r", ""))
except Exception:
    pass
' 2>/dev/null || true)"
mapfile -t JFIELDS <<<"$PARSED"
cwd="${JFIELDS[0]:-}"; [ -z "$cwd" ] && cwd="$PWD"
sid="${JFIELDS[1]:-}"
agent_id="${JFIELDS[2]:-}"
EFFORT="${JFIELDS[3]:-}"
IDDIR="${XDG_RUNTIME_DIR:-/tmp}/north-agent-ids"
# `agent_id` is ambiguous across provider hook surfaces: SubagentStart uses it
# as the native actor id, while some PostToolUse emitters use an invocation-local
# id that changes every call. It is actor evidence only when north-on-spawn has
# already staked that exact key. Otherwise the stable session owns this tool
# event. An unseen agent_id is never allowed to mint a roster row.
agent_key="$(printf '%s' "$agent_id" | sed 's/[^A-Za-z0-9._-]/_/g')"
spawn_staked_agent=0
if [ -n "$agent_id" ] && [ -r "$IDDIR/$agent_key" ]; then
  identity_key_source="$agent_id"
  spawn_staked_agent=1
elif [ -n "$sid" ]; then
  identity_key_source="$sid"
elif [ -n "${NORTH_AGENT_ID:-}" ]; then
  identity_key_source="managed-${NORTH_AGENT_ID:-}"
else
  exit 0
fi
identity_key="$(printf '%s' "$identity_key_source" | sed 's/[^A-Za-z0-9._-]/_/g')"
REPO="$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null || echo "$cwd")"
RN="$(basename "$REPO")"
# identity resolution: per-session cache (written by north-on-spawn — the per-sid
# truth) -> env pin -> legacy cwd derivation. Cache BEFORE env is deliberate: env is
# ambient and INHERITABLE, so a parent's NORTH_AGENT_ID leaks into every subagent;
# preferring env aliased them onto the parent id (2026-07-03, mail answered by the
# wrong actor). The cache is keyed by session_id, so it cannot alias. Env stays only
# as a fallback for a process whose spawn hook never fired (e.g. SDK-dispatched).
# Deriving from each tool call's cwd minted a phantom agent per repo (flood 2026-07-02).
CACHE="${XDG_RUNTIME_DIR:-/tmp}/north-agent-ids/$identity_key"
ROUTE_CACHE="${XDG_RUNTIME_DIR:-/tmp}/north-agent-routes/$identity_key"
ROUTE_SEED="$ROUTE_CACHE.seed"
ID=""
if [ -r "$CACHE" ]; then
  ID="$(cat "$CACHE" 2>/dev/null || true)"
fi
[ "$spawn_staked_agent" -eq 1 ] && [ -z "$ID" ] && exit 0
[ -z "$ID" ] && ID="${NORTH_AGENT_ID:-}"
[ -z "$ID" ] && ID="session-$RN-${sid:0:8}"

# Claude PostToolUse receives the effective effort used for the turn, both as
# the structured input field and CLAUDE_EFFORT; Codex does not currently expose
# effort to hooks. Neither surface sends the active model at PostToolUse,
# so the per-session route cache carries only the last exact SessionStart model;
# never infer one from tool input or ambient ANTHROPIC_MODEL.
[ -n "$EFFORT" ] || EFFORT="${CLAUDE_EFFORT:-}"
cached_provider=""; cached_model=""; cached_effort=""
if [ -r "$ROUTE_CACHE" ]; then
  cached_provider="$(sed -n '1p' "$ROUTE_CACHE" 2>/dev/null || true)"
  cached_model="$(sed -n '2p' "$ROUTE_CACHE" 2>/dev/null || true)"
  cached_effort="$(sed -n '3p' "$ROUTE_CACHE" 2>/dev/null || true)"
fi
seed_provider=""; seed_model=""; seed_effort=""
if [ ! -r "$ROUTE_CACHE" ] && [ -r "$ROUTE_SEED" ]; then
  seed_provider="$(sed -n '1p' "$ROUTE_SEED" 2>/dev/null || true)"
  seed_model="$(sed -n '2p' "$ROUTE_SEED" 2>/dev/null || true)"
  seed_effort="$(sed -n '3p' "$ROUTE_SEED" 2>/dev/null || true)"
fi

# Acquire a per-session singleflight directory, reclaiming it only after the
# worker's own deadline plus a safety margin. Runtime-dir cleanup handles reboot;
# this handles a worker SIGKILL without suppressing repair for the session.
acquire_singleflight() {
  local lock="$1" stale_after_s="$2" now_s modified_s
  mkdir "$lock" 2>/dev/null && return 0
  now_s="$(date +%s 2>/dev/null || echo 0)"
  modified_s="$(stat -c %Y "$lock" 2>/dev/null || echo 0)"
  case "$now_s:$modified_s" in
    *[!0-9:]*|0:*|*:0) return 1 ;;
  esac
  [ $((now_s - modified_s)) -ge "$stale_after_s" ] || return 1
  rmdir "$lock" 2>/dev/null || return 1
  mkdir "$lock" 2>/dev/null
}

# Coalesce native identity convergence behind one background publisher. The
# PostToolUse foreground must stay a mail fast-path; it must not launch seven
# serial `north tell` processes before looking for mail. One Babashka process
# loads the shared coordinator client once, publishes the complete projection,
# and only then advances the route cache. The mkdir is a per-session singleflight
# gate, while the worker's shared deadline bounds even a delayed/down daemon.
schedule_projection_repair() {
  local provider="$1" model="$2" effort="$3" display="$4"
  local lock="${ROUTE_CACHE}.repair.lock"
  local route_tmp="${ROUTE_CACHE}.$$.${RANDOM}.tmp"
  local current_provider="" current_model="" current_effort=""
  mkdir -p "$(dirname "$ROUTE_CACHE")" 2>/dev/null || return 0
  acquire_singleflight "$lock" 10 || return 0
  # A concurrent cold hook may have decided repair was needed before the first
  # publisher committed its cache. Recheck after winning the lock so a burst
  # cannot serialize redundant publishers behind the singleflight gate.
  if [ -r "$ROUTE_CACHE" ]; then
    current_provider="$(sed -n '1p' "$ROUTE_CACHE" 2>/dev/null || true)"
    current_model="$(sed -n '2p' "$ROUTE_CACHE" 2>/dev/null || true)"
    current_effort="$(sed -n '3p' "$ROUTE_CACHE" 2>/dev/null || true)"
  fi
  if [ "$current_provider" = "$provider" ] &&
      [ "$current_model" = "$model" ] &&
      [ "$current_effort" = "$effort" ]; then
    rmdir "$lock" 2>/dev/null || true
    return 0
  fi
  (
    trap 'rm -rf "$lock" 2>/dev/null || true' EXIT
    if timeout --signal=TERM --kill-after=0.2s 6s env \
        NORTH_NATIVE_PORT="${NORTH_PORT:-7977}" \
        NORTH_NATIVE_SUBJECT="@agent:$ID" \
        NORTH_NATIVE_REPO="$RN" \
        NORTH_NATIVE_PROVIDER="$provider" \
        NORTH_NATIVE_MODEL="$model" \
        NORTH_NATIVE_EFFORT="$effort" \
        NORTH_NATIVE_DISPLAY="$display" \
        bb -e '
          (load-file (str (System/getenv "HOME") "/code/north/cli/coord.clj"))
          (let [port (Integer/parseInt (System/getenv "NORTH_NATIVE_PORT"))
                subject (System/getenv "NORTH_NATIVE_SUBJECT")
                facts [["kind" "session"]
                       ["repo" (System/getenv "NORTH_NATIVE_REPO")]
                       ["provider" (System/getenv "NORTH_NATIVE_PROVIDER")]
                       ["model" (System/getenv "NORTH_NATIVE_MODEL")]
                       ["effort" (System/getenv "NORTH_NATIVE_EFFORT")]
                       ["display_handle" (System/getenv "NORTH_NATIVE_DISPLAY")]
                       ["display_name" (System/getenv "NORTH_NATIVE_DISPLAY")]]
                results (mapv (fn [[p r]] (north.coord/put! port subject p r)) facts)]
            (when (some :reject results) (System/exit 1)))' >/dev/null 2>&1
    then
      if printf '%s\n%s\n%s\n' "$provider" "$model" "$effort" >"$route_tmp" 2>/dev/null; then
        mv -f "$route_tmp" "$ROUTE_CACHE" 2>/dev/null || rm -f "$route_tmp" 2>/dev/null || true
      fi
    fi
  ) </dev/null >/dev/null 2>&1 &
}

# SessionStart deliberately publishes presence and identity best-effort. Under
# coordinator contention the lease can land while one of the identity writes
# times out; without repair that creates an online but unclassified roster row
# for the full 30-minute lease. The route cache is committed only after every
# SessionStart identity fact lands, so its absence is the retry signal. Rebuild
# an honest minimal projection before renewing presence: provider may be known
# from an exact runtime marker, while model/effort remain explicitly unobserved
# unless this hook exposes effort. A later exact hook observation supersedes it.
if [ ! -r "$ROUTE_CACHE" ]; then
  PROVIDER="$seed_provider"
  case "${AGENT_PROVIDER:-}" in
    anthropic|openai) PROVIDER="$AGENT_PROVIDER" ;;
  esac
  if [ -z "$PROVIDER" ] && { [ -n "${CODEX_THREAD_ID:-}" ] || [ -n "${CODEX_CI:-}" ]; }; then
    PROVIDER="openai"
  elif [ -z "$PROVIDER" ] && [ -n "${CLAUDECODE:-}" ]; then
    PROVIDER="anthropic"
  fi
  cached_provider="${PROVIDER:-unobserved}"
  cached_model="${seed_model:-unobserved}"
  cached_effort="${EFFORT:-${seed_effort:-unobserved}}"
  slug() {
    printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9][^a-z0-9]*/-/g; s/^-//; s/-$//'
  }
  provider_segment="$(slug "$cached_provider")"; [ -n "$provider_segment" ] || provider_segment="unobserved"
  model_segment="$(slug "$cached_model")"; [ -n "$model_segment" ] || model_segment="unobserved"
  effort_segment="$(slug "$cached_effort")"; [ -n "$effort_segment" ] || effort_segment="unobserved"
  display_handle="$provider_segment-$model_segment-$effort_segment-native-${ID##*-}"
  schedule_projection_repair "$cached_provider" "$cached_model" "$cached_effort" "$display_handle"
fi

if [ -n "$EFFORT" ] && [ "$EFFORT" != "$cached_effort" ]; then
  if [ -r "$ROUTE_CACHE" ]; then
    slug() {
      printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9][^a-z0-9]*/-/g; s/^-//; s/-$//'
    }
    provider_segment="$(slug "${cached_provider:-unknown}")"; [ -n "$provider_segment" ] || provider_segment="unknown"
    model_segment="$(slug "${cached_model:-unknown}")"; [ -n "$model_segment" ] || model_segment="unknown"
    effort_segment="$(slug "$EFFORT")"; [ -n "$effort_segment" ] || effort_segment="unknown"
    display_handle="$provider_segment-$model_segment-$effort_segment-native-${ID##*-}"
    schedule_projection_repair "$cached_provider" "$cached_model" "$EFFORT" "$display_handle"
  fi
fi

# renew presence = ACTIVITY HEARTBEAT. A renewal MEANS "this agent ran a tool just now"
# (IS-WORKING), so the 30min lease expiring becomes a real death signal, not just
# "never registered". THROTTLED: a bb spawn per tool call is the cost, and the lease is
# 30min, so renewing more than once per 60s is pure waste — skip if the last renewal for
# THIS id was <60s ago (marker in XDG_RUNTIME_DIR, keyed by id so agents don't collide).
# Best-effort + bounded: any failure is swallowed, never breaks the tool call. The marker
# is stamped only on a SUCCESSFUL renew, so a failed renew retries on the next tool call.
RENEW_DIR="${XDG_RUNTIME_DIR:-/tmp}/north-presence-renew"
RENEW_MARK="$RENEW_DIR/$ID"
now_s="$(date +%s 2>/dev/null || echo 0)"
last_s=0
[ -r "$RENEW_MARK" ] && last_s="$(cat "$RENEW_MARK" 2>/dev/null || echo 0)"
case "$last_s" in ''|*[!0-9]*) last_s=0 ;; esac
if [ "$now_s" -eq 0 ] || [ $(( now_s - last_s )) -ge 60 ]; then
  # The lease write is maintenance, not mail delivery. Singleflight it and let
  # the foreground continue immediately; only a successful register advances
  # the throttle marker, so a delayed/down coordinator is retried later.
  RENEW_LOCK="${RENEW_MARK}.lock"
  if mkdir -p "$RENEW_DIR" 2>/dev/null && acquire_singleflight "$RENEW_LOCK" 8; then
    fresh_last_s=0
    [ -r "$RENEW_MARK" ] && fresh_last_s="$(cat "$RENEW_MARK" 2>/dev/null || echo 0)"
    case "$fresh_last_s" in ''|*[!0-9]*) fresh_last_s=0 ;; esac
    if [ "$now_s" -ne 0 ] && [ $((now_s - fresh_last_s)) -lt 60 ]; then
      rmdir "$RENEW_LOCK" 2>/dev/null || true
    else
      (
        trap 'rm -rf "$RENEW_LOCK" 2>/dev/null || true' EXIT
        if timeout --signal=TERM --kill-after=0.2s 3s \
            bb "$HOME/code/north/cli/presence-cli.clj" "${NORTH_PORT:-7977}" \
            register "$ID" "$REPO" "$ID" >/dev/null 2>&1
        then
          renew_tmp="${RENEW_MARK}.$$.${RANDOM}.tmp"
          if printf '%s' "$now_s" >"$renew_tmp" 2>/dev/null; then
            mv -f "$renew_tmp" "$RENEW_MARK" 2>/dev/null || rm -f "$renew_tmp" 2>/dev/null || true
          fi
        fi
      ) </dev/null >/dev/null 2>&1 &
    fi
  fi
fi

# Peek + ack is the only coordinator operation on the foreground path. The
# helper prints a complete message before attempting its ack, so even if this
# deadline interrupts a slow ack, command substitution retains the delivered
# text and the message can safely repeat later instead of disappearing.
MAIL="$(timeout --signal=TERM --kill-after=0.2s 1.25s \
  bb "$HOME/code/north/cli/inbox-peek.clj" "${NORTH_PORT:-7977}" "$ID" 2>/dev/null || true)"
[ -z "$MAIL" ] && exit 0

CTX="[north] new peer message(s):
$MAIL"
# Serialize with a real JSON encoder: peer mail is arbitrary text and may
# contain tabs or other control characters that a quote/newline-only shell
# escape leaves as malformed JSON.
printf '%s' "$CTX" | python3 -c '
import json, sys
context = sys.stdin.read()
payload = {
    "hookSpecificOutput": {
        "hookEventName": "PostToolUse",
        "additionalContext": context,
    }
}
sys.stdout.write(json.dumps(payload, ensure_ascii=False, separators=(",", ":")) + "\n")
' 2>/dev/null || true
exit 0
