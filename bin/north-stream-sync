#!/usr/bin/env bash
# north-stream-sync — zero-AI, mechanical log-shipping of Claude Code session
# transcripts into north's stream layer (streams/raw/, see streams/CLAUDE.md).
#
# The harness already appends the full transcript JSONL to
# ~/.claude/projects/<project-slug>/<session-id>.jsonl in real time. This
# script is a byte-cursor sync (journald cursor / Kafka consumer-offset
# prior): per source, remember how many bytes have been shipped, append the
# delta to the dest snapshot, and truncate-then-reappend on crash recovery
# (dest ahead of cursor -> a prior run died mid-append -> truncate dest back
# to the cursor and re-tail from there). No AI, no parsing of message content —
# purely dd/tail/truncate. Idempotent: an immediate re-run is a no-op because
# src_size == cursor for every source.
#
# Cursor file: streams/raw/.cursors — one line per source:
#   <bytes-synced>\t<source-path>\t<dest-date>
# dest-date is the dest file's first-sync date (YYYY-MM-DD), stable across
# runs (a dest filename must not change once minted) — stored explicitly so
# a later run doesn't re-derive "today" and mint a second dest for the same
# source.
set -euo pipefail

usage() {
  cat <<'EOF'
usage: north-stream-sync [--days N] [--min-bytes N] [--src-dir DIR] [--raw-dir DIR]

  --days N        only sync sources modified within the last N days (default 2)
  --min-bytes N   skip sources smaller than N bytes (default 65536)
  --src-dir DIR   override source root (default: ~/.claude/projects)
  --raw-dir DIR   override dest root (default: <north-repo>/streams/raw)
EOF
}

DAYS=2
MIN_BYTES=65536
SRC_DIR="$HOME/.claude/projects"
NORTH_REPO="$(cd "$(dirname "$0")/.." && pwd)"
RAW_DIR="$NORTH_REPO/streams/raw"

while [ $# -gt 0 ]; do
  case "$1" in
    --days) DAYS="$2"; shift 2 ;;
    --min-bytes) MIN_BYTES="$2"; shift 2 ;;
    --src-dir) SRC_DIR="$2"; shift 2 ;;
    --raw-dir) RAW_DIR="$2"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "north-stream-sync: unknown arg: $1" >&2; usage >&2; exit 1 ;;
  esac
done

mkdir -p "$RAW_DIR"
CURSOR_FILE="$RAW_DIR/.cursors"
touch "$CURSOR_FILE"
LOCK_DIR="$RAW_DIR/.stream-sync.lock"

# mkdir is atomic across processes (POSIX) -> cheap mutual-exclusion lock so
# the systemd timer and a session-end hook invocation never interleave writes
# to the same dest/cursor file. Best-effort: if held, just skip this run —
# the next trigger (timer or another session end) will catch up.
if ! mkdir "$LOCK_DIR" 2>/dev/null; then
  echo "north-stream-sync: lock held ($LOCK_DIR) — another sync in flight, skipping" >&2
  exit 0
fi
trap 'rmdir "$LOCK_DIR" 2>/dev/null || true' EXIT

[ -d "$SRC_DIR" ] || exit 0

TMP_CURSOR="$(mktemp "$CURSOR_FILE.tmp.XXXXXX")"
trap 'rm -f "$TMP_CURSOR"; rmdir "$LOCK_DIR" 2>/dev/null || true' EXIT

# carry forward every existing cursor line whose source we do NOT touch this
# run (sources that aged out of the --days window, etc.) — never lose state.
cp "$CURSOR_FILE" "$TMP_CURSOR"

while IFS= read -r -d '' src; do
  src_size=$(stat -c%s "$src")
  [ "$src_size" -ge "$MIN_BYTES" ] || continue

  proj_dir="$(basename "$(dirname "$src")")"
  # ~/.claude/projects/<slug>/... slugs are the cwd path with / -> - and a
  # leading -; strip the common -home-<user>[-code] prefix so the dest name
  # reads as a repo name, not a full path smear.
  slug="$(printf '%s' "$proj_dir" | sed -E 's/^-home-[^-]+-code-/-/; s/^-home-[^-]+-/-/; s/^-+//')"
  session="$(basename "$src" .jsonl)"
  session_short="${session:0:8}"

  # existing cursor line for this exact source (tab-delimited, field 2 == src)
  cur_line="$(awk -F'\t' -v s="$src" '$2==s{print; exit}' "$CURSOR_FILE")"

  if [ -n "$cur_line" ]; then
    cur_bytes="$(printf '%s' "$cur_line" | cut -f1)"
    dest_date="$(printf '%s' "$cur_line" | cut -f3)"
    dest="$RAW_DIR/${dest_date}-${slug}.${session_short}.jsonl"
  else
    # brand-new source. Before minting a fresh dest, check whether a dest
    # already exists for this session (e.g. an earlier manual `cp` snapshot,
    # or a different slug-derivation) — adopt it rather than duplicating, per
    # streams/CLAUDE.md's "a copy is a snapshot" contract: one dest per session.
    adopt="$(find "$RAW_DIR" -maxdepth 1 -type f -iname "*.${session_short}.jsonl" ! -name '.*' 2>/dev/null | head -1)"
    if [ -n "$adopt" ]; then
      dest="$adopt"
      dest_date="$(basename "$dest" | cut -c1-10)"
      cur_bytes=$(stat -c%s "$dest")
    else
      dest_date="$(date +%F)"
      dest="$RAW_DIR/${dest_date}-${slug}.${session_short}.jsonl"
      cur_bytes=0
    fi
  fi

  dest_size=0
  [ -f "$dest" ] && dest_size=$(stat -c%s "$dest")

  # crash recovery: a prior run appended past the recorded cursor and then
  # died before updating the cursor file. Truncate back to the last known-good
  # offset before re-appending, so we never duplicate bytes.
  if [ "$dest_size" -gt "$cur_bytes" ]; then
    truncate -s "$cur_bytes" "$dest"
    dest_size="$cur_bytes"
  fi

  new_bytes="$cur_bytes"
  if [ "$src_size" -gt "$cur_bytes" ]; then
    tail -c "+$((cur_bytes + 1))" "$src" >> "$dest"
    new_bytes="$src_size"
  fi

  # rewrite this source's cursor line: drop any prior line for it, append fresh.
  awk -F'\t' -v s="$src" '$2!=s' "$TMP_CURSOR" > "$TMP_CURSOR.next"
  mv "$TMP_CURSOR.next" "$TMP_CURSOR"
  printf '%s\t%s\t%s\n' "$new_bytes" "$src" "$dest_date" >> "$TMP_CURSOR"
done < <(find "$SRC_DIR" -mindepth 2 -maxdepth 2 -type f -iname '*.jsonl' -mtime "-$DAYS" -print0)

mv "$TMP_CURSOR" "$CURSOR_FILE"
