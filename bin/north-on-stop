#!/usr/bin/env bash
# north-on-stop — bounded fail-open Stop hook.
#
# Block only when this session has a delegation marker and no one-shot North
# listener is armed. Every uncertain state allows the stop. The outer process
# supervises the WHOLE semantic hook—including stdin, git, cache and pgrep—so a
# wedged dependency can never consume the provider's hook deadline.
set -uo pipefail

mode="${1:-}"
if [ -z "$mode" ]; then
  # Python owns the semantic process as a fresh session/process group. A
  # tempfile—not a pipe—means a descendant cannot hold stdout open after its
  # parent exits. The 1.6s work window plus TERM/KILL/reap grace has a measured
  # hard target below 2s, comfortably inside the provider's 10s outer deadline.
  # The supervisor also kills surviving descendants after a NORMAL exit.
  python3 -c '
import json
import os
import signal
import subprocess
import sys
import tempfile
import time

class DuplicateKey(ValueError):
    pass

def exact_object(pairs):
    result = {}
    for key, value in pairs:
        if key in result:
            raise DuplicateKey()
        result[key] = value
    return result

def signal_group(pid, sig):
    try:
        os.killpg(pid, sig)
        return True
    except ProcessLookupError:
        return False
    except OSError:
        return False

try:
    with tempfile.TemporaryFile() as output:
        child = subprocess.Popen(
            [sys.argv[1], "--north-stop-semantic-private"],
            stdin=sys.stdin.buffer,
            stdout=output,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
            close_fds=True,
        )
        timed_out = False
        try:
            child.wait(timeout=1.6)
        except subprocess.TimeoutExpired:
            timed_out = True
            signal_group(child.pid, signal.SIGTERM)
            try:
                child.wait(timeout=0.1)
            except subprocess.TimeoutExpired:
                pass

        # Reap TERM-resistant work and background descendants that outlived a
        # normally-exited semantic parent. Never wait on inherited output pipes.
        if signal_group(child.pid, signal.SIGTERM):
            time.sleep(0.05)
        signal_group(child.pid, signal.SIGKILL)
        try:
            child.wait(timeout=0.15)
        except subprocess.TimeoutExpired:
            pass
        if timed_out or child.returncode != 0:
            raise SystemExit(0)
        output.seek(0)
        raw = output.read(16385)
except (OSError, ValueError, subprocess.SubprocessError):
    raise SystemExit(0)

if len(raw) > 16384:
    raise SystemExit(0)
try:
    text = raw.decode("utf-8", "strict")
    value = json.loads(text, object_pairs_hook=exact_object)
except (UnicodeDecodeError, ValueError, json.JSONDecodeError):
    raise SystemExit(0)
if (
    not isinstance(value, dict)
    or set(value) != {"decision", "reason"}
    or value.get("decision") != "block"
    or not isinstance(value.get("reason"), str)
    or not value["reason"]
    or len(value["reason"].encode("utf-8")) > 12288
    or any(ord(char) < 32 and char not in "\t\n\r" for char in value["reason"])
):
    raise SystemExit(0)
sys.stdout.write(json.dumps(value, ensure_ascii=False, separators=(",", ":")) + "\n")
' "$0" 2>/dev/null || true
  exit 0
fi

if [ "$mode" != "--north-stop-semantic-private" ]; then
  exit 0
fi

# The inner process is always killed as a process group by the outer deadline.
# Read and strictly normalize only the three hook fields used below. A held-open
# or oversized stdin remains inside that deadline and therefore fails open.
parsed="$(
  python3 -c '
import json
import os
import re
import sys

class DuplicateKey(ValueError):
    pass

def exact_object(pairs):
    result = {}
    for key, value in pairs:
        if key in result:
            raise DuplicateKey()
        result[key] = value
    return result

raw = sys.stdin.buffer.read(65537)
if len(raw) > 65536:
    raise SystemExit(1)
try:
    value = json.loads(raw.decode("utf-8", "strict"), object_pairs_hook=exact_object)
except (UnicodeDecodeError, ValueError, json.JSONDecodeError):
    raise SystemExit(1)
if not isinstance(value, dict):
    raise SystemExit(1)
active = value.get("stop_hook_active", False)
if not isinstance(active, bool):
    raise SystemExit(1)
cwd = value.get("cwd", os.getcwd())
session_id = value.get("session_id", "")
if (
    not isinstance(cwd, str)
    or not cwd
    or len(cwd.encode("utf-8")) > 4096
    or any(char in cwd for char in "\0\n\r\t")
    or not os.path.isabs(cwd)
    or not isinstance(session_id, str)
    or len(session_id.encode("ascii", "strict")) > 512
    or (session_id and re.fullmatch(r"[A-Za-z0-9._:-]+", session_id) is None)
):
    raise SystemExit(1)
sys.stdout.write(
    ("1" if active else "0")
    + "\n"
    + cwd
    + "\n"
    + ("1" if session_id else "0")
    + (("\n" + session_id) if session_id else "")
    + "\n"
)
' 2>/dev/null
)" || exit 0

mapfile -t fields <<<"$parsed"
[ "${#fields[@]}" -ge 3 ] || exit 0
[ "${fields[0]}" = "0" ] || exit 0
cwd="${fields[1]}"
case "${fields[2]}" in
  0)
    [ "${#fields[@]}" -eq 3 ] || exit 0
    sid=""
    ;;
  1)
    [ "${#fields[@]}" -eq 4 ] || exit 0
    sid="${fields[3]}"
    ;;
  *) exit 0 ;;
esac

repo="$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null || printf '%s' "$cwd")"
[ -n "$repo" ] || exit 0
repo_name="${repo##*/}"
cache="${XDG_RUNTIME_DIR:-/tmp}/north-agent-ids/$sid"
id=""
if [ -n "$sid" ] && [ -f "$cache" ] && [ -r "$cache" ]; then
  IFS= read -r id <"$cache" 2>/dev/null || id=""
fi
[ -n "$id" ] || id="${NORTH_AGENT_ID:-}"
[ -n "$id" ] || {
  [ -n "$sid" ] || exit 0
  id="session-$repo_name-${sid:0:8}"
}

# IDs are interpolated into paths, process matching and JSON-visible guidance.
# Anything outside North's canonical identifier surface is uncertainty.
[ "${#id}" -le 512 ] || exit 0
case "$id" in
  ""|*[!A-Za-z0-9._:-]*) exit 0 ;;
esac

mark="${XDG_RUNTIME_DIR:-/tmp}/north-delegated/$id"
[ -f "$mark" ] || exit 0

# `north-arm` execs `bb .../north-listen.clj <port> <id> --once`. Read one
# process snapshot and compare the ID as a whitespace-delimited argv token.
listeners="$(pgrep -af 'north-listen[.]clj' 2>/dev/null || true)"
while IFS= read -r listener; do
  case "$listener " in
    *" $id "*) exit 0 ;;
  esac
done <<<"$listeners"

reason="You delegated work this session but no north listener is armed. If you end your turn now, a spawned worker's completion/death ping lands in a dead inbox and this session goes SILENT until a human pokes it. Arm the listener as a BACKGROUND task before yielding:  ~/code/north/bin/north-arm ${id}  (run_in_background). When it fires, handle the mail and re-arm. If every delegated worker is already reconciled and you truly want to stop, clear the marker:  rm ${mark}"
python3 -c '
import json
import sys
sys.stdout.write(json.dumps(
    {"decision": "block", "reason": sys.argv[1]},
    ensure_ascii=False,
    separators=(",", ":"),
) + "\n")
' "$reason" 2>/dev/null || true
exit 0
