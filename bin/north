#!/usr/bin/env bash
# North — the life app. Routes LIFE verbs to the North CLI (north.main,
# run against the Fram engine on the classpath) and ENGINE verbs to the Fram CLI.
# Both operate on the same private XDG fact data. Supplies North's lifecycle
# configuration and capture provenance; executable predicate schema lives in
# the fact graph itself.
#
#   engine: FRAM_HOME (checkout fallback: sibling fram)   data: XDG state
export FRAM_THREADS="${FRAM_THREADS:-$HOME/.local/state/north/threads}"
_north_fram_log_explicit=0
if [ -n "${FRAM_LOG:-}" ]; then _north_fram_log_explicit=1; fi
export FRAM_LOG="${FRAM_LOG:-$HOME/.local/state/north/facts.log}"
# --- the log split: kind-routed telemetry segregation (OPT-IN; off => byte-identical) -
# When enabled the coordinator splits persistence per log: coordination facts
# stay in coordination.log, telemetry (run/session/mine/guard_denial) peels off to
# telemetry.log — same daemon, one unified in-memory store (A1). Opt-in is EITHER
# an explicit FRAM_TELEMETRY_LOG in the caller's env, OR the mere PRESENCE of a
# seeded coordination.log beside FRAM_LOG (the artifact `north-log-split
# --execute` writes) — so the split IS the switch, and rollback is "restore
# facts.log / remove coordination.log". Neither present => FRAM_TELEMETRY_LOG stays
# unset and the engine reads the single FRAM_LOG, byte-identical to pre-split.
if [ "$_north_fram_log_explicit" -eq 0 ] && [ -z "${FRAM_TELEMETRY_LOG:-}" ]; then
  _north_log_dir="$(dirname "$FRAM_LOG")"
  if [ -f "$_north_log_dir/coordination.log" ]; then
    export FRAM_LOG="$_north_log_dir/coordination.log"
    export FRAM_TELEMETRY_LOG="$_north_log_dir/telemetry.log"
  fi
  unset _north_log_dir
fi
unset _north_fram_log_explicit
export FRAM_TIME_DIR="${FRAM_TIME_DIR:-$HOME/.local/state/north/time}"
# TRANSITIONAL_SCHEMA_BOOTSTRAP: graph declarations win whenever present. Keep
# this compatibility set only until a verified two-corpus snapshot, canonical
# schema-migrate execution, strict audit, and restart proof have all landed; its
# removal is deliberately sequenced after that live-data cutover.
export FRAM_SINGLE_VALUED="${FRAM_SINGLE_VALUED:-title owner lead driver source part_of do_on valid_until estimate_hours created_at updated_at name display_name body created_by committed outcome abandoned superseded_by merged_into session_of start_time end_time clocked_by clock_orphaned clockify_id rate invoice_id invoice_state linear kind coordinator provider_target live_input live_input_state live_input_epoch target_identity_manifest_sha256 requested_target fallback_target_path broadcast_audience_version code_port code_log judgment_grade}"
# North DECLARES its lifecycle vocab to the (now genericized) Fram kernel —
# value-identical to the kernel default, so this is the explicit-config form of
# what was previously baked in (Fram >= ec7ef90: FRAM_TERMINAL_PREDS/WITHDRAWN_PREDS).
export FRAM_TERMINAL_PREDS="${FRAM_TERMINAL_PREDS:-outcome abandoned superseded_by}"
export FRAM_WITHDRAWN_PREDS="${FRAM_WITHDRAWN_PREDS:-abandoned}"
export CLOCKIFY_SECRET_FILE="${CLOCKIFY_SECRET_FILE:-/run/secrets/clockify-api-key}"
export NORTH_SOURCE="${NORTH_SOURCE:-tom}"
export NORTH_AUTHOR="${NORTH_AUTHOR:-tom_passarelli}"
export NORTH_LEAD="${NORTH_LEAD:-tom_passarelli}"
export NORTH_DRIVER="${NORTH_DRIVER:-tom_passarelli}"
export NORTH_PROPOSED_BY="${NORTH_PROPOSED_BY:-tom_passarelli}"

FRAM="${FRAM_HOME:-$HOME/code/fram}"
FRAM_BIN="${FRAM_BIN:-$FRAM/bin}"
FRAM_OUT="${FRAM_OUT:-$FRAM/out}"
NORTH="$(cd "$(dirname "$0")/.." && pwd)"
BB="${NORTH_BB:-bb}"
BUN="${NORTH_BUN:-bun}"

# judgment_grade is dispatcher/orchestrator-owned calibration input. Ordinary
# worker thread writes remain available, but managed workers cannot tell,
# retract, or cold-set this predicate. New values pass the one canonical parser;
# malformed legacy values can still be retracted by an ambient human/orchestrator.
# `set` is included because the generic engine passthrough would otherwise bypass
# the coordinated tell policy (and remains discouraged under concurrency).
guard_judgment_grade_write() {
  case "${1:-}" in tell|retract|untell|set) ;; *) return 0 ;; esac
  [ "${3:-}" = judgment_grade ] || return 0
  case "${AGENT_TOPOLOGY:-}" in
    ""|orchestrator) ;;
    *)
      echo "north: $1 REFUSED — judgment_grade is dispatcher/orchestrator-owned; worker topology cannot mutate it" >&2
      return 1 ;;
  esac
  case "$1" in
    tell|set)
      if [ "$#" -ne 4 ]; then
        echo "north: $1 REFUSED — judgment_grade requires exactly one value: s, m, or l" >&2
        return 1
      fi
      "$BUN" run "$NORTH/sdk/src/judgment-grade.ts" validate "$4" >/dev/null || {
        echo "north: $1 REFUSED — judgment_grade must be exactly one of: s, m, l" >&2
        return 1
      }
      ;;
  esac
}

guard_judgment_grade_write "$@" || exit 1

# A worker still needs ordinary THREAD fact writes. Agent identity/lifecycle is
# harness evidence, not agent-authored data: generic fact verbs may not mutate
# any agent subject (self or peer). Trusted harness writes use a subprocess-only
# private writer not routed by this CLI; peer control remains an orchestrator
# operation. This is an application boundary, not same-UID hostile-code isolation.
# Run this before subject resolution: even a read/daemon failure is too late for
# an authorization boundary, and installed MCP `tell`/`retract` routes here too.
deny_worker_agent_mutation() {
  case "${AGENT_TOPOLOGY:-}" in ""|orchestrator) return 0 ;; esac
  case "${1:-}" in tell|retract|untell) ;; *) return 0 ;; esac
  local subject="${2:-}" predicate="${3:-}"
  subject="${subject#@}"
  case "$subject" in agent:*) ;; *) return 0 ;; esac
  echo "north: $1 REFUSED — worker topology cannot mutate agent identity or authority via generic facts ($subject $predicate); report work on the thread or return control to the orchestrator" >&2
  return 1
}

deny_worker_agent_mutation "$@" || exit 1

# Run reservations/evidence/telemetry are harness-owned for the same reason as
# agent identity. A worker records proof only through `north evidence record`;
# generic facts must not bypass the capability-bound writer or poison another
# lane's write-once run subject.
deny_generic_run_mutation() {
  case "${1:-}" in tell|retract|untell) ;; *) return 0 ;; esac
  local subject="${2:-}" predicate="${3:-}"
  subject="${subject#@}"
  case "$subject" in run-*) ;; *) return 0 ;; esac
  echo "north: $1 REFUSED — generic fact verbs cannot mutate harness-owned run facts ($subject $predicate); use 'north evidence record' for done-bar observations" >&2
  return 1
}

deny_generic_run_mutation "$@" || exit 1

case "${1:-}" in
  ""|help|-h|--help)
    # THE CARD — one screen, grouped, "type this → do this". Bare `north` and
    # `north help` are the same implementation (help IS the card verb, not an
    # alias). Every line below is a command that actually works; verify before
    # adding. Kept honest by hand, not generated.
    cat <<'CARD'
north — your one card. Type a command to do the thing next to it.

  GET HELP
    north                              this card
    north <verb> --help                most verbs print their own usage

  SEE WHAT'S GOING ON
    north dashboard                    the cockpit: agents, concerns, board, health, profile
    north threads                      thread-kind overview: active/ready/blocked  (--all = everything; aliases: board, plate)
    north ready                        committed + unblocked work, start anytime, ranked by leverage
    north agenda                       what's dated / overdue today
    north health                       coordination rollup: lanes ran/died, stale concerns
    north trace <id>                   diagnose one agent's lifecycle
    north templates                    Gaffer's reusable stock templates and routing defaults
    north routing report performance  current managed evidence  (--all = legacy/incomplete history)
    north routing report usage        provider work usage (never dollars / API credits)
    north routing report economics    bounded routing-cost signals + alert-only policy findings
    north routing report promotions   bespoke patterns for stock-template review
    north routing report calibration  run-local judgment/struggle detector cohorts
    north schema                       the fact vocabulary in use
    north predicate ls|show|define     inspect or extend executable predicate entities
    north schema-migrate plan|audit    deterministic schema cutover and strict audit
    north snapshot create|verify|restore-plan
                                       immutable dual-log checkpoint and restore planning
    north corpus-transaction check-boundaries
                                       verify split-log append safety before maintenance

  HAND OFF WORK   (starts a new lane — your own channel never blocks)
    /delegate "<thing>" [--new]        chat: delegate; session context rides by
                                       default · --new = empty-context lane
    north delegate "<task>" (--role <worker> | --composite)
                                       shell: intake must classify atomic vs composite

  DRIVE AGENTS
    north agents [--json]              who's live now + stable machine roster
    north watch <id>                   tail an agent's transcript
    north steer <id> "<msg>"           inject a message into a running agent
    north retask <id> "<goal>"         redirect a running agent's goal
    north evidence record <bar> <result>
                                       bind done-bar evidence to this exact managed run
    north delivery attest <agent-id>   unavailable until verifier lanes have OS isolation
    north spawn <role> "<prompt>"      compose from Gaffer's staffing catalog
      --provider auto|anthropic|openai  select or auto-route the worker provider
      --taskGrade/--domain              independently override stock staffing axes
      --topology                        bespoke compositions only; stock topology is fixed
      --tier/--reasoning/--posture      capability, deliberation, and posture
      --assessment JSON|@file           canonical Gaffer selection sidecar (required for max)
      --pin-evidence JSON|@file         typed reason + <=24h expiry for any exact pin
      --rationale "why"                 required for a bespoke role
    (agents dispatch via MCP)          in-harness agents call mcp__north__dispatch / spawn

  LIFE   (capture thoughts, track work + time)
    north capture "<thought>"          turn a thought into a thread
    north show <id>                    read one thread's facts
    north tell <id> <pred> <val>       assert a fact   (north retract … to remove)
    north clock in <owner>|out         open/close one human client billing session
    north clock start|stop             compatibility aliases for legacy thread sessions
    north clock audit                  commits-vs-clock coverage drift report
    north linear get|import|plan|sync  mechanical Linear bridge (sync is plan-only unless --apply)

  SETTINGS & HEALTH
    north config                       posture + routing policy in one report
    north config routing               provider order, pressure, reserves, envelopes
    north account add|login|status     manage provider subscription accounts
    north account usage [id]           subscription windows, resets, and unknown reasons
    north account list [--verbose]    grouped accounts + live login state
    north spend status [target]        API-billing budget: cap, reserved, settled, headroom
    north spend init|override <target> create a guarded budget · add a time-boxed override
    north providers                    provider readiness and auto-route decision
    north doctor                       is everything healthy — daemons, rev skew, env, hooks
CARD
    exit 0 ;;
  clock)
    # `clock audit` is a standalone read-only report (commits-vs-sessions coverage,
    # bin/north-clock-audit); every other clock verb is engine-side in north.main.
    if [ "${2:-}" = "audit" ]; then exec "$NORTH/bin/north-clock-audit" "${@:3}"; fi
    exec "$BB" -cp "$NORTH/out:$FRAM_OUT" -m north.main "$@" ;;
  threads)
    # Kind-scoped noun command: the THREAD-kind overview (threads are one kind
    # among several in the store — see `north schema`; people/concerns/runs are
    # not threads). Same projection the kanban-metaphor aliases render: active
    # drivers + top-ready by leverage + counts. `board`/`plate` = legacy aliases.
    # Future kinds follow the pattern (`north people` when a person registry lands).
    exec "$BB" -cp "$NORTH/out:$FRAM_OUT" -m north.main board "${@:2}" ;;
  ready|blocked|leverage|next|agenda|board|plate|capture|json|needs-review|audit|resolve|validate|schema|schema-seed|tools|heal|boot)
    # `validate` runs north's FULL check (engine-generic ++ north work rules,
    # north.validate) — the fram CLI `validate` is generic-only since the work
    # rules moved out of the kernel. The MCP validate tool shells through here too.
    exec "$BB" -cp "$NORTH/out:$FRAM_OUT" -m north.main "$@" ;;
  coord-doctor)
    # Engine-level coordinator SAFETY handshake + log-hygiene diff (north.main
    # cmd-doctor): tell/untell safe? daemon state matches on-disk log? This is the
    # raw primitive the cockpit `north doctor` leads with. Renamed from the old bare
    # `north doctor` (2026-07-10) when the convoy cockpit doctor folded in.
    "$NORTH/bin/north-coord-up" --check-runtime || exit $?
    exec "$BB" -cp "$NORTH/out:$FRAM_OUT" -m north.main doctor "${@:2}" ;;
  dashboard|doctor)
    # The cockpit (ported from convoy/bin/my-agents, 2026-07-10): `dashboard` =
    # what is happening (agents/concerns/board/daemons/health/profile); `doctor` =
    # is everything healthy (coordinator handshake + daemons/health/rev-skew/env/
    # guard-hooks). Both teach the primitive they wrap. cli/dashboard-cli.clj.
    exec "$BB" "$NORTH/cli/dashboard-cli.clj" "$@" ;;
  config)
    # Personal-stack posture + durable provider routing policy.
    # + the no-arg full report. Ported from dotfiles/bin/my-agent-config (bash)
    # 2026-07-10: north is the settings surface. Provider-neutral state lives at
    # ~/.local/state/north/harness.conf; the Claude-era path is a read-only
    # migration fallback. cli/config-cli.clj.
    exec "$BB" "$NORTH/cli/config-cli.clj" "${@:2}" ;;
  providers)
    exec "$BUN" run "$NORTH/sdk/src/providers-cli.ts" "${@:2}" ;;
  account)
    # Isolated Claude Code / Codex subscription account homes. The TypeScript
    # CLI owns path validation, allowlisted config links, and normalized auth.
    exec "$BUN" run "$NORTH/sdk/src/account-cli.ts" "${@:2}" ;;
  spend)
    # API-billing budget LEDGER (spend-guard step 2). Owns schema declaration,
    # the cap-checked CAS reservation, terminal settlement, and human overrides
    # on the coordination log via cli/coord.clj — writes the coordinator wire the
    # read-only TS SDK client cannot. init/status/override are the cockpit surface
    # (each prints the primitive it runs); reserve/settle/headroom are machine
    # verbs the admission + terminal seams shell out to.
    exec "$BB" "$NORTH/cli/spend-cli.clj" "${@:2}" ;;
  delivery)
    # Historical attestation surface. Shared-UID agents cannot establish an
    # independent verifier boundary, so promotion fails closed.
    exec "$BUN" run "$NORTH/sdk/src/delivery-attest.ts" "${@:2}" ;;
  evidence)
    # Capability-bound self-reporting surface. Run/thread/reporter are inherited
    # from the managed child environment; callers supply only exact bar + result.
    exec "$BUN" run "$NORTH/sdk/src/delivery-evidence.ts" "${@:2}" ;;
  linear)
    # Zero-turn Linear adapter over Codex app-server MCP. `sync` defaults to a
    # read-only plan; only an explicit `sync <thread> --apply` writes remotely.
    exec "$BUN" run "$NORTH/sdk/src/integrations/linear/cli.ts" "${@:2}" ;;
  provider-observe)
    # Hidden machine-ingestion surface. Interactive adapters feed provider
    # telemetry here; it is intentionally silent and best-effort.
    exec "$BUN" run "$NORTH/sdk/src/provider-observations-cli.ts" "${@:2}" ;;
  predicate)
    # Generated read/authoring projection over exact executable @<predicate>
    # entities. Bootstrap inventory is available only through its explicitly
    # weak offline lint; connected commands read the graph authority.
    exec "$BB" "$NORTH/cli/pred-cli.clj" "${NORTH_PORT:-7977}" "${@:2}" ;;
  schema-migrate)
    # Exact Fram fold over coordination + telemetry. Canonical execution is a
    # maintenance operation and must follow a verified two-corpus snapshot;
    # plan/audit remain read-only at all times.
    exec "$BB" -cp "$FRAM_OUT" "$NORTH/cli/schema-migrate.clj" "${NORTH_PORT:-7977}" "${@:2}" ;;
  snapshot)
    # Content-addressed dual-log preservation. Create and restore-plan default
    # to dry-run; restore-plan can only emit a corpus-transaction plan and has
    # no authority to apply it or mutate the selected live corpus.
    exec "$BB" -cp "$FRAM_OUT" "$NORTH/cli/snapshot-cli.clj" "${NORTH_PORT:-7977}" "${@:2}" ;;
  corpus-transaction)
    # Package-owned split-corpus replacement/recovery. The mutable journal and
    # immutable preimage/receipt objects live under XDG state, never in a
    # checkout; the system unit invokes the same route before/after daemon boot.
    exec "$BB" -cp "$FRAM_OUT" "$NORTH/cli/corpus-transaction-cli.clj" "${NORTH_PORT:-7977}" "${@:2}" ;;
  up)
    exec "$NORTH/bin/north-coord-up" "${@:2}" ;;
  agents|templates|spawn|delegate|request|fork|req|watch|steer|retask)
    # Agent verbs — agents are a north concern (spawn/presence/facts live here).
    # Implementation: cli/agents-cli.clj (ported from the convoy cockpit 2026-07-09).
    exec "$BB" "$NORTH/cli/agents-cli.clj" "$@" ;;
  trace)
    # Single-agent lifecycle diagnosis — walk the invariant-spine checklist for one id,
    # flag the first failing stage (F1–F7). Read-only. cli/trace-cli.clj.
    exec "$BB" "$NORTH/cli/trace-cli.clj" "${@:2}" ;;
  health)
    # Aggregate coordination rollup — one durable log fold (lane outcomes, stale
    # concerns, ping-loss, zombie forks, died-unreported). Read-only. cli/health-cli.clj.
    exec "$BB" "$NORTH/cli/health-cli.clj" "${@:2}" ;;
  dials)
    # Compatibility bridge to the evidence-aware report. Dollar-centric dial
    # scoring is intentionally retired for subscription entitlement routing.
    exec "$BB" "$NORTH/cli/dials-cli.clj" "${@:2}" ;;
  routing)
    # Empirical routing feedback joins run telemetry to its exact proof-carrying
    # lane terminal, with current thread facts retained only as review context.
    # It never claims causal model quality or auto-promotes bespoke recurrence.
    exec "$BB" "$NORTH/cli/routing-report.clj" "${@:2}" ;;
  stream-sync)
    # Zero-AI cursor-based transcript log-shipping (streams/CLAUDE.md) — a
    # plain bash script, not a north.main verb, so it execs directly.
    exec "$NORTH/bin/north-stream-sync" "${@:2}" ;;
  listen)
    # Real-time interrupt listener — RUN AS A BACKGROUND TASK. Dormant (zero
    # tokens) until a peer addresses you, then prints the message and exits:
    # that exit is the interrupt. Read it, act, re-arm. bin/north-arm = alias.
    exec "$BB" "$NORTH/cli/north-listen.clj" "${NORTH_PORT:-7977}" "${2:?usage: north listen <agent-id>}" --once --ack "${@:3}" ;;
  reactor)
    # Coordinator AUTO-EXPORT sidecar — RUN AS A LONG-LIVED BACKGROUND TASK next to
    # the daemon. Subscribes to the coordinator commit firehose and re-projects
    # touched threads (`heal`, debounced) so threads/*.md never lag the log. Rides
    # the existing :subscribe seam — no daemon change. Inherits FRAM_LOG/FRAM_THREADS.
    #   north reactor [port] [debounce-ms]   (defaults: 7977, 400)
    exec "$BB" "$NORTH/cli/north-reactor.clj" "${2:-${NORTH_PORT:-7977}}" "${@:3}" ;;
  tell|untell|retract)
    # `retract` is the primary agent-facing retraction verb (R&N TELL/RETRACT);
    # `untell` is an accepted legacy alias. Both map onto fram's `untell` CLI verb
    # (whose wire op is already "retract") at the boundary below.
    # Handles (and @ids) are a NORTH concern: fram is handle-blind and re-adds
    # the leading @ to the bare subject it's handed. So resolve the SUBJECT ref to
    # its canonical id here first — that's what makes `north tell @perf ...`
    # land on the right thread — then pass fram the bare canonical id. Only rewrite
    # when the full `tell <id> <pred> <value>` shape is present; otherwise pass
    # through untouched so fram's own usage/arg checks are unchanged.
    if [ "$#" -ge 4 ]; then
      # FAIL-CLOSED: an unresolvable id-like ref (or a dead resolver) aborts the
      # write — passing the raw ref through would mint a phantom subject under a
      # truncated id and strand the facts (2026-07-03 incident: 19 orphans).
      canon="$("$BB" -cp "$NORTH/out:$FRAM_OUT" -m north.main resolve "$2" 2>/dev/null)"
      case "$canon" in
        ERROR*) echo "north: $1 REFUSED — ${canon#ERROR }" >&2; exit 1 ;;
        "")     echo "north: $1 REFUSED — subject resolver unavailable for '$2' (build out/? daemon?)" >&2; exit 1 ;;
        *)      set -- "$1" "${canon#@}" "${@:3}" ;;
      esac
    fi
    framverb="$1"; [ "$framverb" = retract ] && framverb=untell
    # Done-bars echo (friction gradient): closing a barred thread SEES its bars
    # at the moment of judgment — a reminder, never a reject. cmd-done-bars is
    # silent for bar-less threads; failures never block the write.
    if [ "$framverb" = tell ] && [ "${3:-}" = outcome ]; then
      "$BB" -cp "$NORTH/out:$FRAM_OUT" -m north.main done-bars "$2" 2>/dev/null || true
    fi
    exec "$FRAM_BIN/fram" "$framverb" "${@:2}" ;;
  *)  # engine verbs: import/export/show/set/merge/watch
    exec "$FRAM_BIN/fram" "$@" ;;
esac
