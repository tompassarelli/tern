#!/usr/bin/env bash
# North — the life app. Routes LIFE verbs to the North CLI (north.main,
# run against the Fram engine on the classpath) and ENGINE verbs to the Fram CLI.
# Both operate on the same private XDG fact data. Supplies the life domain config
# (cardinality vocab §1.1 + capture provenance).
#
#   engine: ~/code/fram   data: ~/code/north-data (XDG ~/.local/state/north)
export FRAM_THREADS="${FRAM_THREADS:-$HOME/.local/state/north/threads}"
export FRAM_LOG="${FRAM_LOG:-$HOME/.local/state/north/facts.log}"
export FRAM_TIME_DIR="${FRAM_TIME_DIR:-$HOME/.local/state/north/time}"
export FRAM_SINGLE_VALUED="${FRAM_SINGLE_VALUED:-title owner lead driver source part_of do_on valid_until estimate_hours created_at updated_at name display_name body created_by committed outcome abandoned superseded_by merged_into session_of start_time end_time clockify_id rate invoice_id invoice_state linear kind coordinator}"
# North DECLARES its lifecycle vocab to the (now genericized) Fram kernel —
# value-identical to the kernel default, so this is the explicit-config form of
# what was previously baked in (Fram >= ec7ef90: FRAM_TERMINAL_PREDS/WITHDRAWN_PREDS).
export FRAM_TERMINAL_PREDS="${FRAM_TERMINAL_PREDS:-outcome abandoned superseded_by}"
export FRAM_WITHDRAWN_PREDS="${FRAM_WITHDRAWN_PREDS:-abandoned}"
export CLOCKIFY_SECRET_FILE="${CLOCKIFY_SECRET_FILE:-/run/secrets/clockify-api-key}"
export NORTH_SOURCE="${NORTH_SOURCE:-tom}"
export NORTH_AUTHOR="${NORTH_AUTHOR:-tom_passarelli}"
export NORTH_LEAD="${NORTH_LEAD:-tom_passarelli}"
export NORTH_DRIVER="${NORTH_DRIVER:-tom_passarelli}"
export NORTH_PROPOSED_BY="${NORTH_PROPOSED_BY:-tom_passarelli}"

FRAM="${FRAM_HOME:-$HOME/code/fram}"
NORTH="$(cd "$(dirname "$0")/.." && pwd)"

case "${1:-}" in
  ready|blocked|leverage|next|agenda|board|plate|capture|json|needs-review|audit|resolve|validate|schema|schema-seed|tools|doctor|heal|boot|clock)
    # `validate` runs north's FULL check (engine-generic ++ north work rules,
    # north.validate) — the fram CLI `validate` is generic-only since the work
    # rules moved out of the kernel. The MCP validate tool shells through here too.
    exec bb -cp "$NORTH/out:$FRAM/out" -m north.main "$@" ;;
  up)
    exec "$FRAM/bin/fram-up" "${@:2}" ;;
  agents|spawn|request|watch|steer|retask)
    # Agent verbs — agents are a north concern (spawn/presence/facts live here).
    # Implementation: cli/agents-cli.clj (ported from the convoy cockpit 2026-07-09).
    exec bb "$NORTH/cli/agents-cli.clj" "$@" ;;
  trace)
    # Single-agent lifecycle diagnosis — walk the invariant-spine checklist for one id,
    # flag the first failing stage (F1–F7). Read-only. cli/trace-cli.clj.
    exec bb "$NORTH/cli/trace-cli.clj" "${@:2}" ;;
  health)
    # Aggregate coordination rollup — one durable log fold (lane outcomes, stale
    # concerns, ping-loss, zombie forks, died-unreported). Read-only. cli/health-cli.clj.
    exec bb "$NORTH/cli/health-cli.clj" "${@:2}" ;;
  dials)
    # Routing analytics — group @run telemetry by dial/model/effort/role and report
    # n/Σcost/Σtokens/turns/wall/outcome-mix/escalation-rate. The RATE step of
    # ESTIMATE→RATE→CALIBRATE: measures whether we route the right dial. Read-only.
    # Args: [by-dial|by-model|by-effort|by-role]. cli/dials-cli.clj.
    exec bb "$NORTH/cli/dials-cli.clj" "${@:2}" ;;
  stream-sync)
    # Zero-AI cursor-based transcript log-shipping (streams/CLAUDE.md) — a
    # plain bash script, not a north.main verb, so it execs directly.
    exec "$NORTH/bin/north-stream-sync" "${@:2}" ;;
  listen)
    # Real-time interrupt listener — RUN AS A BACKGROUND TASK. Dormant (zero
    # tokens) until a peer addresses you, then prints the message and exits:
    # that exit is the interrupt. Read it, act, re-arm. bin/north-arm = alias.
    exec bb "$NORTH/cli/north-listen.clj" 7977 "${2:?usage: north listen <agent-id>}" --once "${@:3}" ;;
  reactor)
    # Coordinator AUTO-EXPORT sidecar — RUN AS A LONG-LIVED BACKGROUND TASK next to
    # the daemon. Subscribes to the coordinator commit firehose and re-projects
    # touched threads (`heal`, debounced) so threads/*.md never lag the log. Rides
    # the existing :subscribe seam — no daemon change. Inherits FRAM_LOG/FRAM_THREADS.
    #   north reactor [port] [debounce-ms]   (defaults: 7977, 400)
    exec bb "$NORTH/cli/north-reactor.clj" "${2:-7977}" "${@:3}" ;;
  tell|untell|retract)
    # `retract` is the primary agent-facing retraction verb (R&N TELL/RETRACT);
    # `untell` is an accepted legacy alias. Both map onto fram's `untell` CLI verb
    # (whose wire op is already "retract") at the boundary below.
    # Handles (and @ids) are a NORTH concern: fram is handle-blind and re-adds
    # the leading @ to the bare subject it's handed. So resolve the SUBJECT ref to
    # its canonical id here first — that's what makes `north tell @perf ...`
    # land on the right thread — then pass fram the bare canonical id. Only rewrite
    # when the full `tell <id> <pred> <value>` shape is present; otherwise pass
    # through untouched so fram's own usage/arg checks are unchanged.
    if [ "$#" -ge 4 ]; then
      # FAIL-CLOSED: an unresolvable id-like ref (or a dead resolver) aborts the
      # write — passing the raw ref through would mint a phantom subject under a
      # truncated id and strand the facts (2026-07-03 incident: 19 orphans).
      canon="$(bb -cp "$NORTH/out:$FRAM/out" -m north.main resolve "$2" 2>/dev/null)"
      case "$canon" in
        ERROR*) echo "north: $1 REFUSED — ${canon#ERROR }" >&2; exit 1 ;;
        "")     echo "north: $1 REFUSED — subject resolver unavailable for '$2' (build out/? daemon?)" >&2; exit 1 ;;
        *)      set -- "$1" "${canon#@}" "${@:3}" ;;
      esac
    fi
    framverb="$1"; [ "$framverb" = retract ] && framverb=untell
    exec "$FRAM/bin/fram" "$framverb" "${@:2}" ;;
  *)  # engine verbs: import/export/show/set/merge/watch
    exec "$FRAM/bin/fram" "$@" ;;
esac
