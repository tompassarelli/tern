#!/usr/bin/env bash
# Start North's Fram coordinator against the configured North log.
set -euo pipefail

script_north_home="$(cd "$(dirname "$0")/.." && pwd -P)"
if [[ -n "${NORTH_HOME:-}" && -e "$NORTH_HOME/bin/north-coord-up" &&
      "$NORTH_HOME/bin/north-coord-up" -ef "$0" ]]; then
  NORTH_HOME="$(cd "$NORTH_HOME" && pwd -P)"
else
  # An inherited NORTH_HOME must not make a checkout launcher load another
  # North release's coordination probe.
  NORTH_HOME="$script_north_home"
fi

# Runtime selection is an operational boundary, not an ambient-environment
# coincidence. A checkout launch defaults to the sibling Fram checkout. A
# packaged North launch is selected by the launcher's immutable store
# provenance, and an inherited store pin in an otherwise live launch is
# rejected until the caller names that intent explicitly.
fram_home_input="${FRAM_HOME:-}"
fram_bin_input="${FRAM_BIN:-}"
runtime_selector="${NORTH_FRAM_RUNTIME:-auto}"
if [[ "$script_north_home" == /nix/store/* ]]; then
  # The immutable packaged launcher is itself authoritative provenance. Ambient
  # selector residue cannot turn its pinned store runtime into checkout mode.
  runtime_selector=package
else
  case "$runtime_selector" in
    auto) runtime_selector=checkout ;;
    checkout|package) ;;
    *)
      echo "north up: NORTH_FRAM_RUNTIME must be checkout or package (got '$runtime_selector')" >&2
      exit 2
      ;;
  esac
fi

if [[ "$runtime_selector" == checkout ]]; then
  if [[ -n "$fram_home_input" && "$fram_home_input" == /nix/store/* ]] ||
     [[ -n "$fram_bin_input" && "$fram_bin_input" == /nix/store/* ]]; then
    echo "north up: refusing inherited Nix-store Fram in checkout mode; set NORTH_FRAM_RUNTIME=package to select it explicitly" >&2
    exit 2
  fi
  FRAM_HOME="${fram_home_input:-$HOME/code/fram}"
  FRAM_BIN="${fram_bin_input:-$FRAM_HOME/bin}"

  # These variables are implementation details of the packaged Fram wrapper.
  # If they leak into a checkout launch, fram-daemon otherwise executes the old
  # packaged JVM classpath even when its executable came from the checkout.
  unset FRAM_PACKAGED FRAM_JAVA FRAM_DAEMON_CLASSPATH_FILE FRAM_RESOLVE FRAM_PACKAGE_REV
else
  if [[ -z "$fram_home_input" || -z "$fram_bin_input" ]]; then
    echo "north up: package mode requires FRAM_HOME and FRAM_BIN" >&2
    exit 2
  fi
  FRAM_HOME="$fram_home_input"
  FRAM_BIN="$fram_bin_input"
fi

FRAM_PORT="${FRAM_PORT:-7977}"
FRAM_LOG="${FRAM_LOG:-$HOME/.local/state/north/facts.log}"
if [[ ! "$FRAM_PORT" =~ ^[0-9]+$ ]] ||
   (( 10#$FRAM_PORT < 1 || 10#$FRAM_PORT > 65535 )); then
  echo "north up: FRAM_PORT must be an integer from 1 through 65535 (got '$FRAM_PORT')" >&2
  exit 2
fi
FRAM_PORT="$((10#$FRAM_PORT))"
FRAM_REQUIRE_LOG_FENCE=1
export FRAM_PORT FRAM_LOG FRAM_REQUIRE_LOG_FENCE
state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
runtime_identity_file="${NORTH_COORD_RUNTIME_FILE:-$state_home/north/fram-daemon-$FRAM_PORT.runtime}"

fram="$FRAM_BIN/fram"
daemon="$FRAM_BIN/fram-daemon"
north_bb="${NORTH_BB:-${NORTH_MCP_BB:-bb}}"
restart=0
check_runtime=0
stop=0

case "${1:-}" in
  "") ;;
  --restart) restart=1 ;;
  --check-runtime) check_runtime=1 ;;
  --stop) stop=1 ;;
  *)
    echo "usage: north up [--restart|--check-runtime|--stop]" >&2
    exit 2
    ;;
esac

if [[ "$north_bb" != */* ]]; then
  north_bb="$(command -v "$north_bb" 2>/dev/null || true)"
fi

for executable in "$fram" "$daemon" "$north_bb"; do
  if [[ ! -x "$executable" ]]; then
    echo "north up: required Fram executable is missing: $executable" >&2
    exit 2
  fi
done

canonical_path() {
  local path="$1" parent base canonical
  if canonical="$(realpath -e -- "$path" 2>/dev/null)"; then
    printf '%s\n' "$canonical"
    return
  fi
  if [[ -d "$path" ]]; then
    (cd "$path" && pwd -P)
    return
  fi
  if [[ -e "$path" ]]; then
    parent="$(cd "$(dirname "$path")" && pwd -P)"
    base="$(basename "$path")"
    printf '%s/%s\n' "$parent" "$base"
    return
  fi
  printf '%s\n' "$path"
}

nix_store_object_for_existing_path() {
  local path="$1" canonical relative object
  canonical="$(realpath -e -- "$path" 2>/dev/null)" || return 1
  [[ "$canonical" == /nix/store/* ]] || return 1
  relative="${canonical#/nix/store/}"
  object="${relative%%/*}"
  [[ -n "$object" && -e "/nix/store/$object" ]] || return 1
  printf '/nix/store/%s\n' "$object"
}

immutable_store_fallback_revision() {
  local source_object fram_object daemon_object
  local provenance_name provenance_path provenance_object
  source_object="$(nix_store_object_for_existing_path "$FRAM_HOME")" || return 1
  fram_object="$(nix_store_object_for_existing_path "$fram")" || return 1
  daemon_object="$(nix_store_object_for_existing_path "$daemon")" || return 1
  [[ "$fram_object" == "$source_object" &&
     "$daemon_object" == "$source_object" ]] || return 1

  # When callers expose package code/classpath seams, each Fram-owned path must
  # resolve into the same immutable output. Dependency executables such as the
  # JDK may legitimately live in other store objects and are not Fram identity.
  for provenance_name in FRAM FRAM_OUT FRAM_RESOLVE FRAM_DAEMON_CLASSPATH_FILE; do
    provenance_path="${!provenance_name:-}"
    [[ -n "$provenance_path" ]] || continue
    provenance_object="$(nix_store_object_for_existing_path "$provenance_path")" || return 1
    [[ "$provenance_object" == "$source_object" ]] || return 1
  done

  printf 'store:%s\n' "${source_object#/nix/store/}"
}

runtime_source="$(canonical_path "$FRAM_HOME")"
runtime_daemon="$(canonical_path "$daemon")"
runtime_rev=
runtime_tree=
if [[ "$runtime_selector" == checkout ]]; then
  if ! command -v git >/dev/null 2>&1 ||
     ! runtime_rev="$(git -C "$FRAM_HOME" rev-parse --verify HEAD 2>/dev/null)" ||
     ! runtime_tree="$(git -C "$FRAM_HOME" rev-parse --verify 'HEAD^{tree}' 2>/dev/null)"; then
    echo "north up: checkout mode requires a versioned Fram Git checkout: $FRAM_HOME" >&2
    exit 2
  fi
  if ! git -C "$FRAM_HOME" diff --quiet --no-ext-diff HEAD --; then
    echo "north up: refusing tracked-dirty Fram checkout at $runtime_rev; commit or restore tracked source before coordinator launch/health" >&2
    exit 2
  fi
else
  # FRAM_PACKAGE_REV is the package wrapper's authoritative pin. The runtime
  # observation variable is never package authority: without the package pin,
  # provenance must be earned from one coherent immutable store object below.
  runtime_rev="${FRAM_PACKAGE_REV:-}"
fi
if [[ -z "$runtime_rev" ]]; then
  # Backward compatibility for an older package wrapper is earned only from a
  # real, canonical, internally coherent store output. A store-shaped string,
  # a dangling symlink, or a mutable/mixed executable is not provenance.
  runtime_rev="$(immutable_store_fallback_revision || true)"
fi
if [[ -z "$runtime_rev" ]]; then
  echo "north up: package runtime provenance is unknown for $runtime_source; set authoritative FRAM_PACKAGE_REV" >&2
  exit 2
fi
runtime_tree="${runtime_tree:-immutable:$runtime_rev}"

export NORTH_FRAM_RUNTIME="$runtime_selector"
export FRAM_HOME FRAM_BIN
export FRAM_RUNTIME_SOURCE="$runtime_source"
export FRAM_RUNTIME_REV="$runtime_rev"
export FRAM_RUNTIME_TREE="$runtime_tree"
export FRAM_RUNTIME_DAEMON="$runtime_daemon"

doctor_output=
doctor_healthy() {
  local rc=0 first_line
  doctor_output="$("$fram" doctor 2>&1)" || rc=$?
  first_line="${doctor_output%%$'\n'*}"
  [[ "$rc" -eq 0 &&
     "$first_line" =~ ^coordinator\ UP\ on\ 127\.0\.0\.1:${FRAM_PORT}\ \(v[0-9]+\)$ ]]
}

strict_probe_output=
strict_ready() {
  local rc=0
  strict_probe_output="$(
    "$north_bb" "$NORTH_HOME/cli/coord.clj" strict-probe "$FRAM_PORT" "$FRAM_LOG" 2>&1
  )" || rc=$?
  [[ "$rc" -eq 0 ]]
}

# Return listener PIDs in stable order. `ss` is in North's Linux closure;
# macOS ships `lsof`. Absence is acceptable for a normal start, but a restart
# must never guess which process to kill.
listener_pids() {
  if command -v ss >/dev/null 2>&1; then
    ss -tlnpH "sport = :$FRAM_PORT" 2>/dev/null \
      | grep -oE 'pid=[0-9]+' \
      | cut -d= -f2 \
      | sort -nu \
      || true
    return 0
  fi
  if command -v lsof >/dev/null 2>&1; then
    lsof -nP -iTCP:"$FRAM_PORT" -sTCP:LISTEN -t 2>/dev/null \
      | sort -nu \
      || true
    return 0
  fi
  return 127
}

proc_root="${NORTH_PROC_ROOT:-/proc}"
listener_supervisor=
listener_identity_error=
listener_ownership_error=
owned_listener_pid=
owned_listener_birth=
owned_listener_owner=

process_env_value() {
  local pid="$1" name="$2"
  if [[ -r "$proc_root/$pid/environ" ]]; then
    tr '\0' '\n' <"$proc_root/$pid/environ" \
      | sed -n "s/^${name}=//p" \
      | head -n 1
    return
  fi
  return 1
}

runtime_record_value() {
  local name="$1"
  [[ -r "$runtime_identity_file" ]] || return 1
  sed -n "s/^${name}=//p" "$runtime_identity_file" | head -n 1
}

pid_birth_token() {
  local pid="$1" stat_line remainder start_time ps_start
  if [[ -r "$proc_root/$pid/stat" ]]; then
    stat_line="$(<"$proc_root/$pid/stat")"
    remainder="${stat_line##*) }"
    start_time="$(awk '{print $20}' <<<"$remainder")"
    if [[ "$start_time" =~ ^[0-9]+$ ]]; then
      printf 'proc:%s\n' "$start_time"
      return 0
    fi
  fi
  ps_start="$(LC_ALL=C ps -p "$pid" -o lstart= 2>/dev/null | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' || true)"
  if [[ -n "$ps_start" ]]; then
    printf 'ps:%s\n' "$ps_start"
    return 0
  fi
  return 1
}

runtime_record_matches_pid_birth() {
  local pid="$1" recorded_pid recorded_birth current_birth
  recorded_pid="$(runtime_record_value PID || true)"
  recorded_birth="$(runtime_record_value PID_BIRTH || true)"
  current_birth="$(pid_birth_token "$pid" || true)"
  [[ -n "$recorded_pid" && "$recorded_pid" == "$pid" &&
     -n "$recorded_birth" && "$recorded_birth" == "$current_birth" ]]
}

runtime_identity_value() {
  local pid="$1" name="$2" value
  value="$(process_env_value "$pid" "$name" || true)"
  if [[ -n "$value" ]]; then
    printf '%s\n' "$value"
    return 0
  fi

  # macOS has no /proc. A launcher-owned, PID-bound identity record is the
  # portable fallback. PID alone is never authority: the record must also match
  # the process birth identity so PID reuse cannot inherit runtime trust.
  runtime_record_matches_pid_birth "$pid" || return 1
  runtime_record_value "$name"
}

mint_owner_token() {
  local token=
  if [[ -r /proc/sys/kernel/random/uuid ]]; then
    token="$(</proc/sys/kernel/random/uuid)"
  elif command -v uuidgen >/dev/null 2>&1; then
    token="$(uuidgen)"
  else
    token="$(date +%s%N 2>/dev/null || date +%s)-$$-$RANDOM-$RANDOM"
  fi
  [[ -n "$token" ]] || return 1
  printf '%s\n' "$token"
}

publish_runtime_identity() {
  local pid="$1" birth="$2" owner_token="$3"
  local identity_tmp="$runtime_identity_file.tmp.$$"
  mkdir -p "$(dirname "$runtime_identity_file")"
  (umask 077; printf '%s\n' \
    "PID=$pid" \
    "PID_BIRTH=$birth" \
    "OWNER_TOKEN=$owner_token" \
    "FRAM_RUNTIME_SOURCE=$runtime_source" \
    "FRAM_RUNTIME_REV=$runtime_rev" \
    "FRAM_RUNTIME_TREE=$runtime_tree" \
    "FRAM_RUNTIME_DAEMON=$runtime_daemon" \
    >"$identity_tmp")
  mv -f "$identity_tmp" "$runtime_identity_file"
}

supervisor_for_pid() {
  local pid="$1" cgroup component
  local -a cgroup_components
  [[ -r "$proc_root/$pid/cgroup" ]] || return 1
  while IFS= read -r cgroup; do
    IFS=/ read -r -a cgroup_components <<<"${cgroup#*::}"
    for component in "${cgroup_components[@]}"; do
      [[ "$component" == *.service ]] || continue
      # user@.service is the delegated per-user manager enclosing ordinary
      # scopes and direct children; it does not supervise those processes.
      # A later concrete .service component, if present, is still authoritative.
      [[ "$component" == user@*.service ]] && continue
      printf '%s\n' "$component"
      return 0
    done
  done <"$proc_root/$pid/cgroup"
  return 1
}

runtime_identity_matches_pid() {
  local pid="$1" running_source running_rev running_tree running_daemon
  local running_head derived_tree source_is_verified_deployment_snapshot=0
  running_source="$(runtime_identity_value "$pid" FRAM_RUNTIME_SOURCE || true)"
  running_rev="$(runtime_identity_value "$pid" FRAM_RUNTIME_REV || true)"
  running_tree="$(runtime_identity_value "$pid" FRAM_RUNTIME_TREE || true)"
  running_daemon="$(runtime_identity_value "$pid" FRAM_RUNTIME_DAEMON || true)"

  # Diagnose pre-identity-contract coordinators precisely instead of collapsing
  # them into a generic unknown verdict.
  [[ -n "$running_source" ]] || running_source="$(runtime_identity_value "$pid" FRAM_HOME || true)"
  [[ -n "$running_rev" ]] || running_rev="$(runtime_identity_value "$pid" FRAM_PACKAGE_REV || true)"

  if [[ -z "$running_source" || -z "$running_rev" ]]; then
    listener_identity_error="PID $pid does not expose FRAM_RUNTIME_SOURCE and FRAM_RUNTIME_REV"
    return 1
  fi
  running_source="$(canonical_path "$running_source")"
  if [[ "$runtime_selector" == checkout && -z "$running_tree" ]] &&
     running_head="$(git -C "$running_source" rev-parse --verify HEAD 2>/dev/null)" &&
     [[ "$running_head" == "$running_rev" ]] &&
     git -C "$running_source" diff --quiet --no-ext-diff HEAD --; then
    derived_tree="$(git -C "$running_source" rev-parse --verify 'HEAD^{tree}' 2>/dev/null || true)"
    running_tree="$derived_tree"
  fi
  if [[ "$runtime_selector" == checkout && "$running_source" != "$runtime_source" ]]; then
    # A systemd-supervised coordinator always executes a rev-pinned deployment
    # snapshot worktree (north-data/fram-runtime/deployments/<rev>), never the
    # sibling checkout the CLI targets. Recognize that snapshot as identity
    # -matching only when its own name and git history independently verify
    # the desired rev — never by trusting the exported source path or rev
    # alone — so every other source mismatch still fails closed.
    if [[ "$running_source" == */fram-runtime/deployments/* &&
          "$(basename -- "$running_source")" == "$runtime_rev" ]] &&
       running_head="$(git -C "$running_source" rev-parse --verify HEAD 2>/dev/null)" &&
       [[ "$running_head" == "$runtime_rev" ]] &&
       git -C "$running_source" diff --quiet --no-ext-diff HEAD --; then
      derived_tree="$(git -C "$running_source" rev-parse --verify 'HEAD^{tree}' 2>/dev/null || true)"
      running_tree="$derived_tree"
      source_is_verified_deployment_snapshot=1
    fi
  fi
  if [[ ( "$running_source" != "$runtime_source" && "$source_is_verified_deployment_snapshot" -ne 1 ) ||
        "$running_rev" != "$runtime_rev" ||
        ( "$runtime_selector" == checkout && "$running_tree" != "$runtime_tree" ) ]]; then
    listener_identity_error="PID $pid runs Fram source=$running_source rev=$running_rev tree=${running_tree:-unknown}; desired source=$runtime_source rev=$runtime_rev tree=$runtime_tree"
    return 1
  fi
  if [[ -n "$running_daemon" ]]; then
    running_daemon="$(canonical_path "$running_daemon")"
    if [[ "$running_daemon" != "$runtime_daemon" ]]; then
      # A verified deployment snapshot's own executable, at the same
      # path suffix under its rev-pinned worktree, is the identical file the
      # already-verified matching tree provides — never a substitute identity.
      if [[ "$source_is_verified_deployment_snapshot" -eq 1 &&
            "$running_daemon" == "$running_source${runtime_daemon#"$runtime_source"}" ]]; then
        :
      else
        listener_identity_error="PID $pid runs Fram executable=$running_daemon; desired executable=$runtime_daemon"
        return 1
      fi
    fi
  fi
  return 0
}

launcher_owns_listener() {
  local pids="$1" pid count=0 recorded_pid recorded_birth current_birth
  local recorded_owner running_owner
  listener_ownership_error=
  owned_listener_pid=
  owned_listener_birth=
  owned_listener_owner=
  while IFS= read -r pid; do
    [[ -n "$pid" ]] || continue
    count=$((count + 1))
    owned_listener_pid="$pid"
  done <<<"$pids"
  if [[ "$count" -ne 1 ]]; then
    listener_ownership_error="expected exactly one listener PID, observed $count"
    return 1
  fi

  recorded_pid="$(runtime_record_value PID || true)"
  recorded_birth="$(runtime_record_value PID_BIRTH || true)"
  recorded_owner="$(runtime_record_value OWNER_TOKEN || true)"
  current_birth="$(pid_birth_token "$owned_listener_pid" || true)"
  if [[ -z "$recorded_pid" || "$recorded_pid" != "$owned_listener_pid" ||
        -z "$recorded_birth" || "$recorded_birth" != "$current_birth" ||
        -z "$recorded_owner" ]]; then
    listener_ownership_error="listener PID $owned_listener_pid has no matching launcher ownership record (pid/birth/token)"
    return 1
  fi
  owned_listener_birth="$recorded_birth"
  owned_listener_owner="$recorded_owner"

  running_owner="$(process_env_value "$owned_listener_pid" FRAM_RUNTIME_OWNER_TOKEN || true)"
  if [[ -r "$proc_root/$owned_listener_pid/environ" && "$running_owner" != "$recorded_owner" ]]; then
    listener_ownership_error="listener PID $owned_listener_pid owner token does not match its launcher record"
    return 1
  fi
  return 0
}

runtime_identity_matches_listeners() {
  local pids="$1" pid count=0
  listener_identity_error=
  listener_supervisor=
  while IFS= read -r pid; do
    [[ -n "$pid" ]] || continue
    count=$((count + 1))
    if [[ -z "$listener_supervisor" ]]; then
      listener_supervisor="$(supervisor_for_pid "$pid" || true)"
    fi
    runtime_identity_matches_pid "$pid" || return 1
  done <<<"$pids"
  if [[ "$count" -ne 1 ]]; then
    listener_identity_error="expected exactly one coordinator listener PID, observed $count"
    return 1
  fi
  return 0
}

spawned_identity_matches_pid() {
  local pid="$1"
  if [[ -r "$proc_root/$pid/environ" ]]; then
    runtime_identity_matches_pid "$pid"
    return
  fi
  # On platforms without /proc, the exact executable and environment above are
  # the spawn proof. Publish the portable PID-bound record only after that child
  # owns the listener and passes both coordinator readiness probes.
  return 0
}

before_pids=
have_pid_probe=0
if before_pids="$(listener_pids)"; then
  have_pid_probe=1
fi

identity_matches=0
if [[ -n "$before_pids" ]] && runtime_identity_matches_listeners "$before_pids"; then
  identity_matches=1
fi

if [[ "$check_runtime" -eq 1 ]]; then
  if [[ "$identity_matches" -eq 1 ]]; then
    echo "coordinator runtime identity OK on :$FRAM_PORT (source: $runtime_source, rev: $runtime_rev)"
    exit 0
  fi
  echo "north coord-doctor: coordinator runtime identity UNHEALTHY — ${listener_identity_error:-no listener identity available}" >&2
  exit 1
fi

same_log=0
if doctor_healthy; then
  same_log=1
fi
strict=0
if [[ "$same_log" -eq 1 ]] && strict_ready; then
  strict=1
fi

if [[ "$stop" -eq 1 && -z "$before_pids" ]]; then
  if [[ "$have_pid_probe" -ne 1 ]]; then
    echo "north up: coordinator listener state cannot be identified safely; refusing stop" >&2
    exit 1
  fi
  echo "coordinator already stopped on :$FRAM_PORT"
  exit 0
fi

if [[ "$strict" -eq 1 && "$restart" -eq 0 && "$stop" -eq 0 ]]; then
  if [[ "$identity_matches" -ne 1 ]]; then
    echo "north up: coordinator runtime identity mismatch — $listener_identity_error" >&2
    exit 1
  fi
  echo "coordinator already up on :$FRAM_PORT (source: $runtime_source, rev: $runtime_rev; use \`north up --restart\` to reload it)"
  exit 0
fi

if [[ "$same_log" -eq 1 && "$strict" -eq 0 && "$restart" -eq 0 && "$stop" -eq 0 ]]; then
  echo "north up: coordinator on :$FRAM_PORT serves the configured log but does not enforce corpus fences; run \`north up --restart\` to replace it safely" >&2
  [[ -z "$strict_probe_output" ]] || printf '%s\n' "$strict_probe_output" >&2
  exit 1
fi

if [[ -n "$before_pids" ]]; then
  if [[ "$same_log" -eq 0 ]]; then
    echo "north up: :$FRAM_PORT is occupied, but Fram did not verify that it serves $FRAM_LOG; refusing to replace it" >&2
    [[ -z "$doctor_output" ]] || printf '%s\n' "$doctor_output" >&2
    exit 1
  fi
fi

if [[ ( "$restart" -eq 1 || "$stop" -eq 1 ) && "$same_log" -eq 1 ]]; then
  if [[ "$stop" -eq 1 && "$strict" -ne 1 ]]; then
    echo "north up: coordinator on :$FRAM_PORT does not enforce corpus fences; refusing to signal it" >&2
    [[ -z "$strict_probe_output" ]] || printf '%s\n' "$strict_probe_output" >&2
    exit 1
  fi
  if [[ "$have_pid_probe" -ne 1 || -z "$before_pids" ]]; then
    echo "north up: coordinator is healthy, but its listener PID cannot be identified safely; refusing stop/restart" >&2
    exit 1
  fi

  if [[ "$stop" -eq 1 && "$identity_matches" -ne 1 ]]; then
    echo "north up: coordinator runtime identity mismatch — $listener_identity_error; refusing stop" >&2
    exit 1
  fi

  # Killing a supervised MainPID does not replace that runtime: the supervisor
  # immediately relaunches its configured executable and races North for the
  # same port. Fail before any signal so the owning service can be changed and
  # restarted through its one authoritative control plane.
  if [[ -n "$listener_supervisor" ]]; then
    echo "north up: coordinator listener is owned by systemd unit $listener_supervisor; refusing a direct stop/restart that the supervisor would reclaim" >&2
    if [[ "$identity_matches" -ne 1 ]]; then
      echo "north up: coordinator runtime identity mismatch — $listener_identity_error" >&2
    fi
    exit 1
  fi

  if ! launcher_owns_listener "$before_pids"; then
    echo "north up: refusing to signal an unowned coordinator — $listener_ownership_error" >&2
    if [[ "$identity_matches" -ne 1 ]]; then
      echo "north up: coordinator runtime identity mismatch — $listener_identity_error" >&2
    fi
    exit 1
  fi

  after_pids="$(listener_pids)"
  if [[ "$before_pids" != "$after_pids" ]]; then
    echo "north up: listener on :$FRAM_PORT changed during the health check; refusing restart" >&2
    exit 1
  fi
  if ! launcher_owns_listener "$after_pids"; then
    echo "north up: listener ownership changed during the health check; refusing restart — $listener_ownership_error" >&2
    exit 1
  fi

  echo "stopping coordinator on :$FRAM_PORT"
  kill "$owned_listener_pid"

  for _ in $(seq 1 40); do
    [[ -z "$(listener_pids)" ]] && break
    sleep 0.1
  done
  if [[ -n "$(listener_pids)" ]]; then
    echo "north up: coordinator on :$FRAM_PORT did not stop after SIGTERM; refusing to force-kill it" >&2
    exit 1
  fi

  # Clear only the identity records still naming the exact PID/birth/token we
  # just proved and stopped. A concurrent launcher that published a successor
  # must never have its authority unlinked by this process.
  if [[ "$(runtime_record_value PID || true)" == "$owned_listener_pid" &&
        "$(runtime_record_value PID_BIRTH || true)" == "$owned_listener_birth" &&
        "$(runtime_record_value OWNER_TOKEN || true)" == "$owned_listener_owner" ]]; then
    unlink -- "$runtime_identity_file"
  fi
  if [[ -n "${NORTH_COORD_PID_FILE:-}" && -f "$NORTH_COORD_PID_FILE" &&
        "$(<"$NORTH_COORD_PID_FILE")" == "$owned_listener_pid" ]]; then
    unlink -- "$NORTH_COORD_PID_FILE"
  fi
  if [[ "$stop" -eq 1 ]]; then
    echo "coordinator stopped on :$FRAM_PORT"
    exit 0
  fi
fi

diagnostic_log="${FRAM_DAEMON_LOG:-$state_home/north/fram-daemon-$FRAM_PORT.log}"
mkdir -p "$(dirname "$FRAM_LOG")" "$(dirname "$diagnostic_log")"

echo "starting coordinator on :$FRAM_PORT  (log: $FRAM_LOG)"
export FRAM_SNAPSHOT_BOOT="${FRAM_SNAPSHOT_BOOT:-1}"
launcher_owner_token="$(mint_owner_token)"
export FRAM_RUNTIME_OWNER_TOKEN="$launcher_owner_token"
nohup "$daemon" "$FRAM_PORT" "$FRAM_LOG" \
  </dev/null >"$diagnostic_log" 2>&1 &
daemon_pid=$!
if [[ -n "${NORTH_COORD_PID_FILE:-}" ]]; then
  mkdir -p "$(dirname "$NORTH_COORD_PID_FILE")"
  pid_tmp="$NORTH_COORD_PID_FILE.tmp.$$"
  (umask 077; printf '%s\n' "$daemon_pid" >"$pid_tmp")
  mv -f "$pid_tmp" "$NORTH_COORD_PID_FILE"
fi

# JVM startup includes folding the fact log. Poll BOTH the log-aware doctor and
# the strict raw-wire policy probe for at most 30 seconds. When listener PID
# inspection exists, the socket must belong to the child we just spawned; this
# prevents an old compatibility peer from winning the readiness race.
for _ in $(seq 1 120); do
  if doctor_healthy && strict_ready; then
    listener_owned=1
    if [[ "$have_pid_probe" -eq 1 ]]; then
      listener_owned=0
      while IFS= read -r pid; do
        if [[ "$pid" == "$daemon_pid" ]]; then
          listener_owned=1
          break
        fi
      done < <(listener_pids)
    fi
    if [[ "$listener_owned" -eq 1 ]] && spawned_identity_matches_pid "$daemon_pid"; then
      daemon_birth="$(pid_birth_token "$daemon_pid" || true)"
      if [[ -z "$daemon_birth" ]]; then
        kill "$daemon_pid" 2>/dev/null || true
        echo "north up: coordinator PID birth identity is unavailable; refusing an unverifiable launch" >&2
        exit 1
      fi
      publish_runtime_identity "$daemon_pid" "$daemon_birth" "$launcher_owner_token"
      echo "coordinator up on :$FRAM_PORT"
      exit 0
    fi
  fi
  if ! kill -0 "$daemon_pid" 2>/dev/null; then
    wait "$daemon_pid" || true
    echo "north up: coordinator exited during startup — see $diagnostic_log" >&2
    exit 1
  fi
  sleep 0.25
done

kill "$daemon_pid" 2>/dev/null || true
echo "north up: coordinator did not become healthy — see $diagnostic_log" >&2
[[ -z "$doctor_output" ]] || printf '%s\n' "$doctor_output" >&2
exit 1
