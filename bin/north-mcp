(def gaffer-staffing-path
  (or (System/getenv "GAFFER_STAFFING_CATALOG")
      (str (or (System/getenv "GAFFER_HOME")
               (str (System/getProperty "user.home") "/code/gaffer"))
           "/staffing/catalog.json")))
(def gaffer-staffing
  (try (north.gaffer-staffing/load-catalog gaffer-staffing-path)
       (catch Exception _ nil)))
(def gaffer-role-names
  (set (keep #(get % "name") (get gaffer-staffing "presets"))))
(def gaffer-presets-by-name
  (north.gaffer-staffing/presets-by-name gaffer-staffing))

(def task-grade-values ["novice" "junior" "mid" "senior" "staff" "principal" "research-grade"])
(def topology-values ["worker" "orchestrator"])
(def tier-values ["economy" "standard" "senior" "frontier"])
(def reasoning-values ["low" "medium" "high" "xhigh" "max"])
(def posture-values ["explore" "evaluate" "deliver" "preserve"])
(def role-id-pattern "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$")
(def capability-values
  (vec (or (get-in gaffer-staffing ["vocabulary" "capabilities"]) [])))
(def capabilities-schema
  {:type "array" :minItems 1 :uniqueItems true
   :items {:type "string" :enum capability-values}})
(def non-empty-strings-schema
  {:type "array" :minItems 1 :uniqueItems true :items {:type "string" :minLength 1}})
(def bespoke-contract-schema
  {:type "object"
   :properties {:responsibility {:type "string" :minLength 1}
                :deliverable {:type "string" :minLength 1}
                :capabilities capabilities-schema
                :mayDecide non-empty-strings-schema
                :mustEscalate non-empty-strings-schema
                :doneWhen non-empty-strings-schema
                :report {:type "string" :minLength 1}}
   :required ["responsibility" "deliverable" "capabilities" "mayDecide" "mustEscalate" "doneWhen" "report"]
   :additionalProperties false})
(def composition-schema
  {:oneOf
   [{:type "object"
     :properties {:kind {:const "preset"}
                  :id {:type "string" :pattern role-id-pattern :not {:enum ["researcher"]}}
                  :overrides {:type "array" :uniqueItems true
                              :items {:type "string" :enum ["taskGrade" "domainRequirements" "tier" "reasoning" "posture"]}}
                  :overrideReason {:type "string" :minLength 1}}
     :required ["kind" "id" "overrides"]
     :allOf [{:if {:properties {:overrides {:minItems 1}} :required ["overrides"]}
              :then {:required ["overrideReason"]}
              :else {:not {:required ["overrideReason"]}}}]
     :additionalProperties false}
    {:type "object"
     :properties {:kind {:const "bespoke"}
                  :id {:type "string" :pattern role-id-pattern :not {:enum ["researcher"]}}
                  :nearestPreset {:type "string" :pattern role-id-pattern :not {:enum ["researcher"]}}
                  :bespokeReason {:type "string" :minLength 1}
                  :promotionCandidate {:type "boolean"}
                  :contract bespoke-contract-schema}
     :required ["kind" "id" "bespokeReason" "promotionCandidate" "contract"]
     :additionalProperties false}]})
(def routing-properties
  {:taskGrade {:type "string" :enum task-grade-values :description "Real-world work grade; independent of model tier"}
   :domainRequirements {:type "array" :uniqueItems true :items {:type "string" :minLength 1} :description "Expertise/context the brief or adapter must supply; metadata alone loads nothing"}
   :topology {:type "string" :enum topology-values :description "Lane's coordination position; fixed by stock templates and explicit for bespoke compositions"}
   :composition composition-schema})
(def assessment-signal-schema
  {:type "object"
   :properties {:decisionOwnership {:type "string" :enum ["none" "bounded" "cross-boundary" "system-shaping" "open-solution-class"]}
                :seamScope {:type "string" :enum ["none" "established" "consequential" "system-wide"]}
                :errorExposure {:type "string" :enum ["contained-reversible" "material-recoverable" "high-or-hard-to-reverse"]}
                :oracleStrength {:type "string" :enum ["not-applicable" "objective-local" "objective-end-to-end" "partial" "judgment-only"]}
                :foundationalImpact {:type "string" :enum ["none" "implementation-only" "invariant-decision-owned"]}
                :dependencyShape {:type "string" :enum ["atomic-cohesive" "deterministic-workflow" "parallel-breadth" "dynamic-decomposition" "tightly-coupled-sequential"]}
                :reasoningShape {:type "string" :enum ["deterministic" "bounded-branching" "multi-hypothesis" "system-synthesis" "exceptional"]}}
   :required ["decisionOwnership" "seamScope" "errorExposure" "oracleStrength"
              "foundationalImpact" "dependencyShape" "reasoningShape"]
   :additionalProperties false})
(def routing-assessment-schema
  {:type "object"
   :properties {:$schema {:type "string" :minLength 1}
                :version {:const "minimum-sufficient-v1"}
                :signals assessment-signal-schema
                :derived {:type "object"
                          :properties {:minimumTier {:type "string" :enum tier-values}
                                       :minimumReasoning {:type "string" :enum reasoning-values}
                                       :ruleCodes non-empty-strings-schema}
                          :required ["minimumTier" "minimumReasoning" "ruleCodes"]
                          :additionalProperties false}
                :selected {:type "object"
                           :properties {:tier {:type "string" :enum tier-values}
                                        :reasoning {:type "string" :enum reasoning-values}}
                           :required ["tier" "reasoning"]
                           :additionalProperties false}
                :exception {:type "object"
                            :properties {:code {:type "string" :enum ["explicit-human-floor" "recent-lower-tier-failure" "calibration-experiment" "unmodeled-risk"]}
                                         :detail {:type "string" :minLength 1}}
                            :required ["code" "detail"]
                            :additionalProperties false}
                :exceptionalDeliberation {:type "string" :minLength 1}}
   :required ["version" "signals" "derived" "selected"]
   :additionalProperties false})
(def routing-pin-evidence-schema
  {:type "object"
   :properties {:policyVersion {:const "north-routing-pin-v1"}
                :issuedAt {:type "string" :format "date-time"}
                :expiresAt {:type "string" :format "date-time"}
                :reasonCode {:type "string" :enum ["explicit-human-request" "provider-recovery" "capability-requirement" "calibration-experiment"]}
                :detail {:type "string" :minLength 1}
                :pins {:type "array" :minItems 1 :maxItems 3 :uniqueItems true
                       :items {:type "object"
                               :properties {:kind {:type "string" :enum ["provider" "account" "model"]}
                                            :value {:type "string" :minLength 1}}
                               :required ["kind" "value"]
                               :additionalProperties false}}}
   :required ["policyVersion" "issuedAt" "expiresAt" "reasonCode" "detail" "pins"]
   :additionalProperties false})

(def sdk-tools
  [{:name "dispatch"
    :desc "Dispatch an agent for a thread (must exist — capture first). North derives posture and routes to an available provider. Returns the agent ID."
    ;; Property ORDER is load-bearing, not cosmetic: cheshire serializes a map in
    ;; its seq order, and a >8-key literal `{}` is a PersistentHashMap (scrambled,
    ;; unstable). `array-map` pins insertion order so tools/list advertises the work
    ;; identifier first, then the eight Gaffer routing fields contiguously, then the
    ;; optional compat/provider fields. Anti-rot: mcp-dispatch-contract.test.ts.
    :schema {:type "object"
             :properties (array-map
                          :id {:type "string" :minLength 1 :description "Thread ID to dispatch (e.g. 2026-06-27-193317)"}
                          :role {:type "string" :pattern role-id-pattern :not {:enum ["researcher"]} :description "Functional responsibility from Gaffer's staffing catalog, or a reasoned bespoke role."}
                          :taskGrade (:taskGrade routing-properties)
                          :domainRequirements (:domainRequirements routing-properties)
                          :topology (:topology routing-properties)
                          :tier {:type "string" :enum ["economy" "standard" "senior" "frontier"] :description "Provider-neutral capability tier"}
                          :reasoning {:type "string" :enum reasoning-values :description "Provider-neutral deliberation; independent of role and tier"}
                          :posture {:type "string" :enum posture-values}
                          :composition (:composition routing-properties)
                          :routingAssessment routing-assessment-schema
                          :pinEvidence routing-pin-evidence-schema
                          :model {:type "string" :minLength 1 :description "Provider model override; normally omit and let the semantic tier resolve it"}
                          :effort {:type "string" :enum reasoning-values :description "Compatibility alias for reasoning"}
                          :provider {:type "string" :enum ["auto" "anthropic" "openai"] :description "Agent provider (default auto)"}
                          :target {:type "string" :minLength 1 :description "Exact configured routing target/account; exact pins never fall back"}
                          :coordinator {:type "string" :minLength 1 :description "Caller's north id; the lane pings it on done/death + records a `coordinator` fact. Omit to inherit from AGENT_ID/NORTH_AGENT_ID env; pass explicitly from an interactive session."})
             :required ["id" "role" "taskGrade" "domainRequirements" "topology"
                        "tier" "reasoning" "posture" "composition"]
             :additionalProperties false}}
   {:name "spawn"
    :desc "Spawn an ad-hoc agent from a prompt (no thread needed; for thread work prefer capture+dispatch). Returns the agent ID."
    ;; Same deterministic contract as dispatch (see note there): work identifier
    ;; (prompt) first, then the eight Gaffer routing fields, then optional fields.
    :schema {:type "object"
             :properties (array-map
                          :prompt {:type "string" :minLength 1 :description "The task prompt"}
                          :role {:type "string" :pattern role-id-pattern :not {:enum ["researcher"]} :description "Functional responsibility from Gaffer's staffing catalog, or a reasoned bespoke role."}
                          :taskGrade (:taskGrade routing-properties)
                          :domainRequirements (:domainRequirements routing-properties)
                          :topology (:topology routing-properties)
                          :tier {:type "string" :enum ["economy" "standard" "senior" "frontier"] :description "Provider-neutral capability tier"}
                          :reasoning {:type "string" :enum reasoning-values :description "Provider-neutral deliberation; independent of role and tier"}
                          :posture {:type "string" :enum posture-values}
                          :composition (:composition routing-properties)
                          :routingAssessment routing-assessment-schema
                          :pinEvidence routing-pin-evidence-schema
                          :model {:type "string" :minLength 1 :description "Provider model override; normally omit and let the semantic tier resolve it"}
                          :effort {:type "string" :enum reasoning-values :description "Compatibility alias for reasoning"}
                          :provider {:type "string" :enum ["auto" "anthropic" "openai"] :description "Agent provider (default auto)"}
                          :target {:type "string" :minLength 1 :description "Exact configured routing target/account; exact pins never fall back"}
                          :caveman {:type "string" :enum ["off" "lite" "full"] :description "Terse-output dial (default ambient AGENT_CAVEMAN)"}
                          :worktree {:type "boolean" :description "OPT-IN: run this lane in an isolated per-lane git worktree (own index+tree). Default off."}
                          :setupCmd {:type "string" :minLength 1 :description "Optional repo-setup command run in the fresh worktree (e.g. 'bun install'); only with worktree=true"}
                          :coordinator {:type "string" :minLength 1 :description "Caller's north id; see dispatch.coordinator"})
             :required ["prompt" "role" "taskGrade" "domainRequirements" "topology"
                        "tier" "reasoning" "posture" "composition"]
             :additionalProperties false}}])

;; Attribution (routing-overhaul PART 1): the spawned lane inherits AGENT_COORDINATOR
;; so it records a `coordinator` fact + pings that id on completion/death — otherwise
;; every MCP-spawned lane shows coordinator "(none)" and audits can't attribute fan-out.
;; The host session's north id is NOT in this server's env (north-mcp registers env:{}),
;; so resolve it in priority order:
;;   1. explicit `coordinator` arg — an interactive session passes its "you are agent …" id;
;;   2. the CALLER's AGENT_ID — for a sub-spawn, this is the parent LANE's own id (its MCP
;;      server inherits {...process.env} incl. AGENT_ID), so sub-delegation attributes to
;;      the immediate parent, not a leaked top-of-tree pin;
;;   3. NORTH_AGENT_ID — a pinned session id (last, so an inherited pin never beats #2).
;; Captured from `env` BEFORE cmd-env reassigns AGENT_ID to the new lane.
(defn canonical-default-path [home & segments]
  (.getCanonicalPath (apply io/file home segments)))

(defn materialize-instance-env
  "Compile the MCP server's captured process environment into the exact North
  instance selectors a managed child receives. Explicit instance pins win;
  otherwise this mirrors bin/north's facts.log default and seeded split switch."
  ([source]
   (materialize-instance-env source #(.isFile (io/file %))))
  ([source regular-file?]
   (let [home (or (not-empty (get source "HOME"))
                  (System/getProperty "user.home"))
         explicit-log (not-empty (get source "FRAM_LOG"))
         explicit-telemetry (not-empty (get source "FRAM_TELEMETRY_LOG"))
         default-log (canonical-default-path home ".local" "state" "north" "facts.log")
         initial-log (or explicit-log default-log)
         log-parent (or (.getParent (io/file initial-log)) ".")
         split-log (.getCanonicalPath (io/file log-parent "coordination.log"))
         split? (and (nil? explicit-log)
                     (nil? explicit-telemetry)
                     (regular-file? split-log))
         selected-log (if split? split-log initial-log)
         threads (or (not-empty (get source "FRAM_THREADS"))
                     (canonical-default-path home ".local" "state" "north" "threads"))
         port (or (not-empty (get source "NORTH_PORT")) "7977")]
     (cond-> (assoc source
                    "HOME" home
                    "FRAM_LOG" selected-log
                    "FRAM_THREADS" threads
                    "NORTH_PORT" port)
       split? (assoc "FRAM_TELEMETRY_LOG"
                     (.getCanonicalPath (io/file log-parent "telemetry.log")))))))

(defn resolve-coordinator [env args]
  (or (not-empty (get args "coordinator"))
      (not-empty (get env "AGENT_ID"))
      (not-empty (get env "NORTH_AGENT_ID"))))

;; A child request owns every managed routing axis. Starting from the parent
;; process environment without removing these lets a director's composition or
;; account pin contaminate a role-only worker request. Capture coordinator
;; attribution first, then construct the child from this scrubbed base.
(defn semantic-segment [value]
  (let [s (some-> value str str/trim str/lower-case
                  (str/replace #"[^a-z0-9]+" "-")
                  (str/replace #"(^-|-$)" ""))]
    (if (seq s) s "unknown")))

(defn canonical-north-thread-id [value]
  (let [raw (when (string? value) value)
        bare (some-> raw (str/replace-first #"^@" ""))]
    (when (and raw
               (= raw (str/trim raw))
               (<= (count bare) 512)
               (re-matches #"[A-Za-z0-9][A-Za-z0-9._:-]*" bare))
      bare)))

(defn north-thread-subject [value]
  (when-let [id (canonical-north-thread-id value)]
    (str "@" id)))

(defn semantic-model [value]
  (let [model (semantic-segment value)
        parts (set (str/split model #"-"))]
    (or (some #(when (parts %) %) ["opus" "sonnet" "haiku" "fable" "sol" "terra" "luna"])
        model)))

(defn observed-agent-facts [agent-id]
  (try
    (let [{:keys [out exit]} (proc/sh engine "json" "show" (str "agent:" agent-id))]
      (when (zero? exit)
        (reduce (fn [facts fact]
                  (if-let [predicate (not-empty (get fact "predicate"))]
                    (north.agent-provenance/fold-fact facts predicate (get fact "value"))
                    facts))
                {} (json/parse-string out))))
    (catch Exception _ nil)))

(defn mcp-agent-online? [agent-id]
  (try
    (let [{:keys [out exit]} (proc/sh {:out :string :err :string}
                                      driver-bb (str root "/cli/presence-cli.clj")
                                      north-port "presence-online")]
      (and (zero? exit)
           (boolean
            (some (fn [line]
                    (let [tokens (str/split (str/trim line) #"\s+")]
                      (and (= agent-id (first tokens)) (some #{"yes"} tokens))))
                  (str/split-lines out)))))
    (catch Exception _ false)))

(defn launch-sdk! [command cmd-env log]
  (north.spawn-process/launch-detached! command cmd-env log))

(defn await-sdk-startup [process agent-id log]
  (north.spawn-process/await-startup
   process agent-id log observed-agent-facts mcp-agent-online?))

(defn startup-success? [startup]
  (contains? #{:ready :completed} (:status startup)))

(defn startup-summary [verb startup suffix]
  (if (= :completed (:status startup))
    (str "completed " (:handle startup) suffix
         "\nAgent reached outcome=" (:outcome startup) " during startup acknowledgement. "
         "Control key: @agent:" (:agent-id startup) ".")
    (str verb " " (:handle startup) suffix
         "\nAgent is running in the background. "
         "Control key: @agent:" (:agent-id startup) ".")))

(defn create-mcp-agent-id [thread]
  (let [segment (semantic-segment thread)
        fragment (subs segment (max 0 (- (count segment) 12)))]
    (north.spawn-process/create-agent-id (str "sdk-" fragment))))

(defn driver-command [verb thread agent-id]
  (when-let [subject (north-thread-subject thread)]
    (try
      (:exit (proc/sh {:out :string :err :string}
                      driver-bb driver-cli north-port verb subject agent-id))
      (catch Exception _ nil))))

(defn claim-driver-problem [thread agent-id]
  (let [id (canonical-north-thread-id thread)]
    (case (driver-command "claim" id agent-id)
      0 nil
      3 (str "thread @" id " already has an active driver")
      (str "could not establish the active driver for thread @" id))))

(defn release-driver! [thread agent-id]
  ;; The child releases on every normal terminal path. This duplicate release is
  ;; intentional: it also covers construction failure and abrupt child exit.
  (driver-command "release" thread agent-id)
  nil)

(defn watch-driver-release! [process thread agent-id]
  (future
    (try
      @process
      (catch Exception _ nil)
      (finally (release-driver! thread agent-id)))))

(def sdk-argument-keys
  {"dispatch" #{"id" "model" "effort" "reasoning" "role" "posture" "provider" "target" "tier"
                 "coordinator" "taskGrade" "domainRequirements" "topology" "composition"
                 "routingAssessment" "pinEvidence"}
   "spawn" #{"prompt" "model" "effort" "reasoning" "role" "posture" "provider" "target" "tier"
              "caveman" "coordinator" "taskGrade" "domainRequirements" "topology" "composition"
              "routingAssessment" "pinEvidence"}})

(def routing-override-fields
  #{"taskGrade" "domainRequirements" "tier" "reasoning" "posture"})
(def managed-routing-fields
  ["role" "taskGrade" "domainRequirements" "topology"
   "tier" "reasoning" "posture" "composition"])
(def bespoke-contract-fields
  #{"responsibility" "deliverable" "capabilities" "mayDecide" "mustEscalate" "doneWhen" "report"})

(def edge-ascii-whitespace #"^[\u0009-\u000d\u0020]+|[\u0009-\u000d\u0020]+$")

(defn canonical-contract-text [value]
  (if (string? value)
    (-> value
        (str/replace #"\r\n?" "\n")
        (java.text.Normalizer/normalize java.text.Normalizer$Form/NFC)
        (str/replace edge-ascii-whitespace ""))
    value))

(defn canonicalize-bespoke-routing [args]
  (let [composition (when (map? args) (get args "composition"))
        contract (when (map? composition) (get composition "contract"))]
    (if (and (= "bespoke" (get composition "kind")) (map? contract))
      (let [normalized
            (-> (reduce (fn [value field]
                          (if (contains? value field)
                            (update value field canonical-contract-text)
                            value))
                        contract ["responsibility" "deliverable" "report"])
                ((fn [value]
                   (reduce (fn [result field]
                             (if (sequential? (get result field))
                               (update result field #(mapv canonical-contract-text %))
                               result))
                           value ["capabilities" "mayDecide" "mustEscalate" "doneWhen"]))))]
        (assoc-in args ["composition" "contract"] normalized))
      args)))

(defn valid-string-list? [value require-items?]
  (and (sequential? value)
       (or (not require-items?) (seq value))
       (every? #(and (string? %) (not (str/blank? %))) value)
       (let [normalized (mapv canonical-contract-text value)]
         (= (count normalized) (count (set normalized))))))

(defn non-empty-string? [value]
  (and (string? value) (not (str/blank? value))))

(defn safe-role-id? [value]
  (and (string? value) (boolean (re-matches (re-pattern role-id-pattern) value))))

(defn topology-capability-problem [topology capabilities]
  (let [caps (set capabilities)]
    (cond
      (and (caps "shell") (caps "shell.readonly"))
      "shell and shell.readonly are mutually exclusive"
      (and (= topology "orchestrator") (not (caps "coordination")))
      "orchestrator topology requires coordination capability"
      (and (= topology "orchestrator") (caps "filesystem.write"))
      "orchestrator topology forbids filesystem.write capability"
      (and (= topology "orchestrator") (caps "shell"))
      "orchestrator topology forbids unrestricted shell capability"
      (and (= topology "worker") (caps "coordination"))
      "worker topology forbids coordination capability"
      :else nil)))

(defn invalid-routing [nm args]
  (if-not (map? args)
    "arguments must be an object"
    (let [grade (get args "taskGrade") topology (get args "topology") role (get args "role")
        domains (get args "domainRequirements") composition (get args "composition")
        reasoning (get args "reasoning") effort (get args "effort") effective-reasoning reasoning
        tier (get args "tier") posture (get args "posture") provider (get args "provider")
        target (get args "target") model (get args "model") coordinator (get args "coordinator")
        id (get args "id") prompt (get args "prompt") caveman (get args "caveman")
        unknown (seq (sort (remove (get sdk-argument-keys nm #{}) (keys args))))
        missing-routing (seq (remove #(contains? args %) managed-routing-fields))
        kind (when (map? composition) (get composition "kind"))
        composition-keys (case kind
                           "preset" #{"kind" "id" "overrides" "overrideReason"}
                           "bespoke" #{"kind" "id" "nearestPreset" "bespokeReason" "promotionCandidate" "contract"}
                           #{"kind" "id" "overrides" "overrideReason" "nearestPreset" "bespokeReason" "promotionCandidate" "contract"})
        unknown-composition (when (map? composition)
                              (seq (sort (remove composition-keys (keys composition)))))
        contract (when (map? composition) (get composition "contract"))
        contract-capabilities (when (map? contract) (get contract "capabilities"))
        unknown-contract (when (map? contract)
                           (seq (sort (remove bespoke-contract-fields (keys contract)))))
        canonical-role role
        known-role? (contains? gaffer-role-names canonical-role)
        preset (get gaffer-presets-by-name canonical-role)
        effective-capabilities (if known-role? (get preset "capabilities") contract-capabilities)
        effective-topology topology
        depth-problem
        (north.topology-authority/managed-child-topology-problem
         nm effective-topology)
        capability-problem (when (and effective-topology (sequential? effective-capabilities))
                             (topology-capability-problem effective-topology effective-capabilities))
        base-posture (or (get preset "posture") (get-in gaffer-staffing ["defaults" "posture"]))
        actual-overrides (set (keep (fn [[field supplied base]]
                                      (when (and (some? supplied) (not= supplied base)) field))
                                    [["taskGrade" grade (get preset "taskGrade")]
                                     ["domainRequirements" domains []]
                                     ["tier" tier (get preset "tier")]
                                     ["reasoning" effective-reasoning (get preset "deliberation")]
                                     ["posture" posture base-posture]]))
        declared-overrides (when (= kind "preset") (get composition "overrides"))
        route-problem (north.gaffer-staffing/unsupported-route-problem tier effective-reasoning)
        missing-bespoke-axes (when (and role (not known-role?))
                               (seq (keep (fn [[label value]] (when (nil? value) label))
                                          [["taskGrade" grade] ["domainRequirements" domains]
                                           ["topology" topology] ["tier" tier]
                                           ["reasoning" effective-reasoning] ["posture" posture]])))]
    (cond
      unknown (str "unknown " nm " routing field(s): " (str/join ", " unknown))
      (and (= nm "dispatch") (not (non-empty-string? id))) "dispatch id must be a non-empty string"
      (and (= nm "dispatch") (nil? (canonical-north-thread-id id)))
      "dispatch id must be a safe North thread id (bare or single @ prefix)"
      (and (= nm "spawn") (not (non-empty-string? prompt))) "spawn prompt must be a non-empty string"
      missing-routing
      (str "managed " nm " requires the complete eight-field Gaffer request; missing: "
           (str/join ", " missing-routing))
      (and (#{"dispatch" "spawn"} nm) (not (non-empty-string? role)))
      (str "managed " nm " requires role selecting a canonical Gaffer preset or a complete bespoke composition")
      (and (some? model) (not (non-empty-string? model))) "model must be a non-empty string"
      (and (some? coordinator) (not (non-empty-string? coordinator))) "coordinator must be a non-empty string"
      (and (some? caveman) (not (some #{caveman} ["off" "lite" "full"]))) "invalid caveman mode"
      (and role (or (not (string? role)) (str/blank? role))) "role must be a non-empty string"
      (and role (not (safe-role-id? role))) "role must be a lowercase kebab-case Gaffer role id"
      (= role "researcher") "role researcher is retired because it was ambiguous; use scout, analyst, or research-scientist"
      (#{"worker" "orchestrator"} role) (str role " is a topology, not a role; use director for orchestration or a functional worker role")
      (and role (nil? gaffer-staffing)) (str "Gaffer staffing catalog unavailable: " gaffer-staffing-path)
      (not (some #{grade} task-grade-values)) "invalid taskGrade"
      (not (valid-string-list? domains false))
      "domainRequirements must contain unique non-empty strings"
      (not (some #{topology} topology-values)) "invalid topology"
      (and role known-role? (not= topology (get preset "topology")))
      (str "stock-template topology is fixed at '" (get preset "topology")
           "'; use a bespoke composition for '" topology "'")
      depth-problem depth-problem
      (not (some #{tier} tier-values)) "invalid tier"
      (not (some #{reasoning} reasoning-values)) "invalid reasoning"
      route-problem route-problem
      (not (some #{posture} posture-values)) "invalid posture"
      (and provider (not (some #{provider} ["auto" "anthropic" "openai"]))) "invalid provider"
      (and reasoning effort (not= reasoning effort)) "reasoning and compatibility effort disagree"
      (and target (or (not (string? target)) (str/blank? target))) "target must be a non-empty string"
      (not (map? composition)) "composition must be an object"
      unknown-composition (str "unknown composition field(s): " (str/join ", " unknown-composition))
      (and composition (not (#{"preset" "bespoke"} kind))) "invalid composition.kind"
      (and composition (let [v (get composition "id")] (or (not (string? v)) (str/blank? v)))) "composition.id is required"
      (and composition (not (safe-role-id? (get composition "id"))))
      "composition.id must be a lowercase kebab-case Gaffer role id"
      (and composition (nil? role)) "composition requires role"
      (and role (not known-role?) (= kind "preset"))
      (str "unknown role " role " requires a bespoke composition")
      (and role known-role? (= kind "bespoke"))
      (str "known role " canonical-role " requires preset composition id " canonical-role)

      (and (= kind "preset") (not (valid-string-list? declared-overrides false)))
      "preset composition.overrides must be an array of unique routing-axis names"
      (and (= kind "preset") (some #(not (routing-override-fields %)) declared-overrides))
      "composition.overrides contains an invalid routing axis"
      (and (= kind "preset") (not= actual-overrides (set declared-overrides)))
      (str "composition.overrides must exactly record changed preset axes: "
           (if (seq actual-overrides) (str/join ", " (sort actual-overrides)) "none"))
      (and (= kind "preset") (seq declared-overrides)
           (let [v (get composition "overrideReason")] (or (not (string? v)) (str/blank? v))))
      "preset axis overrides require composition.overrideReason"
      (and (= kind "preset") (empty? declared-overrides) (contains? composition "overrideReason"))
      "unchanged preset must omit composition.overrideReason"
      (and role known-role? (seq actual-overrides) (nil? composition))
      (str "known role " canonical-role " overrides " (str/join ", " (sort actual-overrides))
           "; supply preset composition.overrides and composition.overrideReason")
      (and role known-role? composition
           (or (not= "preset" kind) (not= canonical-role (get composition "id"))))
      (str "known role " canonical-role " requires preset composition id " canonical-role)

      (and (= kind "bespoke") (contains? composition "nearestPreset")
           (let [v (get composition "nearestPreset")] (or (not (string? v)) (str/blank? v))))
      "bespoke composition.nearestPreset must be a non-empty string when supplied"
      (and (= kind "bespoke") (some? (get composition "nearestPreset"))
           (not (contains? gaffer-role-names (get composition "nearestPreset"))))
      "bespoke composition.nearestPreset must name a canonical preset"
      (and (= kind "bespoke")
           (let [v (get composition "bespokeReason")] (or (not (string? v)) (str/blank? v))))
      "bespoke composition requires bespokeReason"
      (and (= kind "bespoke") (not (boolean? (get composition "promotionCandidate"))))
      "bespoke composition.promotionCandidate must be explicit boolean"
      (and (= kind "bespoke") (not (map? contract))) "bespoke composition.contract must be an object"
      unknown-contract (str "unknown composition.contract field(s): " (str/join ", " unknown-contract))
      (and (= kind "bespoke")
           (some (fn [field]
                   (let [v (get contract field)] (or (not (string? v)) (str/blank? v))))
                 ["responsibility" "deliverable" "report"]))
      "bespoke composition.contract requires responsibility, deliverable, and report"
      (and (= kind "bespoke")
           (some #(not (valid-string-list? (get contract %) true)) ["mayDecide" "mustEscalate" "doneWhen"]))
      "bespoke composition.contract requires non-empty unique mayDecide, mustEscalate, and doneWhen lists"
      (and (= kind "bespoke")
           (or (not (valid-string-list? contract-capabilities true))
               (some #(not (some #{%} capability-values)) contract-capabilities)))
      "bespoke composition.contract capabilities must be non-empty, unique, and canonical"
      capability-problem capability-problem
      (and role (not known-role?)
           (or (not= "bespoke" kind) (not= role (get composition "id")) missing-bespoke-axes))
      (str "unknown role " role " requires complete bespoke composition"
           (when missing-bespoke-axes (str "; missing: " (str/join ", " missing-bespoke-axes))))
      :else nil))))

(defn preflight-exact-target [args]
  (when-let [target (not-empty (get args "target"))]
    (let [provider (or (not-empty (get args "provider")) "auto")
          tier (not-empty (get args "tier"))
          reasoning (or (not-empty (get args "reasoning")) (not-empty (get args "effort")))
          model (not-empty (get args "model"))
          argv [bun "run" route-preflight target provider
                (or tier "-") (or reasoning "-") (or model "-")]
          {:keys [out err exit]} (apply proc/sh argv)]
      (when-not (zero? exit)
        (let [message (str/trim (str err (when (and (seq err) (seq out)) "\n") out))]
          (if (str/blank? message) "exact routing target preflight failed" message))))))

(defn preflight-routing-economics [args]
  ;; This is the single canonical admission seam shared with execution. Gaffer
  ;; derives and validates the sidecar inside the SDK; the MCP edge does not
  ;; carry a weaker copy that could claim a driver before detecting tampering.
  (let [payload (cond-> {"routingMetadata" (select-keys args managed-routing-fields)}
                  (contains? args "routingAssessment")
                  (assoc "routingAssessment" (get args "routingAssessment"))
                  (contains? args "pinEvidence")
                  (assoc "pinEvidence" (get args "pinEvidence"))
                  (contains? args "provider") (assoc "provider" (get args "provider"))
                  (contains? args "target") (assoc "target" (get args "target"))
                  (contains? args "model") (assoc "model" (get args "model")))
        {:keys [out err exit]}
        (proc/sh {:in (json/generate-string payload)}
                 policy-bun "run" routing-economics-preflight)]
    (when-not (zero? exit)
      (let [message (str/trim (str err (when (and (seq err) (seq out)) "\n") out))]
        (if (str/blank? message) "routing economics preflight failed" message)))))

(defn preflight-struggle-policy [args]
  ;; The MCP edge always invokes the same resolver as execution. Its exact JSON
  ;; becomes a one-shot child witness, so defaults and overrides alike cannot
  ;; diverge between admission, selection, and the SDK observer.
  (let [{:keys [out err exit]}
        (proc/sh policy-bun "run" struggle-policy-cli "policy" (get args "topology"))
        expected (str/trim out)]
    (if (zero? exit)
      {:expected expected}
      {:problem (or (not-empty (str/trim err))
                    "invalid struggle detector policy")})))

(defn call-sdk [nm raw-args]
  (let [args (canonicalize-bespoke-routing raw-args)]
    (if-let [problem (north.topology-authority/authority-problem nm)]
      {:content [{:type "text" :text problem}] :isError true}
      (if-let [problem (invalid-routing nm args)]
      {:content [{:type "text" :text problem}] :isError true}
      (if-let [problem (preflight-routing-economics args)]
        {:content [{:type "text" :text problem}] :isError true}
      (if-let [problem (preflight-exact-target args)]
        {:content [{:type "text" :text problem}] :isError true}
        (let [struggle-preflight (preflight-struggle-policy args)]
          (if-let [problem (:problem struggle-preflight)]
            {:content [{:type "text" :text problem}] :isError true}
        (let [parent-env (materialize-instance-env (into {} (System/getenv)))
            coordinator (resolve-coordinator parent-env args)
            env (cond-> (north.managed-child-env/scrub parent-env)
                  (:expected struggle-preflight)
                  (assoc "NORTH_STRUGGLE_POLICY_EXPECTED"
                         (:expected struggle-preflight)))]
        (case nm
          "dispatch"
          (let [id (canonical-north-thread-id (get args "id"))
            model (get args "model")
            effort (get args "effort")
            reasoning (get args "reasoning")
            role (get args "role")
            posture (get args "posture")
            provider (get args "provider")
            target (get args "target")
            tier (get args "tier")
            task-grade (get args "taskGrade")
            domains (get args "domainRequirements")
            topology (get args "topology")
            composition (get args "composition")
            routing-assessment (get args "routingAssessment")
            pin-evidence (get args "pinEvidence")
            agent-id (create-mcp-agent-id id)
            cmd-env (cond-> (assoc env
                              "AGENT_ID" agent-id
                              "NORTH_DISPATCH_DRIVER_PRECLAIMED" "1")
                      model       (assoc "AGENT_MODEL" model)
                      reasoning   (assoc "AGENT_REASONING" reasoning "AGENT_EFFORT" reasoning)
                      role        (assoc "AGENT_ROLE" role)
                      role        (assoc "AGENT_IDENTITY_ROLE" role)
                      posture     (assoc "AGENT_POSTURE" posture)
                      provider    (assoc "AGENT_PROVIDER" provider)
                      target      (assoc "AGENT_TARGET" target)
                      tier        (assoc "AGENT_TIER" tier)
                      task-grade  (assoc "AGENT_TASK_GRADE" task-grade)
                      domains     (assoc "AGENT_DOMAIN_REQUIREMENTS" (json/generate-string domains))
                      topology    (assoc "AGENT_TOPOLOGY" topology)
                      composition (assoc "AGENT_COMPOSITION" (json/generate-string composition))
                      routing-assessment (assoc "AGENT_ROUTING_ASSESSMENT" (json/generate-string routing-assessment))
                      pin-evidence (assoc "NORTH_ROUTING_PIN_EVIDENCE" (json/generate-string pin-evidence))
                      coordinator (assoc "AGENT_COORDINATOR" coordinator))]
        (if-let [problem (claim-driver-problem id agent-id)]
          {:content [{:type "text" :text problem}] :isError true}
          (try
            (let [log (io/file (str (get parent-env "HOME") "/.local/state/north/agents/" agent-id ".log"))
                  process (launch-sdk! [bun "run" (str sdk-dir "/dispatch.ts") id] cmd-env log)
                  _ (watch-driver-release! process id agent-id)
                  startup (await-sdk-startup process agent-id log)
                  suffix (str " for thread @" id
                              (when model (str " model=" model))
                              (when target (str " target=" target))
                              (when coordinator (str " coordinator=" coordinator)))]
              (if (startup-success? startup)
                {:content [{:type "text"
                            :text (str (startup-summary "dispatched" startup suffix)
                                       (when (= :ready (:status startup))
                                         " Watch with `north show` or `north agents`."))}]}
                (do
                  (release-driver! id agent-id)
                  {:content [{:type "text" :text (north.spawn-process/failure-message startup)}]
                   :isError true})))
            (catch Exception _
              (release-driver! id agent-id)
              {:content [{:type "text" :text (str "could not start an agent for thread @" id)}]
               :isError true}))))

          "spawn"
          (let [prompt (get args "prompt")
            model (get args "model")
            effort (get args "effort")
            reasoning (get args "reasoning")
            role (get args "role")
            posture (get args "posture")
            provider (get args "provider")
            target (get args "target")
            tier (get args "tier")
            task-grade (get args "taskGrade")
            domains (get args "domainRequirements")
            topology (get args "topology")
            composition (get args "composition")
            routing-assessment (get args "routingAssessment")
            pin-evidence (get args "pinEvidence")
            caveman (get args "caveman")
            worktree (get args "worktree")
            setup-cmd (get args "setupCmd")
            agent-id (create-mcp-agent-id "spawn")
            cmd-env (cond-> (assoc env "AGENT_ID" agent-id)
                      model       (assoc "AGENT_MODEL" model)
                      reasoning   (assoc "AGENT_REASONING" reasoning "AGENT_EFFORT" reasoning)
                      role        (assoc "AGENT_ROLE" role)
                      role        (assoc "AGENT_IDENTITY_ROLE" role)
                      posture     (assoc "AGENT_POSTURE" posture)
                      provider    (assoc "AGENT_PROVIDER" provider)
                      target      (assoc "AGENT_TARGET" target)
                      tier        (assoc "AGENT_TIER" tier)
                      task-grade  (assoc "AGENT_TASK_GRADE" task-grade)
                      domains     (assoc "AGENT_DOMAIN_REQUIREMENTS" (json/generate-string domains))
                      topology    (assoc "AGENT_TOPOLOGY" topology)
                      composition (assoc "AGENT_COMPOSITION" (json/generate-string composition))
                      routing-assessment (assoc "AGENT_ROUTING_ASSESSMENT" (json/generate-string routing-assessment))
                      pin-evidence (assoc "NORTH_ROUTING_PIN_EVIDENCE" (json/generate-string pin-evidence))
                      caveman     (assoc "AGENT_CAVEMAN" caveman)
                      worktree    (assoc "AGENT_WORKTREE" "1")
                      setup-cmd   (assoc "AGENT_SETUP_CMD" setup-cmd)
                      coordinator (assoc "AGENT_COORDINATOR" coordinator))]
        (try
          (let [log (io/file (str (get parent-env "HOME") "/.local/state/north/agents/" agent-id ".log"))
                process (launch-sdk! [bun "run" (str sdk-dir "/spawn.ts") prompt] cmd-env log)
                startup (await-sdk-startup process agent-id log)
                suffix (str (when model (str " model=" model))
                            (when target (str " target=" target))
                            (when coordinator (str " coordinator=" coordinator)))]
            (if (startup-success? startup)
              {:content [{:type "text"
                          :text (str (startup-summary "spawned" startup suffix)
                                     (when (= :ready (:status startup))
                                       " Watch with `north show` or `north agents`."))}]}
              {:content [{:type "text" :text (north.spawn-process/failure-message startup)}]
               :isError true}))
            (catch Exception _
              {:content [{:type "text" :text "could not start an ad-hoc agent"}]
               :isError true})))))))))))))

;; `untell` is an accepted legacy alias for `retract` — route it to the same tool.
(def tool-aliases {"untell" "retract"})
(defn find-tool [nm] (let [nm (get tool-aliases nm nm)] (first (filter #(= (:name %) nm) tools))))
(defn find-sdk-tool [nm] (first (filter #(= (:name %) nm) sdk-tools)))

;; Result diet — the MCP is the AI-facing edge, so we slim results for the model
;; without touching engine output the CLI/humans rely on. Cuts BYTES, never facts.
(def clock-report-top-n 15)

(defn slim-clock-report
  "Default clock_report: calibration + a compact summary + the top-N threads by
   logged time (threads with zero logged time are omitted — they carry no signal).
   full=true short-circuits this and returns every row. Fails open to raw text."
  [text full?]
  (if full?
    text
    (try
      (let [d (json/parse-string text)
            rows (get d "rows")
            logged (->> rows (filter #(pos? (or (get % "actual_sec") 0)))
                        (sort-by #(- (get % "actual_sec"))))
            total-sec (reduce + 0 (map #(get % "actual_sec") rows))
            top (vec (take clock-report-top-n logged))]
        (json/generate-string
         {:summary {:threads (count rows)
                    :with_logged_time (count logged)
                    :total_logged_h (Double/parseDouble (format "%.1f" (/ total-sec 3600.0)))
                    :shown (count top)
                    :omitted (- (count logged) (count top))
                    :note "top threads by logged time; pass full=true for every thread"}
          :calibration (get d "calibration")
          :rows top}))
      (catch Exception _ text))))

(defn slim-capture
  "capture ack keeps the id+title line; drops the local file path and the
   `Next:` hint (the AI drives via tell, not the .md projection)."
  [text]
  (or (first (str/split-lines text)) text))

(defn slim-output [nm args text]
  (case nm
    "clock_report" (slim-clock-report text (boolean (get args "full")))
    "capture"      (slim-capture text)
    text))

(def max-tool-error-chars 8192)
(defn bound-tool-error [text]
  (if (<= (count text) max-tool-error-chars)
    text
    (let [marker "\n... tool error truncated ...\n"
          available (- max-tool-error-chars (count marker))
          head (quot available 2)
          tail (- available head)]
      (str (subs text 0 head) marker (subs text (- (count text) tail))))))

(defn call-tool [nm args]
  (if-let [st (find-sdk-tool nm)]
    (call-sdk nm (or args {}))
    (if-let [t (find-tool nm)]
      (let [arguments (or args {})]
        (if-let [problem (when-let [argument-problem (:argument-problem t)]
                           (argument-problem arguments))]
          {:content [{:type "text" :text problem}] :isError true}
          (let [argv (mapv str ((:argv t) arguments))
                {:keys [out err exit]} (apply proc/sh engine argv)
                errs (str/trim (or err ""))
                raw (str/trim (str out (when (seq errs) (str "\n[stderr] " errs))))
                text (if (zero? exit)
                       (slim-output nm arguments raw)
                       (bound-tool-error raw))]
            {:content [{:type "text" :text (if (str/blank? text) (str "(done; exit " exit ")") text)}]
             :isError (not (zero? exit))})))
      {:content [{:type "text" :text (str "unknown tool: " nm)}] :isError true})))

(defn tool-descriptor [t]
  (cond-> {:name (:name t) :description (:desc t) :inputSchema (:schema t)}
    (:annotations t) (assoc :annotations (:annotations t))))

(defn tools-list []
  {:tools (into (mapv tool-descriptor tools)
                (mapv tool-descriptor sdk-tools))})

(defn on-initialize [params]
  {:protocolVersion (get params "protocolVersion" "2025-06-18")
   :capabilities {:tools {}}
   :serverInfo {:name "north" :version "0.1.0"}
   :instructions cheatsheet})

(defn emit! [m] (println (json/generate-string m)) (flush))
(defn respond [id result] (emit! {:jsonrpc "2.0" :id id :result result}))
(defn respond-err [id code msg] (emit! {:jsonrpc "2.0" :id id :error {:code code :message msg}}))

(defn handle [line]
  (when-not (str/blank? line)
    (let [msg (try (json/parse-string line) (catch Exception _ nil))]
      (when msg
        (let [id (get msg "id") method (get msg "method") params (get msg "params")]
          (cond
            (= method "initialize")                 (respond id (on-initialize params))
            (= method "notifications/initialized")  nil
            (= method "ping")                       (respond id {})
            (= method "tools/list")                 (respond id (tools-list))
            (= method "tools/call")                 (respond id (call-tool (get params "name") (get params "arguments")))
            (some? id)                              (respond-err id -32601 (str "method not found: " method))
            :else                                   nil))))))

(loop []
  (let [line (read-line)]
    (when (some? line)
      (handle line)
      (recur))))
