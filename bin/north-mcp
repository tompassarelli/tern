#!/usr/bin/env bb
;; North MCP server — the AI-facing edge of one instance.
;;
;; Speaks MCP (JSON-RPC 2.0, newline-delimited, over stdio) and maps each tool
;; call to the existing `north` engine, so it reuses every tested op + the
;; coordinator write path. Reads are off the warm log; writes serialize through
;; the coordinator exactly as the CLI does. A consumer chat AI connects, gets the
;; tools + the cheatsheet (server `instructions`), and never touches a CLI.
;;
;; Config (per instance, via env — the same vars the engine reads):
;;   NORTH_BIN   path to the engine wrapper to invoke (default: sibling `north`)
;;   FRAM_LOG / FRAM_THREADS / provenance vars  passed through to it
;;
;; Transport here is stdio (local, zero-setup). HTTP/SSE + auth is the next layer.
(require '[cheshire.core :as json]
         '[babashka.process :as proc]
         '[clojure.java.io :as io]
         '[clojure.string :as str])

(def here (-> *file* io/file .getCanonicalFile .getParentFile))
(def engine (or (System/getenv "NORTH_BIN") (str here "/north")))

;; The `instructions` block teaches the FACT MODEL + cross-tool norms ONCE —
;; things no single tool description can carry. Per-verb "what it does" lives in
;; each tool's own description (tools/list), so it is NOT repeated here; doing so
;; paid the same bytes twice on every request.
(def cheatsheet
  (str
   "North is a fact-native substrate for coordinating work and life. Every fact "
   "is a triple (subject predicate object); a thread is any id that has a `title`. "
   "Lifecycle is DERIVED from facts, never stored: committed=accepted, outcome=done, "
   "abandoned=canceled, driver=active, depends_on=blocked. Facts record what was "
   "ASSERTED, not verified — supersession, retraction, and views handle disagreement.\n\n"
   "Refs to other threads are written @<id> (e.g. depends_on @2026-06-16-101500); "
   "everything else is a literal. ids look like 2026-06-16-101500.\n\n"
   "Prefer `capture` for new work and `tell`/`retract` for changes; every write is "
   "serialized and rule-checked, so just state facts and let the engine enforce integrity. "
   "The canonical multi-agent flow: capture a thread -> tell it facts -> dispatch it.\n\n"
   "PRESENTATION CONTRACT: list tools return an `emoji` field per item. Render each item "
   "with its given `emoji`; do NOT invent your own. Keep it terse, group by project, lead "
   "with active work. To change a glyph: tell @ui emoji_<condition> \"<glyph>\" "
   "(conditions: active/ready/blocked/draft)."))

;; tool name -> {desc, schema, argv}. argv maps the JSON arguments map (string
;; keys) to the engine argument vector.
(def tools
  [{:name "ready"        :desc "Threads doable now (committed, unblocked, not active, not done). Default: kind=thread, top-15 by leverage. Pass all=true for the full unscoped list. Returns JSON [{id,title,condition,emoji}]."
    :schema {:type "object" :properties {:all {:type "boolean" :description "return every ready thread, unscoped (default false: kind=thread top-15 by leverage)"}}}
    :argv (fn [a] (if (get a "all") ["json" "ready" "--all"] ["json" "ready"]))}
   {:name "next"         :desc "The recommended next thread(s) to pull."
    :schema {:type "object" :properties {}} :argv (fn [_] ["next"])}
   {:name "board"        :desc "Open work, kanban view. Default: the curated slice (kind=thread; live-active + top-15 ready by leverage) — parity with the CLI board. Pass all=true for every open thread unscoped. Returns JSON [{id,title,condition,emoji}] where condition is active/ready/blocked/draft."
    :schema {:type "object" :properties {:all {:type "boolean" :description "return every open thread, unscoped (default false: curated active + top-15 ready)"}}}
    :argv (fn [a] (if (get a "all") ["json" "board" "--all"] ["json" "board"]))}
   {:name "plate"        :desc "Alias of `board` — curated open-work slice by default; all=true for the full dump. Prefer `board`."
    :schema {:type "object" :properties {:all {:type "boolean" :description "return every open thread, unscoped"}}}
    :argv (fn [a] (if (get a "all") ["json" "board" "--all"] ["json" "board"]))}
   {:name "blocked"      :desc "Threads waiting on an unresolved dependency. Returns JSON [{id,title,condition}]."
    :schema {:type "object" :properties {}} :argv (fn [_] ["json" "blocked"])}
   {:name "agenda"       :desc "Calendar view: threads bucketed by do_on (overdue/today/upcoming)."
    :schema {:type "object" :properties {}} :argv (fn [_] ["agenda"])}
   {:name "leverage"     :desc "High-leverage threads — finishing them unblocks the most downstream work."
    :schema {:type "object" :properties {}} :argv (fn [_] ["leverage"])}
   {:name "needs_review" :desc "Belief-revision queue: judgments whose inputs moved. Returns JSON [{id,title,pred,detail}]."
    :schema {:type "object" :properties {}} :argv (fn [_] ["json" "needs-review"])}
   {:name "validate"     :desc "Integrity check over the whole graph."
    :schema {:type "object" :properties {}} :argv (fn [_] ["validate"])}
   {:name "show"         :desc "Show one thread's facts. Returns JSON [{predicate,value}]."
    :schema {:type "object" :properties {:id {:type "string"}} :required ["id"]}
    :argv (fn [a] ["json" "show" (get a "id")])}
   {:name "capture"      :desc "Create a new thread from a title (a thought or unit of work)."
    :schema {:type "object" :properties {:title {:type "string"}
                                         :owner {:type "string" :description "defaults to personal"}}
             :required ["title"]}
    :argv (fn [a] ["capture" (get a "title") (get a "owner" "personal")])}
   {:name "tell"         :desc "Add or replace one fact about a thread. For thread refs (depends_on/part_of/relates_to) pass the bare target id; the engine adds the @."
    :schema {:type "object" :properties {:id {:type "string"}
                                         :predicate {:type "string"}
                                         :value {:type "string"}}
             :required ["id" "predicate" "value"]}
    :argv (fn [a] ["tell" (get a "id") (get a "predicate") (get a "value")])}
   {:name "retract"      :desc "Retract one fact about a thread. (untell accepted as a legacy alias.)"
    :schema {:type "object" :properties {:id {:type "string"}
                                         :predicate {:type "string"}
                                         :value {:type "string"}}
             :required ["id" "predicate" "value"]}
    :argv (fn [a] ["retract" (get a "id") (get a "predicate") (get a "value")])}
   {:name "clock_start"  :desc "Start logging time against a thread (one session at a time)."
    :schema {:type "object" :properties {:id {:type "string"}} :required ["id"]}
    :argv (fn [a] ["clock" "start" (get a "id")])}
   {:name "clock_stop"   :desc "Stop the running time session."
    :schema {:type "object" :properties {}} :argv (fn [_] ["clock" "stop"])}
   {:name "clock_status" :desc "Show the running session + elapsed."
    :schema {:type "object" :properties {}} :argv (fn [_] ["clock" "status"])}
   {:name "clock_report" :desc "Estimate vs actual per thread + calibration %. Default: summary + top rows by logged time (rows with no logged time omitted). Pass full=true for every thread. Returns JSON {summary,calibration,rows[]} or, with full, {calibration,rows[]}."
    :schema {:type "object" :properties {:full {:type "boolean" :description "return every thread (default false: summary + top-N logged)"}}}
    :argv (fn [_] ["json" "clock-report"])}
   {:name "presentation" :desc "The effective emoji map (condition -> glyph), engine defaults + user overrides. Returns JSON {active,ready,blocked,draft}."
    :schema {:type "object" :properties {}} :argv (fn [_] ["json" "presentation"])}])

;; --- SDK agent tools (dispatch/spawn) — shell out to bun, not the engine ----
(def sdk-dir (str (.getParent (io/file (str here))) "/sdk/src"))
(def bun "/run/current-system/sw/bin/bun")

(def task-grade-values ["novice" "junior" "mid" "senior" "staff" "principal" "research-grade"])
(def topology-values ["worker" "verifier" "orchestrator"])
(def composition-schema
  {:type "object"
   :properties {:kind {:type "string" :enum ["preset" "bespoke"]}
                :id {:type "string" :minLength 1}
                :nearestPreset {:type "string" :minLength 1}
                :bespokeReason {:type "string" :minLength 1}
                :promotionCandidate {:type "boolean"}}
   :required ["kind" "id"]
   :allOf [{:if {:properties {:kind {:const "bespoke"}} :required ["kind"]}
            :then {:required ["bespokeReason"]}}]
   :additionalProperties false})
(def routing-properties
  {:taskGrade {:type "string" :enum task-grade-values :description "Real-world work grade; independent of model tier"}
   :domainRequirements {:type "array" :items {:type "string" :minLength 1} :description "Domain expertise/context the lane must load"}
   :topology {:type "string" :enum topology-values :description "Lane's coordination position"}
   :composition composition-schema})

(def sdk-tools
  [{:name "dispatch"
    :desc "Dispatch an agent for a thread (must exist — capture first). North derives posture and routes to an available provider. Returns the agent ID."
    :schema {:type "object"
             :properties {:id {:type "string" :description "Thread ID to dispatch (e.g. 2026-06-27-193317)"}
                          :model {:type "string" :description "opus|sonnet|haiku|fable (default sonnet)"}
                          :effort {:type "string" :description "low|medium|high|xhigh (default high)"}
                          :role {:type "string" :minLength 1 :description "Functional responsibility. Canonical presets include executor, implementer, integrator, designer, scout, and research-scientist; bespoke roles are allowed. researcher is a legacy alias for scout."}
                          :posture {:type "string" :description "explore|deliver|preserve"}
                          :provider {:type "string" :enum ["auto" "anthropic" "openai"] :description "Agent provider (default auto)"}
                          :tier {:type "string" :enum ["economy" "standard" "senior" "frontier"] :description "Provider-neutral capability tier"}
                          :coordinator {:type "string" :description "Caller's north id; the lane pings it on done/death + records a `coordinator` fact. Omit to inherit from AGENT_ID/NORTH_AGENT_ID env; pass explicitly from an interactive session."}
                          :taskGrade (:taskGrade routing-properties)
                          :domainRequirements (:domainRequirements routing-properties)
                          :topology (:topology routing-properties)
                          :composition (:composition routing-properties)}
             :required ["id"]}}
   {:name "spawn"
    :desc "Spawn an ad-hoc agent from a prompt (no thread needed; for thread work prefer capture+dispatch). Returns the agent ID."
    :schema {:type "object"
             :properties {:prompt {:type "string" :description "The task prompt"}
                          :model {:type "string" :description "opus|sonnet|haiku|fable (default sonnet)"}
                          :effort {:type "string" :description "low|medium|high|xhigh (default high)"}
                          :role {:type "string" :minLength 1 :description "Functional responsibility. Canonical presets include executor, implementer, integrator, designer, scout, and research-scientist; bespoke roles are allowed. researcher is a legacy alias for scout."}
                          :posture {:type "string" :description "explore|deliver|preserve"}
                          :provider {:type "string" :enum ["auto" "anthropic" "openai"] :description "Agent provider (default auto)"}
                          :tier {:type "string" :enum ["economy" "standard" "senior" "frontier"] :description "Provider-neutral capability tier"}
                          :caveman {:type "string" :enum ["off" "lite" "full"] :description "Terse-output dial (default ambient AGENT_CAVEMAN)"}
                          :coordinator {:type "string" :description "Caller's north id; see dispatch.coordinator"}
                          :taskGrade (:taskGrade routing-properties)
                          :domainRequirements (:domainRequirements routing-properties)
                          :topology (:topology routing-properties)
                          :composition (:composition routing-properties)}
             :required ["prompt"]}}])

;; Attribution (routing-overhaul PART 1): the spawned lane inherits AGENT_COORDINATOR
;; so it records a `coordinator` fact + pings that id on completion/death — otherwise
;; every MCP-spawned lane shows coordinator "(none)" and audits can't attribute fan-out.
;; The host session's north id is NOT in this server's env (north-mcp registers env:{}),
;; so resolve it in priority order:
;;   1. explicit `coordinator` arg — an interactive session passes its "you are agent …" id;
;;   2. the CALLER's AGENT_ID — for a sub-spawn, this is the parent LANE's own id (its MCP
;;      server inherits {...process.env} incl. AGENT_ID), so sub-delegation attributes to
;;      the immediate parent, not a leaked top-of-tree pin;
;;   3. NORTH_AGENT_ID — a pinned session id (last, so an inherited pin never beats #2).
;; Captured from `env` BEFORE cmd-env reassigns AGENT_ID to the new lane.
(defn resolve-coordinator [env args]
  (or (not-empty (get args "coordinator"))
      (not-empty (get env "AGENT_ID"))
      (not-empty (System/getenv "NORTH_AGENT_ID"))))

(defn invalid-routing [args]
  (let [grade (get args "taskGrade") topology (get args "topology") role (get args "role")
        domains (get args "domainRequirements") composition (get args "composition")]
    (cond
      (and role (or (not (string? role)) (str/blank? role))) "role must be a non-empty string"
      (and grade (not (some #{grade} task-grade-values))) "invalid taskGrade"
      (and topology (not (some #{topology} topology-values))) "invalid topology"
      (and domains (or (not (sequential? domains)) (some #(or (not (string? %)) (str/blank? %)) domains))) "domainRequirements must contain non-empty strings"
      (and composition (not (map? composition))) "composition must be an object"
      (and composition (not (some #{(get composition "kind")} ["preset" "bespoke"]))) "invalid composition.kind"
      (and composition (let [v (get composition "id")] (or (not (string? v)) (str/blank? v)))) "composition.id is required"
      (and composition (contains? composition "nearestPreset")
           (let [v (get composition "nearestPreset")] (or (not (string? v)) (str/blank? v)))) "composition.nearestPreset must be a non-empty string"
      (and composition (contains? composition "promotionCandidate") (not (boolean? (get composition "promotionCandidate")))) "composition.promotionCandidate must be boolean"
      (and (= "bespoke" (get composition "kind"))
           (let [v (get composition "bespokeReason")] (or (not (string? v)) (str/blank? v)))) "bespoke composition requires bespokeReason"
      :else nil)))

(defn call-sdk [nm args]
  (if-let [problem (invalid-routing args)]
    {:content [{:type "text" :text problem}] :isError true}
    (let [env (into {} (System/getenv))
        coordinator (resolve-coordinator env args)]
    (case nm
      "dispatch"
      (let [id (get args "id")
            model (get args "model")
            effort (get args "effort")
            role (get args "role")
            posture (get args "posture")
            provider (get args "provider")
            tier (get args "tier")
            task-grade (get args "taskGrade")
            domains (get args "domainRequirements")
            topology (get args "topology")
            composition (get args "composition")
            agent-id (str "sdk-" (subs (str (java.util.UUID/randomUUID)) 0 8))
            cmd-env (cond-> (assoc env "AGENT_ID" agent-id)
                      model       (assoc "AGENT_MODEL" model)
                      effort      (assoc "AGENT_EFFORT" effort)
                      role        (assoc "AGENT_ROLE" role)
                      posture     (assoc "AGENT_POSTURE" posture)
                      provider    (assoc "AGENT_PROVIDER" provider)
                      tier        (assoc "AGENT_TIER" tier)
                      task-grade  (assoc "AGENT_TASK_GRADE" task-grade)
                      domains     (assoc "AGENT_DOMAIN_REQUIREMENTS" (json/generate-string domains))
                      topology    (assoc "AGENT_TOPOLOGY" topology)
                      composition (assoc "AGENT_COMPOSITION" (json/generate-string composition))
                      coordinator (assoc "AGENT_COORDINATOR" coordinator))]
        (let [log (io/file (str (System/getenv "HOME") "/.local/state/north/agents/" agent-id ".log"))]
          (.mkdirs (.getParentFile log))
          (proc/process {:env cmd-env :out log :err log}
                        bun "run" (str sdk-dir "/dispatch.ts") id))
        {:content [{:type "text" :text (str "dispatched @agent:" agent-id " for thread @" id
                                            (when model (str " model=" model))
                                            (when coordinator (str " coordinator=" coordinator))
                                            "\nAgent is running in the background. "
                                            "Watch via web client (:8088) or `show` the thread.")}]})

      "spawn"
      (let [prompt (get args "prompt")
            model (get args "model")
            effort (get args "effort")
            role (get args "role")
            posture (get args "posture")
            provider (get args "provider")
            tier (get args "tier")
            task-grade (get args "taskGrade")
            domains (get args "domainRequirements")
            topology (get args "topology")
            composition (get args "composition")
            caveman (get args "caveman")
            agent-id (str "sdk-" (subs (str (java.util.UUID/randomUUID)) 0 8))
            cmd-env (cond-> (assoc env "AGENT_ID" agent-id)
                      model       (assoc "AGENT_MODEL" model)
                      effort      (assoc "AGENT_EFFORT" effort)
                      role        (assoc "AGENT_ROLE" role)
                      posture     (assoc "AGENT_POSTURE" posture)
                      provider    (assoc "AGENT_PROVIDER" provider)
                      tier        (assoc "AGENT_TIER" tier)
                      task-grade  (assoc "AGENT_TASK_GRADE" task-grade)
                      domains     (assoc "AGENT_DOMAIN_REQUIREMENTS" (json/generate-string domains))
                      topology    (assoc "AGENT_TOPOLOGY" topology)
                      composition (assoc "AGENT_COMPOSITION" (json/generate-string composition))
                      caveman     (assoc "AGENT_CAVEMAN" caveman)
                      coordinator (assoc "AGENT_COORDINATOR" coordinator))]
        (let [log (io/file (str (System/getenv "HOME") "/.local/state/north/agents/" agent-id ".log"))]
          (.mkdirs (.getParentFile log))
          (proc/process {:env cmd-env :out log :err log}
                        bun "run" (str sdk-dir "/spawn.ts") prompt))
        {:content [{:type "text" :text (str "spawned @agent:" agent-id
                                            (when model (str " model=" model))
                                            (when coordinator (str " coordinator=" coordinator))
                                            "\nAgent is running in the background. "
                                            "Watch via web client (:8088).")}]})))))

;; `untell` is an accepted legacy alias for `retract` — route it to the same tool.
(def tool-aliases {"untell" "retract"})
(defn find-tool [nm] (let [nm (get tool-aliases nm nm)] (first (filter #(= (:name %) nm) tools))))
(defn find-sdk-tool [nm] (first (filter #(= (:name %) nm) sdk-tools)))

;; Result diet — the MCP is the AI-facing edge, so we slim results for the model
;; without touching engine output the CLI/humans rely on. Cuts BYTES, never facts.
(def clock-report-top-n 15)

(defn slim-clock-report
  "Default clock_report: calibration + a compact summary + the top-N threads by
   logged time (threads with zero logged time are omitted — they carry no signal).
   full=true short-circuits this and returns every row. Fails open to raw text."
  [text full?]
  (if full?
    text
    (try
      (let [d (json/parse-string text)
            rows (get d "rows")
            logged (->> rows (filter #(pos? (or (get % "actual_sec") 0)))
                        (sort-by #(- (get % "actual_sec"))))
            total-sec (reduce + 0 (map #(get % "actual_sec") rows))
            top (vec (take clock-report-top-n logged))]
        (json/generate-string
         {:summary {:threads (count rows)
                    :with_logged_time (count logged)
                    :total_logged_h (Double/parseDouble (format "%.1f" (/ total-sec 3600.0)))
                    :shown (count top)
                    :omitted (- (count logged) (count top))
                    :note "top threads by logged time; pass full=true for every thread"}
          :calibration (get d "calibration")
          :rows top}))
      (catch Exception _ text))))

(defn slim-capture
  "capture ack keeps the id+title line; drops the local file path and the
   `Next:` hint (the AI drives via tell, not the .md projection)."
  [text]
  (or (first (str/split-lines text)) text))

(defn slim-output [nm args text]
  (case nm
    "clock_report" (slim-clock-report text (boolean (get args "full")))
    "capture"      (slim-capture text)
    text))

(defn call-tool [nm args]
  (if-let [st (find-sdk-tool nm)]
    (call-sdk nm (or args {}))
    (if-let [t (find-tool nm)]
      (let [argv (mapv str ((:argv t) (or args {})))
            {:keys [out err exit]} (apply proc/sh engine argv)
            errs (str/trim (or err ""))
            raw (str/trim (str out (when (seq errs) (str "\n[stderr] " errs))))
            text (if (zero? exit) (slim-output nm (or args {}) raw) raw)]
        {:content [{:type "text" :text (if (str/blank? text) (str "(done; exit " exit ")") text)}]
         :isError (not (zero? exit))})
      {:content [{:type "text" :text (str "unknown tool: " nm)}] :isError true})))

(defn tools-list []
  {:tools (into (mapv (fn [t] {:name (:name t) :description (:desc t) :inputSchema (:schema t)}) tools)
                (mapv (fn [t] {:name (:name t) :description (:desc t) :inputSchema (:schema t)}) sdk-tools))})

(defn on-initialize [params]
  {:protocolVersion (get params "protocolVersion" "2025-06-18")
   :capabilities {:tools {}}
   :serverInfo {:name "north" :version "0.1.0"}
   :instructions cheatsheet})

(defn emit! [m] (println (json/generate-string m)) (flush))
(defn respond [id result] (emit! {:jsonrpc "2.0" :id id :result result}))
(defn respond-err [id code msg] (emit! {:jsonrpc "2.0" :id id :error {:code code :message msg}}))

(defn handle [line]
  (when-not (str/blank? line)
    (let [msg (try (json/parse-string line) (catch Exception _ nil))]
      (when msg
        (let [id (get msg "id") method (get msg "method") params (get msg "params")]
          (cond
            (= method "initialize")                 (respond id (on-initialize params))
            (= method "notifications/initialized")  nil
            (= method "ping")                       (respond id {})
            (= method "tools/list")                 (respond id (tools-list))
            (= method "tools/call")                 (respond id (call-tool (get params "name") (get params "arguments")))
            (some? id)                              (respond-err id -32601 (str "method not found: " method))
            :else                                   nil))))))

(loop []
  (let [line (read-line)]
    (when (some? line)
      (handle line)
      (recur))))
