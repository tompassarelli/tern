#!/usr/bin/env bb
;; North MCP server — the AI-facing edge of one instance.
;;
;; Speaks MCP (JSON-RPC 2.0, newline-delimited, over stdio) and maps each tool
;; call to the existing `north` engine, so it reuses every tested op + the
;; coordinator write path. Reads are off the warm log; writes serialize through
;; the coordinator exactly as the CLI does. A consumer chat AI connects, gets the
;; tools + the cheatsheet (server `instructions`), and never touches a CLI.
;;
;; Config (per instance, via env — the same vars the engine reads):
;;   NORTH_BIN   path to the engine wrapper to invoke (default: sibling `north`)
;;   FRAM_LOG / FRAM_THREADS / provenance vars  passed through to it
;;
;; Transport here is stdio (local, zero-setup). HTTP/SSE + auth is the next layer.
(require '[cheshire.core :as json]
         '[babashka.process :as proc]
         '[clojure.java.io :as io]
         '[clojure.string :as str])

(def here (-> *file* io/file .getCanonicalFile .getParentFile))
(def engine (or (System/getenv "NORTH_BIN") (str here "/north")))
(load-file (str (.getParentFile here) "/cli/managed-child-env.clj"))
(load-file (str (.getParentFile here) "/cli/gaffer-staffing.clj"))

;; The `instructions` block teaches the FACT MODEL + cross-tool norms ONCE —
;; things no single tool description can carry. Per-verb "what it does" lives in
;; each tool's own description (tools/list), so it is NOT repeated here; doing so
;; paid the same bytes twice on every request.
(def cheatsheet
  (str
   "North is a fact-native substrate for coordinating work and life. Every fact "
   "is a triple (subject predicate object); a thread is any id that has a `title`. "
   "Lifecycle is DERIVED from facts, never stored: committed=accepted, outcome=done, "
   "abandoned=canceled, driver=active, depends_on=blocked. Facts record what was "
   "ASSERTED, not verified — supersession, retraction, and views handle disagreement.\n\n"
   "Refs to other threads are written @<id> (e.g. depends_on @2026-06-16-101500); "
   "everything else is a literal. ids look like 2026-06-16-101500.\n\n"
   "Prefer `capture` for new work and `tell`/`retract` for changes; every write is "
   "serialized and rule-checked, so just state facts and let the engine enforce integrity. "
   "The canonical multi-agent flow: capture a thread -> tell it facts -> dispatch it.\n\n"
   "PRESENTATION CONTRACT: list tools return an `emoji` field per item. Render each item "
   "with its given `emoji`; do NOT invent your own. Keep it terse, group by project, lead "
   "with active work. To change a glyph: tell @ui emoji_<condition> \"<glyph>\" "
   "(conditions: active/ready/blocked/draft)."))

;; tool name -> {desc, schema, argv}. argv maps the JSON arguments map (string
;; keys) to the engine argument vector.
(def read-external-annotations
  {:readOnlyHint true :destructiveHint false :idempotentHint true :openWorldHint true})
(def local-write-annotations
  {:readOnlyHint false :destructiveHint false :idempotentHint true :openWorldHint true})
(def remote-write-annotations
  {:readOnlyHint false :destructiveHint true :idempotentHint false :openWorldHint true})
(def server-property
  {:type "string" :minLength 1 :description "Optional configured Linear MCP server name"})

(def evidence-argument-keys #{"bar" "observed"})
(defn evidence-argument-problem [arguments]
  (cond
    (not (map? arguments)) "arguments must be an object"
    (seq (remove evidence-argument-keys (keys arguments)))
    (str "unknown evidence_record arguments: "
         (str/join ", " (sort (remove evidence-argument-keys (keys arguments)))))
    (not (and (string? (get arguments "bar"))
              (not (str/blank? (get arguments "bar")))))
    "bar must be a non-empty string"
    (not (and (string? (get arguments "observed"))
              (not (str/blank? (get arguments "observed")))))
    "observed must be a non-empty string"
    :else nil))

(defn linear-sync-argument-problem [arguments]
  (let [expected (get arguments "expectedPlanHash")]
    (cond
      (and (some? expected)
           (not (and (string? expected)
                     (or (= expected "none")
                         (re-matches #"[0-9a-f]{64}" expected)))))
      "expectedPlanHash must be 'none' or a 64-character lowercase SHA-256 hash"
      (and (some? expected) (not (true? (get arguments "apply"))))
      "expectedPlanHash requires apply=true"
      :else nil)))

(def tools
  [{:name "ready"        :desc "Threads doable now (committed, unblocked, not active, not done). Default: kind=thread, top-15 by leverage. Pass all=true for the full unscoped list. Returns JSON [{id,title,condition,emoji}]."
    :schema {:type "object" :properties {:all {:type "boolean" :description "return every ready thread, unscoped (default false: kind=thread top-15 by leverage)"}}}
    :argv (fn [a] (if (get a "all") ["json" "ready" "--all"] ["json" "ready"]))}
   {:name "next"         :desc "The recommended next thread(s) to pull."
    :schema {:type "object" :properties {}} :argv (fn [_] ["next"])}
   {:name "board"        :desc "Open work, kanban view. Default: the curated slice (kind=thread; live-active + top-15 ready by leverage) — parity with the CLI board. Pass all=true for every open thread unscoped. Returns JSON [{id,title,condition,emoji}] where condition is active/ready/blocked/draft."
    :schema {:type "object" :properties {:all {:type "boolean" :description "return every open thread, unscoped (default false: curated active + top-15 ready)"}}}
    :argv (fn [a] (if (get a "all") ["json" "board" "--all"] ["json" "board"]))}
   {:name "plate"        :desc "Alias of `board` — curated open-work slice by default; all=true for the full dump. Prefer `board`."
    :schema {:type "object" :properties {:all {:type "boolean" :description "return every open thread, unscoped"}}}
    :argv (fn [a] (if (get a "all") ["json" "board" "--all"] ["json" "board"]))}
   {:name "blocked"      :desc "Threads waiting on an unresolved dependency. Returns JSON [{id,title,condition}]."
    :schema {:type "object" :properties {}} :argv (fn [_] ["json" "blocked"])}
   {:name "agenda"       :desc "Calendar view: threads bucketed by do_on (overdue/today/upcoming)."
    :schema {:type "object" :properties {}} :argv (fn [_] ["agenda"])}
   {:name "leverage"     :desc "High-leverage threads — finishing them unblocks the most downstream work."
    :schema {:type "object" :properties {}} :argv (fn [_] ["leverage"])}
   {:name "needs_review" :desc "Belief-revision queue: judgments whose inputs moved. Returns JSON [{id,title,pred,detail}]."
    :schema {:type "object" :properties {}} :argv (fn [_] ["json" "needs-review"])}
   {:name "validate"     :desc "Integrity check over the whole graph."
    :schema {:type "object" :properties {}} :argv (fn [_] ["validate"])}
   {:name "show"         :desc "Show one thread's facts. Returns JSON [{predicate,value}]."
    :schema {:type "object" :properties {:id {:type "string"}} :required ["id"]}
    :argv (fn [a] ["json" "show" (get a "id")])}
   {:name "capture"      :desc "Create a new thread from a title (a thought or unit of work)."
    :schema {:type "object" :properties {:title {:type "string"}
                                         :owner {:type "string" :description "defaults to personal"}}
             :required ["title"]}
    :argv (fn [a] ["capture" (get a "title") (get a "owner" "personal")])}
   {:name "tell"         :desc "Add or replace one fact about a thread. For thread refs (depends_on/part_of/relates_to) pass the bare target id; the engine adds the @."
    :schema {:type "object" :properties {:id {:type "string"}
                                         :predicate {:type "string"}
                                         :value {:type "string"}}
             :required ["id" "predicate" "value"]}
    :argv (fn [a] ["tell" (get a "id") (get a "predicate") (get a "value")])}
   {:name "evidence_record"
    :desc "Record an observed result for one exact done_when bar on this managed run. Run, thread, reporter, capability, North port, and Fram log are derived from the managed environment; callers supply only bar and observed."
    :schema {:type "object"
             :properties {:bar {:type "string" :minLength 1}
                          :observed {:type "string" :minLength 1}}
             :required ["bar" "observed"]
             :additionalProperties false}
    :annotations local-write-annotations
    :argument-problem evidence-argument-problem
    :argv (fn [a] ["evidence" "record" (get a "bar") (get a "observed")])}
   {:name "retract"      :desc "Retract one fact about a thread. (untell accepted as a legacy alias.)"
    :schema {:type "object" :properties {:id {:type "string"}
                                         :predicate {:type "string"}
                                         :value {:type "string"}}
             :required ["id" "predicate" "value"]}
    :argv (fn [a] ["retract" (get a "id") (get a "predicate") (get a "value")])}
   {:name "clock_start"  :desc "Start logging time against a thread (one session at a time)."
    :schema {:type "object" :properties {:id {:type "string"}} :required ["id"]}
    :argv (fn [a] ["clock" "start" (get a "id")])}
   {:name "clock_stop"   :desc "Stop the running time session."
    :schema {:type "object" :properties {}} :argv (fn [_] ["clock" "stop"])}
   {:name "clock_status" :desc "Show the running session + elapsed."
    :schema {:type "object" :properties {}} :argv (fn [_] ["clock" "status"])}
   {:name "clock_report" :desc "Estimate vs actual per thread + calibration %. Default: summary + top rows by logged time (rows with no logged time omitted). Pass full=true for every thread. Returns JSON {summary,calibration,rows[]} or, with full, {calibration,rows[]}."
    :schema {:type "object" :properties {:full {:type "boolean" :description "return every thread (default false: summary + top-N logged)"}}}
    :argv (fn [_] ["json" "clock-report"])}
   {:name "presentation" :desc "The effective emoji map (condition -> glyph), engine defaults + user overrides. Returns JSON {active,ready,blocked,draft}."
    :schema {:type "object" :properties {}} :argv (fn [_] ["json" "presentation"])}
   {:name "linear_get"
    :desc "Read one Linear issue mechanically through North. Returns the CLI JSON unchanged; does not start a model turn."
    :schema {:type "object"
             :properties {:issue {:type "string" :minLength 1}
                          :server server-property}
             :required ["issue"] :additionalProperties false}
    :annotations read-external-annotations
    :argv (fn [a] (cond-> ["linear" "get" (get a "issue")]
                    (get a "server") (conj "--server" (get a "server"))))}
   {:name "linear_import"
    :desc "Import one Linear issue into North mechanically. Mutates only North's local graph and is idempotent by persisted North-Linear link identity."
    :schema {:type "object"
             :properties {:issue {:type "string" :minLength 1}
                          :server server-property}
             :required ["issue"] :additionalProperties false}
    :annotations local-write-annotations
    :argv (fn [a] (cond-> ["linear" "import" (get a "issue")]
                    (get a "server") (conj "--server" (get a "server"))))}
   {:name "linear_plan"
    :desc "Compute a read-only North-to-Linear synchronization plan for one thread. Returns JSON and performs no writes."
    :schema {:type "object"
             :properties {:thread {:type "string" :minLength 1}
                          :server server-property}
             :required ["thread"] :additionalProperties false}
    :annotations read-external-annotations
    :argv (fn [a] (cond-> ["linear" "plan" (get a "thread")]
                    (get a "server") (conj "--server" (get a "server"))))}
   {:name "linear_sync"
    :desc "Plan synchronization for one North thread. Remote writes occur only when apply=true; expectedPlanHash makes apply compare the freshly locked plan before mutation."
    :schema {:type "object"
             :properties {:thread {:type "string" :minLength 1}
                          :apply {:type "boolean" :description "Apply the plan to Linear (default false)"}
                          :expectedPlanHash {:type "string"
                                             :pattern "^(none|[0-9a-f]{64})$"
                                             :description "Require this exact fresh plan hash, or none for an in-sync no-op"}
                          :server server-property}
             :required ["thread"] :additionalProperties false}
    :annotations remote-write-annotations
    :argument-problem linear-sync-argument-problem
    :argv (fn [a] (cond-> ["linear" "sync" (get a "thread")]
                    (true? (get a "apply")) (conj "--apply")
                    (get a "expectedPlanHash") (conj "--expect-plan-hash" (get a "expectedPlanHash"))
                    (get a "server") (conj "--server" (get a "server"))))}])

