#!/usr/bin/env bash
# north-on-spawn — Claude Code / Codex SessionStart + SubagentStart hook.
# Registers the agent's presence on the north roster and injects the concern-
# coordination protocol into the new session via hookSpecificOutput.additionalContext
# — so an agent coordinates the moment it spawns, no human pasting anything.
# SessionStart cannot block startup; all graph maintenance is best-effort.
set -uo pipefail
umask 077
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
NORTH_HOME="${NORTH_HOME:-$(cd "$SCRIPT_DIR/.." && pwd)}"
export NORTH_HOME
ACTOR_KEY="$SCRIPT_DIR/north-actor-key"

# The provider allows 15s, but startup must never approach that deadline. Buffer
# one complete envelope behind a much smaller circuit breaker; malformed input,
# a wedged filesystem, or an unexpected crash becomes an empty successful hook
# instead of a provider-visible SessionStart timeout or truncated JSON.
if [ "${NORTH_SPAWN_INNER:-0}" != 1 ]; then
  out_dir="${XDG_RUNTIME_DIR:-/tmp}"
  timeout --signal=TERM --kill-after=0.1s 0.3s mkdir -p "$out_dir" 2>/dev/null || out_dir=/tmp
  in=""
  out=""
  trap '[ -z "${in:-}" ] || timeout --signal=TERM --kill-after=0.1s 0.2s rm -f -- "${in:?}" 2>/dev/null || true; [ -z "${out:-}" ] || timeout --signal=TERM --kill-after=0.1s 0.2s rm -f -- "${out:?}" 2>/dev/null || true' EXIT
  in="$(timeout --signal=TERM --kill-after=0.1s 0.3s \
    mktemp "$out_dir/north-spawn-input.XXXXXX" 2>/dev/null || true)"
  out="$(timeout --signal=TERM --kill-after=0.1s 0.3s \
    mktemp "$out_dir/north-spawn-output.XXXXXX" 2>/dev/null || true)"
  [ -n "$in" ] && [ -n "$out" ] || exit 0
  timeout --signal=TERM --kill-after=0.2s 1s cat >"$in" 2>/dev/null || exit 0
  NORTH_SPAWN_INNER=1 timeout --signal=TERM --kill-after=0.2s 3s \
    "$0" <"$in" >"$out" 2>/dev/null || true
  out_bytes="$(timeout --signal=TERM --kill-after=0.1s 0.2s \
    stat -c %s -- "${out:?}" 2>/dev/null || true)"
  case "$out_bytes" in ''|*[!0-9]*) out_bytes=0 ;; esac
  if [ "$out_bytes" -gt 0 ] && [ "$out_bytes" -le 32768 ] &&
      timeout --signal=TERM --kill-after=0.1s 1s python3 -c '
import json, sys
allowed = {"SessionStart", "SubagentStart", "SubagentSessionStart"}
with open(sys.argv[1], encoding="utf-8") as handle:
    source = json.load(handle)
expected = source.get("hook_event_name", "SessionStart")
assert isinstance(expected, str) and expected in allowed
with open(sys.argv[2], encoding="utf-8") as handle:
    payload = json.load(handle)
specific = payload["hookSpecificOutput"]
assert specific["hookEventName"] == expected
assert isinstance(specific["additionalContext"], str)
' "$in" "$out" 2>/dev/null; then
    cat -- "${out:?}"
  fi
  exit 0
fi

# Parse the envelope once. Provider hook payloads can be large, and the former
# per-field sed scans multiplied that cost while misparsing escaped strings.
PARSED="$(python3 -c '
import json, sys
try:
    d = json.load(sys.stdin)
    effort = d.get("effort")
    effort = effort.get("level", "") if isinstance(effort, dict) else ""
    values = (
        d.get("cwd", ""),
        d.get("session_id", ""),
        d.get("agent_id", ""),
        d.get("hook_event_name", ""),
        d.get("model", ""),
        effort,
    )
    for value in values:
        value = value if isinstance(value, str) else ""
        print(value.replace("\n", "").replace("\r", ""))
except Exception:
    pass
' 2>/dev/null || true)"
mapfile -t JFIELDS <<<"$PARSED"
cwd="${JFIELDS[0]:-}"; [ -z "$cwd" ] && cwd="$PWD"
sid="${JFIELDS[1]:-}"
agent_id="${JFIELDS[2]:-}"
evt="${JFIELDS[3]:-}"; [ -z "$evt" ] && evt="SessionStart"
MODEL="${JFIELDS[4]:-}"
EFFORT="${JFIELDS[5]:-}"
case "$evt" in
  SessionStart|SubagentStart|SubagentSessionStart) ;;
  *) exit 0 ;;
esac

# Freeze the dispatch topology that was in force when this provider-native
# actor began. Report-time config is mutable context, never historical proof.
dispatch_mode_at_start="north"
harness_state="${NORTH_HARNESS_STATE:-$HOME/.local/state/north/harness.conf}"
legacy_harness_state="${NORTH_LEGACY_HARNESS_STATE:-$HOME/.claude/my-config.state}"
if [ -f "$harness_state" ]; then
  dispatch_source="$harness_state"
elif [ -f "$legacy_harness_state" ]; then
  dispatch_source="$legacy_harness_state"
else
  dispatch_source=""
fi
if [ -n "$dispatch_source" ]; then
  observed_dispatch="$(awk -F= '$1 == "dispatch" { value=$2 } END { print value }' "$dispatch_source" 2>/dev/null || true)"
  case "$observed_dispatch" in
    north|warn|native) dispatch_mode_at_start="$observed_dispatch" ;;
    "") ;;
    *) dispatch_mode_at_start="unknown" ;;
  esac
fi
# SubagentStart carries a provider-owned `agent_id`; on Codex its session_id is
# explicitly the PARENT session. Keying presence/cache by that parent would
# collapse every native subagent onto one row. Prefer the actor id when present.
if [ "$evt" = "SubagentStart" ] && [ -n "$agent_id" ]; then
  identity_kind="agent"
  identity_sid="$agent_id"
elif [ -n "$sid" ]; then
  identity_kind="session"
  identity_sid="$sid"
else
  identity_kind="managed"
  identity_sid="${NORTH_AGENT_ID:-}"
fi
[ -n "$identity_sid" ] || exit 0
identity_key="$("$ACTOR_KEY" "$identity_kind" "$identity_sid" 2>/dev/null || true)"
[ "${#identity_key}" -eq 64 ] || exit 0
case "$evt" in
  SubagentStart|SubagentSessionStart)
    native_actor_kind="subagent"
    native_depth="1"
    native_parent_actor_key="$("$ACTOR_KEY" session "$sid" 2>/dev/null || true)"
    [ "${#native_parent_actor_key}" -eq 64 ] || native_parent_actor_key="unobserved"
    ;;
  *)
    native_actor_kind="root"
    native_depth="0"
    native_parent_actor_key=""
    ;;
esac
pin="${NORTH_AGENT_ID:-}"
if [ -n "$pin" ]; then
  pin_validation="$("$ACTOR_KEY" managed "$pin" 2>/dev/null || true)"
  [ "${#pin_validation}" -eq 64 ] || pin=""
fi
REPO="$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null || echo "$cwd")"
RN="$(basename "$REPO")"
IDDIR="${XDG_RUNTIME_DIR:-/tmp}/north-agent-ids"
ROUTEDIR="${XDG_RUNTIME_DIR:-/tmp}/north-agent-routes"
# Provider actor IDs are control identity, not decoration. Filesystem keys and
# derived graph IDs use the complete domain-separated SHA-256 actor key; raw
# provider/repo text is display provenance only and cannot alias or exceed
# NAME_MAX.
DERIVED="native-$identity_key"

# Identity, de-aliased. INVARIANT: one live actor == one id; an id is only
# renewed/registered by the session that FIRST acquired it. An env pin
# (NORTH_AGENT_ID) is honored ONLY if no OTHER session already owns it. Otherwise
# it is an inherited parent pin and this actor derives a distinct id.
#
# Pin ownership uses an atomic hard-link claim. The former scan -> choose ->
# write sequence was TOCTOU: concurrent sibling starts could both observe no
# cache owner and both publish the same inherited pin. A fully written temp file
# is linked into the stable claim name atomically, so every contender observes
# one complete winner. Existing pre-claim cache entries seed the first claim.
ID=""
if [ -n "$pin" ]; then
  pin_owners="$IDDIR/.pin-owners"
  # Reuse the canonical managed-actor key for both the claim name and every
  # actor cache. A second ad-hoc hash namespace would make collision audits and
  # migration reasoning needlessly ambiguous.
  pin_digest="$pin_validation"
  existing_owner=""
  conflicting_owners=0
  if mkdir -p "$IDDIR" "$pin_owners" 2>/dev/null; then
    for f in "$IDDIR"/*; do
      [ -f "$f" ] || continue
      [ "$(cat "$f" 2>/dev/null || true)" = "$pin" ] || continue
      if [ -z "$existing_owner" ]; then
        existing_owner="${f##*/}"
      elif [ "$existing_owner" != "${f##*/}" ]; then
        conflicting_owners=1
      fi
    done
    claim_owner="${existing_owner:-$identity_key}"
    [ "$conflicting_owners" -eq 0 ] || claim_owner="__conflicting_legacy_owners__"
    claim_file="$pin_owners/$pin_digest"
    claim_tmp="$pin_owners/.$pin_digest.$$.${RANDOM}.tmp"
    if printf '%s' "$claim_owner" >"$claim_tmp" 2>/dev/null; then
      ln "$claim_tmp" "$claim_file" 2>/dev/null || true
      rm -f -- "${claim_tmp:?}" 2>/dev/null || true
    fi
    committed_owner="$(cat "$claim_file" 2>/dev/null || true)"
    [ "$committed_owner" = "$identity_key" ] && ID="$pin"
  fi
fi
[ -z "$ID" ] && ID="$DERIVED"

# pin identity for the session's lifetime: tooluse renews THIS id, whatever cwd later
# tool calls run in. Without the pin, identity flapped per (cwd-repo x session) and the
# roster flooded with phantoms (188 cc-after-text-* ghosts, 2026-07-02).
if [ -n "$identity_key" ]; then
  identity_tmp="$IDDIR/.$identity_key.$$.${RANDOM}.tmp"
  if mkdir -p "$IDDIR" 2>/dev/null && printf '%s' "$ID" >"$identity_tmp" 2>/dev/null; then
    mv -f "$identity_tmp" "$IDDIR/$identity_key" 2>/dev/null || rm -f -- "${identity_tmp:?}" 2>/dev/null || true
  fi
fi

PROVIDER=""
case "${AGENT_PROVIDER:-}" in
  anthropic|openai) PROVIDER="$AGENT_PROVIDER" ;; # explicit SDK/provider boundary
esac
if [ -z "$PROVIDER" ] && { [ -n "${CODEX_THREAD_ID:-}" ] || [ -n "${CODEX_CI:-}" ]; }; then
  PROVIDER="openai"
elif [ -z "$PROVIDER" ] && [ -n "${CLAUDECODE:-}" ]; then
  PROVIDER="anthropic"
fi
# SessionStart carries the active model on both provider surfaces. Claude
# tool-context hooks also expose effective effort; Codex hooks currently do not.
# Prefer exact hook observations over adapter env. `unobserved` is an explicit
# epistemic state, never an inferred model/effort/provider claim.
[ -n "$MODEL" ] || MODEL="${AGENT_MODEL:-}"
[ -n "$EFFORT" ] || EFFORT="${CLAUDE_EFFORT:-${AGENT_REASONING:-${AGENT_EFFORT:-}}}"
PROVIDER_OBS="${PROVIDER:-unobserved}"
MODEL_OBS="${MODEL:-unobserved}"
EFFORT_OBS="${EFFORT:-unobserved}"
# Preserve the exact SessionStart observations independently from the route
# cache. The route cache is a convergence marker and must stay absent when any
# graph projection fails; this seed is evidence for the PostToolUse repair path,
# so Codex does not lose its observed provider merely because its later hook has
# no CODEX_* marker. It is never inferred from a model name.
if [ -n "$identity_key" ]; then
  route_seed="$ROUTEDIR/$identity_key.seed"
  seed_tmp="$ROUTEDIR/.$identity_key.$$.seed.tmp"
  if mkdir -p "$ROUTEDIR" 2>/dev/null &&
      printf '%s\n%s\n%s\n' "$PROVIDER_OBS" "$MODEL_OBS" "$EFFORT_OBS" > "$seed_tmp" 2>/dev/null; then
    mv -f "$seed_tmp" "$route_seed" 2>/dev/null || rm -f -- "${seed_tmp:?}" 2>/dev/null || true
  fi
fi
slug() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9][^a-z0-9]*/-/g; s/^-//; s/-$//'
}
provider_segment="$(slug "$PROVIDER_OBS")"; [ -n "$provider_segment" ] || provider_segment="unobserved"
model_segment="$(slug "$MODEL_OBS")"; [ -n "$model_segment" ] || model_segment="unobserved"
effort_segment="$(slug "$EFFORT_OBS")"; [ -n "$effort_segment" ] || effort_segment="unobserved"
DISPLAY_HANDLE="$provider_segment-$model_segment-$effort_segment-native-${ID##*-}"

acquire_singleflight() {
  local lock="$1" stale_after_s="$2" now_s modified_s
  mkdir "$lock" 2>/dev/null && return 0
  now_s="$(date +%s 2>/dev/null || echo 0)"
  modified_s="$(stat -c %Y "$lock" 2>/dev/null || echo 0)"
  case "$now_s:$modified_s" in
    *[!0-9:]*|0:*|*:0) return 1 ;;
  esac
  [ $((now_s - modified_s)) -ge "$stale_after_s" ] || return 1
  rmdir -- "${lock:?}" 2>/dev/null || return 1
  mkdir "$lock" 2>/dev/null
}

# Presence and graph projection are maintenance, not bootstrap context. Launch
# them once per actor behind a shared deadline; the foreground has already
# resolved and pinned the exact ID that both context and this worker use.
schedule_spawn_maintenance() {
  local lock="$ROUTEDIR/$identity_key.spawn.lock"
  local route_cache="$ROUTEDIR/$identity_key"
  local route_tmp="$ROUTEDIR/.$identity_key.$$.${RANDOM}.tmp"
  mkdir -p "$ROUTEDIR" 2>/dev/null || return 0
  acquire_singleflight "$lock" 10 || return 0
  (
    trap 'rm -f -- "${route_tmp:?}" 2>/dev/null || true; rm -rf -- "${lock:?}" 2>/dev/null || true' EXIT
    timeout --signal=TERM --kill-after=0.2s 3s \
      bb "$NORTH_HOME/cli/presence-cli.clj" "${NORTH_PORT:-7977}" \
      register "$ID" "$REPO" "$ID" >/dev/null 2>&1 &
    presence_pid=$!
    timeout --signal=TERM --kill-after=0.2s 6s env \
      NORTH_NATIVE_PORT="${NORTH_PORT:-7977}" \
      NORTH_NATIVE_SUBJECT="@agent:$ID" \
      NORTH_NATIVE_REPO="$RN" \
      NORTH_NATIVE_PROVIDER="$PROVIDER_OBS" \
      NORTH_NATIVE_MODEL="$MODEL_OBS" \
      NORTH_NATIVE_EFFORT="$EFFORT_OBS" \
      NORTH_NATIVE_DISPLAY="$DISPLAY_HANDLE" \
      NORTH_NATIVE_ACTOR_KIND="$native_actor_kind" \
      NORTH_NATIVE_DEPTH="$native_depth" \
      NORTH_NATIVE_DISPATCH_MODE_AT_START="$dispatch_mode_at_start" \
      NORTH_NATIVE_PARENT_ACTOR_KEY="$native_parent_actor_key" \
      bb -e '
        (load-file (str (System/getenv "NORTH_HOME") "/cli/coord.clj"))
        (let [port (Integer/parseInt (System/getenv "NORTH_NATIVE_PORT"))
              subject (System/getenv "NORTH_NATIVE_SUBJECT")
              base-facts [["kind" "session"]
                     ["repo" (System/getenv "NORTH_NATIVE_REPO")]
                     ["provider" (System/getenv "NORTH_NATIVE_PROVIDER")]
                     ["model" (System/getenv "NORTH_NATIVE_MODEL")]
                     ["effort" (System/getenv "NORTH_NATIVE_EFFORT")]
                     ["execution_source" "provider-native"]
                     ["execution_transport" "provider-hook"]
                     ["provider_session_persistence" "unknown"]
                     ["thread_provenance" "unknown"]
                     ["turn_provenance" "unknown"]
                     ["native_actor_kind" (System/getenv "NORTH_NATIVE_ACTOR_KIND")]
                     ["native_depth" (System/getenv "NORTH_NATIVE_DEPTH")]
                     ["dispatch_mode_at_start"
                      (System/getenv "NORTH_NATIVE_DISPATCH_MODE_AT_START")]
                     ["display_handle" (System/getenv "NORTH_NATIVE_DISPLAY")]
                     ["display_name" (System/getenv "NORTH_NATIVE_DISPLAY")]]
              facts (cond-> base-facts
                      (seq (System/getenv "NORTH_NATIVE_PARENT_ACTOR_KEY"))
                      (conj ["native_parent_actor_key"
                             (System/getenv "NORTH_NATIVE_PARENT_ACTOR_KEY")]))
              results (mapv (fn [[p r]] (north.coord/put! port subject p r)) facts)]
          (when (some :reject results) (System/exit 1)))' >/dev/null 2>&1 &
    projection_pid=$!
    projection_ok=0
    wait "$projection_pid" && projection_ok=1
    wait "$presence_pid" 2>/dev/null || true
    # The route cache is a convergence marker. Commit it only after every
    # identity fact lands, so PostToolUse repairs any failed projection.
    if [ "$projection_ok" -eq 1 ] &&
        printf '%s\n%s\n%s\n' "$PROVIDER_OBS" "$MODEL_OBS" "$EFFORT_OBS" >"$route_tmp" 2>/dev/null; then
      mv -f "$route_tmp" "$route_cache" 2>/dev/null || rm -f -- "${route_tmp:?}" 2>/dev/null || true
    fi
  ) </dev/null >/dev/null 2>&1 &
}

CTX="$(cat <<EOF
[north coordination active — you are agent "$ID" in repo "$RN"]
Other agents may be working here concurrently. You coordinate through CONCERNS, not locks —
work coexists; declaring never blocks. See who else is in your footprint, and shape your
feature against what is likely to land before it is in main.
  $NORTH_HOME/bin/concern declare $ID $RN "<what you're building>" <file1,file2,...>
  $NORTH_HOME/bin/concern overlap <your-id>   # who's in your footprint; likely-to-land marked -> build against it
  $NORTH_HOME/bin/concern status <id> likely-to-land · done <id> · ls [repo]
Declare a concern before editing code for a feature, so others can see + shape around your work.

Internal notes / status / scratch / handoffs -> docs/private/ (gitignored), NEVER public docs/.
Run \`$NORTH_HOME/bin/ensure-private-docs\` to set up the ignore in a repo before writing there.

To be reachable in REAL TIME, arm your interrupt listener as a BACKGROUND task now:
  $NORTH_HOME/bin/north listen $ID
Dormant (no tokens) until a peer addresses you; when it returns you have mail — read it, act, re-arm.
Ping a peer:  bb $NORTH_HOME/cli/msg-cli.clj 7977 send $ID <peer-id> "URGENT" "<message>"
EOF
)"

# Emit bootstrap context before starting any external maintenance. The real
# serializer keeps repo/identity text with control characters valid JSON.
printf '%s' "$CTX" | HOOK_EVENT_NAME="$evt" python3 -c '
import json, os, sys
payload = {
    "hookSpecificOutput": {
        "hookEventName": os.environ["HOOK_EVENT_NAME"],
        "additionalContext": sys.stdin.read(),
    }
}
sys.stdout.write(json.dumps(payload, ensure_ascii=False, separators=(",", ":")) + "\n")
' 2>/dev/null || true

schedule_spawn_maintenance
exit 0
