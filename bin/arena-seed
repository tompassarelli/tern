#!/usr/bin/env bb
;; EXP-025 ARENA seed — fabricates a filmable demo run for the north web arena.
;;
;; Creates 5 shared tasks × 2 arms (control | graph) as board threads carrying
;; the fixed event contract (exp_id, arm, task_id, title, state, tokens,
;; wall_s, updated), then drives their states over ~60s so /arena?exp=<id>
;; renders + updates live. The graph arm uses fewer tokens and less wall time;
;; the control arm burns extra attempts and usage, one task blocks, one fails.
;;
;; One process, one short-lived TCP socket per op through North's shared,
;; corpus-fenced coordinator transport. Re-drivable: each run mints a FRESH exp
;; id unless one is passed.
;;
;;   usage: bin/arena-seed [exp_id]
(require '[clojure.java.io :as io])

(def ROOT
  (some-> (System/getProperty "babashka.file")
          io/file .getCanonicalFile .getParentFile .getParentFile str))
(load-file (str ROOT "/cli/coord.clj"))

(defn parse-port [raw]
  (when-not (and (string? raw) (re-matches #"[1-9][0-9]{0,4}" raw))
    (throw (ex-info "NORTH_PORT/FRAM_PORT must be an integer from 1 through 65535"
                    {:port raw})))
  (let [port (parse-long raw)]
    (when (> port 65535)
      (throw (ex-info "NORTH_PORT/FRAM_PORT must be an integer from 1 through 65535"
                      {:port raw})))
    (int port)))

(def PORT
  (parse-port
   (or (System/getenv "NORTH_PORT")
       (System/getenv "FRAM_PORT")
       north.coord/PORT)))
(def exp (or (first *command-line-args*)
             (str "EXP-025-demo-"
                  (.format (java.time.LocalTime/now)
                           (java.time.format.DateTimeFormatter/ofPattern "HHmmss")))))

(defn now-iso []
  (.format (java.time.OffsetDateTime/now java.time.ZoneOffset/UTC)
           (java.time.format.DateTimeFormatter/ofPattern "yyyy-MM-dd'T'HH:mm:ss'Z'")))

(defn assert! [te p r]
  (let [resp (north.coord/swap! PORT te p r)]
    (when-not (or (:ok resp) (:version resp))
      (throw (ex-info (str "arena seed write rejected for " te " " p)
                      {:response resp :subject te :predicate p})))
    resp))

(def task-ids ["PR-142" "PR-153" "PR-188" "PR-201" "PR-219"])
(def titles ["fix cljs reader edge case" "nil-safe transducer arity"
             "async channel close race" "spec gen shrink loop"
             "protocol dispatch cache"])

;; deterministic, human-legible thread ids so a re-run of the SAME exp reuses
;; the same threads (no duplicate discovery).
(defn tid [arm idx] (str "@arena-" exp "-" arm "-" idx))

(defn capture! [arm idx]
  (let [id (tid arm idx) t (nth task-ids idx)]
    (assert! id "title"    (str "[" arm "] " t " " (nth titles idx)))
    (assert! id "exp_id"   exp)
    (assert! id "arm"      arm)
    (assert! id "task_id"  t)
    (assert! id "state"    "pending")
    (assert! id "tokens"   "0")
    (assert! id "wall_s"   "0")
    (assert! id "updated"  (now-iso))))

(defn mut [arm idx state tokens wall]
  (let [id (tid arm idx)]
    (assert! id "state"    state)
    (assert! id "tokens"   tokens)
    (assert! id "wall_s"   wall)
    (assert! id "updated"  (now-iso))))

(println "arena exp:" exp)
(println "open:      http://127.0.0.1:8088/arena?exp=" exp)
(println)
(println "capturing 10 task threads…")
(doseq [idx (range 5) arm ["control" "graph"]] (capture! arm idx))
(println "seeded. driving states (~60s)…")

(defn step [t ms]
  (println (str "  t+" t "s"))
  (when-not (= "1" (System/getenv "NORTH_ARENA_NO_SLEEP"))
    (Thread/sleep ms)))

;; kick everything to running
(doseq [idx (range 5)] (mut "graph" idx "running" "50" "3"))
(doseq [idx (range 5)] (mut "control" idx "running" "80" "4"))
(step 4 4000)

(mut "graph" 0 "green" "110" "12")
(mut "graph" 1 "running" "140" "11")
(mut "control" 0 "running" "310" "18")
(mut "control" 1 "attempt-2" "440" "22")
(step 9 5000)

(mut "graph" 1 "green" "190" "17")
(mut "graph" 2 "running" "160" "14")
(mut "control" 0 "attempt-2" "550" "29")
(mut "control" 2 "blocked" "380" "24")
(step 15 6000)

(mut "graph" 2 "green" "240" "21")
(mut "graph" 3 "running" "200" "16")
(mut "control" 0 "green" "710" "41")
(mut "control" 1 "attempt-3" "660" "35")
(mut "control" 4 "attempt-2" "520" "31")
(step 22 7000)

(mut "graph" 3 "green" "270" "24")
(mut "graph" 4 "running" "220" "18")
(mut "control" 1 "green" "880" "44")
(mut "control" 3 "running" "490" "33")
(step 30 8000)

(mut "graph" 4 "green" "310" "27")
(mut "control" 3 "attempt-2" "740" "46")
(mut "control" 4 "attempt-3" "810" "48")
(step 40 10000)

(mut "control" 3 "green" "1020" "58")
(mut "control" 4 "failed" "1190" "63")
(mut "control" 2 "blocked" "610" "61")
(step 52 12000)

(println)
(println "done. control landed 3/5 (PR-188 blocked, PR-219 failed); graph landed 5/5.")
(println "arena still live at: http://127.0.0.1:8088/arena?exp=" exp)
